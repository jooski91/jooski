let dragSrcId=null;
function initEmpDrag(){
  dom('emp-list').querySelectorAll('.emp-card:not(.no-drag)').forEach(card=>{
    card.addEventListener('dragstart',e=>{
      dragSrcId=parseInt(card.dataset.eid);
      card.classList.add('dragging');
      e.dataTransfer.effectAllowed='move';
    });
    card.addEventListener('dragend',()=>{
      card.classList.remove('dragging');
      dom('emp-list').querySelectorAll('.emp-card').forEach(c=>c.classList.remove('drag-over'));
    });
    card.addEventListener('dragover',e=>{
      e.preventDefault();e.dataTransfer.dropEffect='move';
      dom('emp-list').querySelectorAll('.emp-card').forEach(c=>c.classList.remove('drag-over'));
      if(parseInt(card.dataset.eid)!==dragSrcId)card.classList.add('drag-over');
    });
    card.addEventListener('dragleave',()=>card.classList.remove('drag-over'));
    card.addEventListener('drop',e=>{
      e.preventDefault();e.stopPropagation();
      const targetId=parseInt(card.dataset.eid);
      if(dragSrcId===null||dragSrcId===targetId)return;
      const fromIdx=emps.findIndex(x=>x.id===dragSrcId);
      const toIdx=emps.findIndex(x=>x.id===targetId);
      if(fromIdx<0||toIdx<0)return;
      const [moved]=emps.splice(fromIdx,1);
      emps.splice(toIdx,0,moved);
      dragSrcId=null;
      renderEmpList();renderAll();
    });
  });
}
