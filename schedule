

<!DOCTYPE html>
<html lang="ko"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=1200, initial-scale=1.0, minimum-scale=1.0">
<title>스케줄 관리</title>
<link href="https://fonts.googleapis.com/css2?family=Pretendard:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@400;600&amp;display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#ffffff;--surface:#ffffff;--surface2:#ffffff;--surface3:#f0f0f0;--even-row:#ffffff;
  --th-head-bg:#e8e8e8;
  --border:#c8c8c8;--border2:#b0b0b0;--border-sep:#c8c8c8;
  --text:#1a1d2e;--text2:#4a4a4a;--text3:#808080;
  --accent:#3a75e8;--accent2:#2960d0;--red:#e03050;--green:#1a9e60;--yellow:#c88a00;
  --O-bg:#fff176;  --O-c:#e03050;
  --C-bg:#d6f5e0;  --C-c:#1a7a3c;
  --h-bg:#ffe0e5;  --h-c:#b0001e;
  --R-bg:#ffd0d5;  --R-c:#aa001a;
  --V-bg:#daeeff;  --V-c:#1a5a9e;
  --y-bg:#ece6ff;  --y-c:#4a20aa;
  --ban-bg:#fff0d8;--ban-c:#8a4000;
  --g-bg:#d0f0ff;  --g-c:#005a88;
  --birth-bg:#fce0ff;--birth-c:#aa00cc;
  --sat-head-bg:#daeeff;--sat-head-c:#1a5a9e;
  --sun-head-bg:#ffe0e3;--sun-head-c:#b0001e;
  --sat-cell-bg:#eef5ff;--sun-cell-bg:#fff0f0;
  --cov-ok-bg:#d6f5e0;--cov-ok-c:#1a7a3c;
  --cov-zero-bg:#ffe0e3;
  --shadow:rgba(0,0,0,.12);
  --overlay:rgba(30,35,60,.35);
  --today-head-bg:#00FFFF;--today-head-c:#000000;
  --today-cell-bg:#eef8d0;
}
html,body{height:100%;overflow:hidden;margin:0;padding:0}
body{font-family:'Pretendard',sans-serif;background:var(--bg);color:var(--text);font-size:13px;display:flex;flex-direction:column}

.date-picker-wrap{position:relative;display:inline-block;width:100%}
.date-display-btn{width:100%;padding:5px 8px;border:1px solid var(--border2);border-radius:6px;background:var(--surface2);color:var(--text);font-size:12px;font-family:inherit;cursor:pointer;text-align:left;display:flex;align-items:center;justify-content:space-between;transition:border-color .15s}
.date-display-btn:hover{border-color:var(--accent)}
.date-display-btn.has-value{color:var(--text)}
.date-display-btn.empty{color:var(--text3)}
.date-popup{position:fixed;z-index:20000;background:var(--surface);border:1px solid var(--border2);border-radius:10px;padding:12px;box-shadow:0 8px 32px var(--shadow);width:224px}
.dp-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.dp-nav-btn{background:none;border:none;cursor:pointer;color:var(--text2);font-size:16px;padding:2px 7px;border-radius:5px;line-height:1;transition:background .1s}
.dp-nav-btn:hover{background:var(--surface3);color:var(--text)}
.dp-ym-label{font-size:12px;font-weight:700;color:var(--text);cursor:pointer;padding:2px 6px;border-radius:5px;transition:background .1s}
.dp-ym-label:hover{background:var(--surface3)}
.dp-grid-head{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:4px}
.dp-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.dp-dow{font-size:9px;font-weight:700;color:var(--text3);text-align:center;padding:2px 0}
.dp-day{height:26px;border-radius:5px;font-size:11px;font-weight:500;border:none;background:transparent;cursor:pointer;color:var(--text2);transition:background .1s,color .1s;font-family:inherit}
.dp-day:hover:not(:disabled){background:var(--surface3);color:var(--text)}
.dp-day.today{color:var(--accent);font-weight:700}
.dp-day.selected{background:var(--accent);color:#fff;font-weight:700}
.dp-day:disabled{opacity:.25;cursor:default}
.dp-day.other-month{opacity:.3}
.dp-clear{width:100%;margin-top:8px;padding:4px;border-radius:6px;font-size:11px;font-family:inherit;cursor:pointer;background:var(--surface2);border:1px solid var(--border2);color:var(--text2);transition:all .1s}
.dp-clear:hover{border-color:var(--red);color:var(--red)}
.dp-year-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;max-height:160px;overflow-y:auto}
.dp-month-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px}
.dp-ym-btn{padding:6px 0;border-radius:6px;font-size:11px;font-family:inherit;cursor:pointer;border:1px solid var(--border2);background:var(--surface2);color:var(--text2);transition:all .1s}
.dp-ym-btn:hover{background:var(--surface3);color:var(--text)}
.dp-ym-btn.cur{background:var(--accent);border-color:var(--accent2);color:#fff;font-weight:700}

*::-webkit-scrollbar{width:7px;height:7px}
*::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}

.topbar{height:50px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;padding:0 16px;flex-shrink:0;z-index:100}
.yearbar{height:36px;background:var(--surface2);border-bottom:1px solid var(--border);display:flex;align-items:flex-end;gap:0;padding:0 16px;flex-shrink:0;overflow:hidden;z-index:99}
.yearbar::-webkit-scrollbar{height:3px}
.subtabbar{height:30px;background:var(--surface);border-bottom:2px solid var(--border);display:flex;align-items:center;gap:0;padding:0 20px;flex-shrink:0;z-index:98}
.stab{padding:0 14px;height:30px;display:flex;align-items:center;gap:5px;font-size:11px;font-weight:600;color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;user-select:none;white-space:nowrap;transition:all .12s;letter-spacing:.2px}
.stab:hover{color:var(--text)}
.stab.active{color:var(--accent);border-bottom-color:var(--accent)}
.stab-pro.active{color:var(--green);border-bottom-color:var(--green)}
.ytab{padding:0 14px;height:28px;display:flex;align-items:center;gap:6px;font-size:12px;font-weight:500;color:var(--text2);cursor:pointer;border-radius:7px 7px 0 0;border:1px solid transparent;border-bottom:none;user-select:none;white-space:nowrap;transition:all .12s}
.ytab:hover{color:var(--text);background:var(--surface3)}
.ytab.active{background:var(--bg);color:var(--text);border-color:var(--border);font-weight:700}
.ytab-del{color:var(--text3);font-size:13px;line-height:1;margin-left:2px;opacity:0;transition:opacity .1s}
.ytab:hover .ytab-del{opacity:1}
.ytab-del:hover{color:var(--red)!important;opacity:1!important}
.ytab-add{padding:0 10px;height:28px;display:flex;align-items:center;font-size:16px;color:var(--text3);cursor:pointer;border-radius:7px 7px 0 0;transition:color .12s;margin-left:4px}
.ytab-add:hover{color:var(--accent)}
.ytab-pro{margin-left:4px;color:var(--text2)}
.ytab-pro.active{background:var(--bg);color:var(--green);border-color:var(--border);font-weight:700}
.logo{font-size:15px;font-weight:700;letter-spacing:-.5px;color:var(--text);margin-right:4px}
.logo span{color:var(--accent)}
.tb-sep{width:1px;height:20px;background:var(--border2);margin:0 4px}
.tb-label{font-size:11px;color:var(--text2);white-space:nowrap}
.tb-select{padding:4px 8px;border:1px solid var(--border2);border-radius:6px;background:var(--surface2);color:var(--text);font-size:12px;font-family:inherit;outline:none;cursor:pointer}
.tb-select option{background:var(--surface2)}
.tb-spacer{flex:1}
.tb-btn{display:inline-flex;align-items:center;gap:4px;padding:5px 11px;border-radius:7px;font-size:12px;font-family:inherit;cursor:pointer;border:1px solid var(--border2);background:var(--surface2);color:var(--text2);transition:all .15s}
.tb-btn:hover{background:var(--surface3);color:var(--text)}
.tb-btn.primary{background:var(--surface2);border-color:var(--accent);color:var(--accent)}
.tb-btn.primary:hover{background:var(--surface3);color:var(--accent2);border-color:var(--accent2)}
.tb-btn.danger{border-color:#7f1d1d;color:var(--red)}
.tb-btn.danger:hover{background:rgba(240,92,110,.1)}

.app{display:flex;flex:1;overflow:hidden;min-height:0}
.sidebar{width:255px;min-width:255px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;transition:width .25s cubic-bezier(.4,0,.2,1),min-width .25s cubic-bezier(.4,0,.2,1);overflow:hidden;position:relative}
.sidebar.collapsed{width:0;min-width:0;border-right:none}
.sidebar-inner{width:255px;display:flex;flex-direction:column;height:100%}
.sb-head{padding:14px 14px 4px;font-size:10px;font-weight:700;color:var(--text3);letter-spacing:.8px;text-transform:uppercase;flex-shrink:0}
.sb-scroll{flex:1;overflow-y:auto;padding:8px 13px 16px}

.field{margin-bottom:7px}
.field label{display:block;font-size:10px;font-weight:600;color:var(--text3);margin-bottom:3px;text-transform:uppercase;letter-spacing:.3px}
.field input,.field select{width:100%;padding:5px 8px;border:1px solid var(--border2);border-radius:6px;background:var(--surface2);color:var(--text);font-size:12px;font-family:inherit;outline:none}
.field input:focus,.field select:focus{border-color:var(--accent);background:var(--surface3)}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:7px}
.dp-wrap{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:9px}
.dp-btn{width:30px;height:26px;border:1px solid var(--border2);border-radius:6px;font-size:11px;font-weight:600;background:var(--surface2);color:var(--text2);cursor:pointer;transition:all .1s;font-family:inherit;position:relative}
.dp-btn.on{background:var(--accent);border-color:var(--accent);color:#fff}
.dp-btn .dp-order{position:absolute;top:-5px;right:-5px;width:13px;height:13px;border-radius:50%;background:#f0b429;color:#000;font-size:8px;font-weight:800;display:flex;align-items:center;justify-content:center;line-height:1;pointer-events:none}
.add-btn{width:100%;padding:7px;border-radius:8px;background:var(--accent);border:none;color:#fff;font-size:12px;font-family:inherit;font-weight:600;cursor:pointer;margin-top:2px;transition:background .15s}
.add-btn:hover{background:var(--accent2)}
.s-div{height:1px;background:var(--border);margin:12px 0}
.emp-card{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:7px 9px 7px 30px;margin-bottom:5px;position:relative;cursor:pointer;transition:border-color .15s,opacity .15s,transform .15s}
.emp-card:hover{border-color:var(--border2)}
.emp-card.dragging{opacity:.4;transform:scale(.98)}
.emp-card.drag-over{border-color:var(--accent);background:var(--surface3)}
.drag-handle{position:absolute;left:8px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:12px;cursor:grab;user-select:none;line-height:1;letter-spacing:-1px}
.drag-handle:active{cursor:grabbing}
.emp-name{font-size:12px;font-weight:600;color:var(--text);display:flex;align-items:center;gap:5px}
.emp-meta{font-size:10px;color:var(--text2);margin-top:2px}
.emp-del{position:absolute;top:6px;right:7px;background:none;border:none;cursor:pointer;color:var(--text3);font-size:15px;line-height:1;transition:color .1s}
.emp-del:hover{color:var(--red)}
.badge{font-size:9px;padding:1px 5px;border-radius:4px;background:var(--surface3);color:var(--text2);font-weight:500}
.badge.owner{color:var(--yellow)}

.sb-toggle{position:fixed;left:255px;top:50%;transform:translateY(-50%);width:22px;height:44px;background:var(--surface2);border:1px solid var(--border2);border-left:none;border-radius:0 8px 8px 0;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:200;user-select:none;transition:left .25s cubic-bezier(.4,0,.2,1),background .15s,box-shadow .15s}
.sb-toggle:hover{background:var(--surface3);box-shadow:2px 0 8px var(--shadow)}
.sb-toggle svg{transition:transform .25s cubic-bezier(.4,0,.2,1)}
.sb-toggle.collapsed{left:0}
.sb-toggle.collapsed svg{transform:rotate(180deg)}

.main{flex:1;overflow:auto;background:var(--bg);padding:16px 20px;min-width:0;min-height:0}
.month-block{margin-bottom:22px;width:fit-content}
.month-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:6px;display:flex;align-items:center;gap:8px;user-select:none}
.month-title-inner{cursor:pointer;display:inline-flex;align-items:center;gap:8px}
.month-title-inner:hover{color:var(--accent)}
.month-fold-btn{font-size:11px;color:var(--text3);transition:transform .2s;display:inline-block;margin-right:2px}
.month-block.folded .month-fold-btn{transform:rotate(-90deg)}
.month-block.folded .table-wrap{display:none}
.month-title small{color:var(--text3);font-weight:400;font-size:11px}
.table-wrap{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;display:block;width:fit-content}
.sch-table{border-collapse:collapse;width:auto;font-size:10px;table-layout:fixed;contain:layout style}
.sch-table th,.sch-table td{border:1px solid var(--border);text-align:center;padding:0}
.col-name{width:54px;min-width:54px;max-width:54px}.col-rank{width:36px;min-width:36px;max-width:36px}.col-team{width:40px;min-width:40px;max-width:40px}.col-day{width:22px;min-width:22px;max-width:22px}.col-note{}
.col-note-fixed{width:330px;min-width:330px;max-width:330px}
.col-lc-fixed{width:19px;min-width:19px;max-width:19px}
.th-empty{background:var(--surface3)!important;opacity:.35}
.cell-pad{background:var(--surface3);opacity:.35;pointer-events:none}
.th-base{background:var(--th-head-bg);color:var(--text2);font-size:11px;font-weight:600;height:21px}
.th-day{height:20px;font-size:10px;font-weight:600;color:var(--text);background:var(--th-head-bg)}
.th-dow{height:14px;font-size:8px;color:var(--text2);background:var(--th-head-bg)}
.th-sat .th-day,.th-sat .th-dow{background:var(--sat-head-bg)!important;color:var(--sat-head-c)!important}
.th-sun .th-day,.th-sun .th-dow{background:var(--sun-head-bg)!important;color:var(--sun-head-c)!important}
.th-today .th-day,.th-today .th-dow{background:var(--today-head-bg)!important;color:var(--today-head-c)!important}
.cell-today-bg{background:var(--today-cell-bg)!important}
.week-end{border-right:2px solid var(--border-sep)!important}
.td-name{font-weight:600;font-size:11px;text-align:left;padding:0 6px;height:22px;white-space:nowrap;overflow:hidden;color:var(--text)}
.td-rank{font-size:9.5px;font-weight:600;color:var(--text);height:22px;white-space:nowrap;overflow:hidden}.td-team{font-size:11px;font-weight:600;color:var(--text);height:22px;white-space:nowrap;overflow:hidden}
.td-team{border-right:2px solid var(--border-sep)!important}
.td-lc{font-size:9px;font-weight:700;height:22px;font-family:'JetBrains Mono',monospace}
.td-note{font-size:10px;color:var(--text2);padding:2px 7px;height:22px;cursor:pointer;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;border-left:2px solid var(--border-sep)!important;border-right:2px solid var(--border-sep)!important}
.td-note:hover{background:var(--surface3)!important}
.td-note.has-note{color:var(--text);font-weight:500}
.td-note.note-editing{padding:0!important;height:auto!important;overflow:visible!important;white-space:normal!important;cursor:default!important;background:var(--surface)!important;z-index:50;position:relative}
.cell{height:22px;line-height:22px;font-size:10px;font-weight:700;cursor:pointer;position:relative;font-family:'Pretendard',sans-serif;color:#374151}
.cell:hover{filter:brightness(.85)}
.cell.sel{outline:2px solid var(--accent)!important;outline-offset:-2px;z-index:2;position:relative}
.cell-empty{color:var(--text3)!important}
.cell-custom{/* inline style applied via JS */}
.cell-sat-bg{background:var(--sat-cell-bg)!important;color:var(--text3)!important}
.cell-sun-bg{background:var(--sun-cell-bg)!important;color:var(--text3)!important}
.cell-O{background:var(--O-bg);color:var(--O-c)}
.cell-C{background:var(--C-bg);color:var(--C-c)}
.cell-휴{background:var(--h-bg);color:var(--h-c)}
.cell-R{background:var(--R-bg);color:var(--R-c)}
.cell-V{background:var(--V-bg);color:var(--V-c)}
.cell-연{background:var(--y-bg);color:var(--y-c)}
.cell-반{background:var(--ban-bg);color:var(--ban-c)}
.cell-월{background:var(--ban-bg);color:var(--ban-c)}
.cell-결{background:var(--g-bg);color:var(--g-c)}
.cell-출{background:var(--birth-bg);color:var(--birth-c)}
.tr-even .td-name,.tr-even .td-rank,.tr-even .td-team,.tr-even .td-lc,.tr-even .td-note{background:var(--surface)}
.tr-owner .td-name{color:var(--text)}
.sep-bottom td{border-bottom:2px solid var(--border-sep)!important}
.sep-top td{border-top:2px solid var(--border-sep)!important}
.sep-both td{border-top:2px solid var(--border-sep)!important;border-bottom:2px solid var(--border-sep)!important}
.tr-cov td{font-size:9px;height:17px;font-family:'JetBrains Mono',monospace;font-weight:600}
.cov-label{background:var(--surface3);font-size:8px;color:var(--text3);text-align:left;padding:0 5px}
.cov-ok{color:var(--cov-ok-c)}
.cov-zero{color:var(--red);font-weight:800}

.cell.has-cell-note::after{content:'';position:absolute;top:2px;right:2px;width:4px;height:4px;border-radius:50%;background:var(--accent);pointer-events:none}

.ctx-menu{position:fixed;background:var(--surface);border:1px solid var(--border2);border-radius:8px;padding:3px;z-index:9000;min-width:120px;box-shadow:0 4px 16px var(--shadow)}
.ctx-title{font-size:8px;font-weight:700;color:var(--text3);padding:2px 7px 3px;letter-spacing:.6px;text-transform:uppercase}
.ctx-item{display:flex;align-items:center;gap:6px;padding:4px 8px;border-radius:5px;cursor:pointer;font-size:11px;transition:background .1s}
.ctx-item:hover{background:var(--surface3)}
.ctx-badge{width:18px;height:18px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;font-family:'Pretendard',sans-serif;flex-shrink:0}

.note-popup{position:fixed;background:var(--surface);border:1px solid var(--border2);border-radius:12px;padding:13px;width:216px;box-shadow:0 8px 32px var(--shadow);z-index:9001}
.note-popup-top{font-size:11px;font-weight:600;color:var(--text2);margin-bottom:9px;display:flex;justify-content:space-between;align-items:center}
.note-popup-x{cursor:pointer;color:var(--text3);font-size:16px;line-height:1}
.note-popup-x:hover{color:var(--text)}
.note-popup textarea{width:100%;height:78px;resize:none;border:1px solid var(--border2);border-radius:6px;font-size:11px;font-family:inherit;padding:6px 8px;color:var(--text);outline:none;background:var(--surface2)}
.note-popup textarea:focus{border-color:var(--accent)}
.note-btns{display:flex;gap:6px;margin-top:7px}
.note-btns button{flex:1;padding:5px;border-radius:6px;font-size:11px;font-family:inherit;cursor:pointer}
.btn-s{background:var(--accent);color:#fff;border:none;font-weight:600}
.btn-c{background:var(--surface2);color:var(--text2);border:1px solid var(--border2)}

.kb-hint{position:fixed;bottom:18px;left:50%;transform:translateX(-50%);background:var(--surface);border:1px solid var(--border2);color:var(--text2);padding:6px 14px;border-radius:9px;font-size:11px;display:flex;gap:10px;align-items:center;box-shadow:0 4px 16px var(--shadow);z-index:8000;pointer-events:none;opacity:0;transition:opacity .2s}
.kb-hint.show{opacity:1}
.kb-hint kbd{background:var(--surface3);border:1px solid var(--border2);border-radius:3px;padding:1px 5px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text)}

.modal-ov{position:fixed;inset:0;z-index:10000;background:var(--overlay);display:flex;align-items:center;justify-content:center}
.mpk-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px}
.mpk-btn{padding:7px 0;border-radius:7px;font-size:12px;font-family:inherit;cursor:pointer;border:1px solid var(--border2);background:var(--surface2);color:var(--text2);transition:all .1s;font-weight:500}
.mpk-btn:hover{background:var(--surface3);color:var(--text)}
.mpk-btn.mpk-sel{background:var(--accent);border-color:var(--accent2);color:#fff;font-weight:700}
.modal-box{background:var(--surface);border:1px solid var(--border2);border-radius:13px;padding:24px 26px;width:370px;box-shadow:0 12px 48px var(--shadow)}
.modal-icon{font-size:26px;margin-bottom:9px}.modal-title{font-size:15px;font-weight:700;margin-bottom:5px}
.modal-desc{font-size:12px;color:var(--text2);margin-bottom:20px;line-height:1.7}
.modal-btns{display:flex;gap:8px;justify-content:flex-end}
.modal-btn{padding:6px 16px;border-radius:7px;font-size:12px;font-family:inherit;cursor:pointer;border:1px solid var(--border2)}
.m-cancel{background:var(--surface2);color:var(--text)}.m-del{background:var(--red);border-color:#7f1d1d;color:#fff;font-weight:600}.m-ok{background:var(--accent);border-color:var(--accent);color:#fff;font-weight:600}

.edit-ov{position:fixed;inset:0;z-index:10001;background:var(--overlay);display:none;align-items:center;justify-content:center}
