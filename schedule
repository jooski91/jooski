/* ─── AUTO FILL ─── */
function autoFill(){
  showMonthPicker('자동 채우기', '채우기', m=>doAutoFill(m));
}
// 보존할 값(직접 입력한 특수 상태) — O/C는 이전 자동채우기 결과라 덮어씀
const PRESERVE=['휴','R','V','연','반','결','출'];

function doAutoFill(m){
  snapshotForUndo();
  const days=getDays(year,m);

  // 1단계: 기존 방식으로 각 직원 O/C 배정 (draft)
  emps.forEach(e=>{
    if(e.role==='owner')return;
    if(!sched[m][e.id])sched[m][e.id]={};
    const sc=sched[m][e.id];

    if(e.type==='close'){
      for(let d=1;d<=days;d++){if(!PRESERVE.includes(sc[d]))sc[d]='C';}
      return;
    }
    if(e.type==='open'){
      for(let d=1;d<=days;d++){if(!PRESERVE.includes(sc[d]))sc[d]='O';}
      return;
    }

    // both: 주 단위로 골고루, 각 주 내에서 O/C를 한 덩어리로 배정
    const bwCfg=(autoFillConfig.biweekly||{})[e.id]||{enabled:false,start:'O'};

    if(bwCfg.enabled){
      const weekKeys=[];
      for(let d=1;d<=days;d++){
        const wk=getMondayWeekKey(year,m,d);
        if(!weekKeys.includes(wk))weekKeys.push(wk);
      }
      for(let d=1;d<=days;d++){
        if(PRESERVE.includes(sc[d]))continue;
        const wi=weekKeys.indexOf(getMondayWeekKey(year,m,d));
        sc[d]=((wi%2===0)===(bwCfg.start==='O'))?'O':'C';
      }
      return;
    }

    // 기존 both 로직 (격주 비활성화 시)
    const firstType='O';
    const secondType='C';

    // 전체 free 날짜 수집
    const freeDays=[];
    for(let d=1;d<=days;d++){if(!PRESERVE.includes(sc[d]))freeDays.push(d);}

    // 주별로 free 날짜 그룹화 (월요일 기준 주)
    const weekMap=new Map();
    freeDays.forEach(d=>{
      const wk=getMondayWeekKey(year,m,d);
      if(!weekMap.has(wk))weekMap.set(wk,[]);
      weekMap.get(wk).push(d);
    });
    const weeks=[...weekMap.values()]; // 각 주의 free 날짜 배열

    // 전체 free 수 기준 절반 → 첫 번째 타입 배정 목표
    const totalFree=freeDays.length;
    const targetFirst=Math.round(totalFree/2);

    // 주별로 firstType 배정 개수를 분배 (균등하게, 앞 주에 집중되지 않도록)
    // 각 주: floor(weekFree/2) ~ ceil(weekFree/2) 범위에서 전체 합이 targetFirst 되도록
    const weekAlloc=weeks.map(wDays=>Math.floor(wDays.length/2));
    let allocated=weekAlloc.reduce((a,b)=>a+b,0);
    // 부족한 만큼 주별로 +1씩 (뒤 주부터, 월초 집중 방지)
    let need=targetFirst-allocated;
    // 뒤에서부터 채워 앞주에 몰리지 않게
    for(let i=weeks.length-1;i>=0&&need>0;i--){
      if(weekAlloc[i]<weeks[i].length){weekAlloc[i]++;need--;}
    }

    // 각 주 내에서 firstType을 앞 덩어리로 배정 (교차 없음)
    weeks.forEach((wDays,wi)=>{
      const nFirst=weekAlloc[wi];
      wDays.forEach((d,i)=>{sc[d]=i<nFirst?firstType:secondType;});
    });
  });

  // 2단계 이후: 우선순위 순서대로 조건 적용
  const teams=[...new Set(emps.filter(e=>e.team&&e.role!=='owner').map(e=>e.team))];
  const pri=autoFillConfig.priority||['pattern','three_c2','min_team'];

  function applyMinTeam(){
    teams.forEach(team=>{
      const teamEmps=emps.filter(e=>e.team===team&&e.role!=='owner');
      const minO=autoFillConfig.minOpen[team]??1;
      const minC=autoFillConfig.minClose[team]??1;
      for(let d=1;d<=days;d++){
        const working=teamEmps.filter(e=>!PRESERVE.includes((sched[m][e.id]||{})[d]));
        if(!working.length)continue;
        let openCnt=working.filter(e=>(sched[m][e.id]||{})[d]==='O').length;
        if(openCnt<minO){
          const cands=working.filter(e=>e.type==='both'&&(sched[m][e.id]||{})[d]==='C');
          for(let i=0;i<cands.length&&openCnt<minO;i++){sched[m][cands[i].id][d]='O';openCnt++;}
        }
        let closeCnt=working.filter(e=>(sched[m][e.id]||{})[d]==='C').length;
        if(closeCnt<minC){
          const cands=working.filter(e=>e.type==='both'&&(sched[m][e.id]||{})[d]==='O');
          for(let i=0;i<cands.length&&closeCnt<minC;i++){sched[m][cands[i].id][d]='C';closeCnt++;}
        }
      }
    });
  }

  function applyThreeC2(){
    teams.forEach(team=>{
      const teamEmps=emps.filter(e=>e.team===team&&e.role!=='owner');
      for(let d=1;d<=days;d++){
        const working=teamEmps.filter(e=>!PRESERVE.includes((sched[m][e.id]||{})[d]));
        if(working.length!==3)continue;
        const oList=working.filter(e=>(sched[m][e.id]||{})[d]==='O');
        if(oList.length<2)continue;
        const candidate=oList.find(e=>e.type==='both');
        if(candidate)sched[m][candidate.id][d]='C';
      }
    });
  }

  // 패턴은 이미 1단계에서 적용됨 — 우선순위 순서대로 나머지 실행
  pri.forEach(cid=>{
    if(cid==='min_team')applyMinTeam();
    else if(cid==='three_c2')applyThreeC2();
    // 'pattern'은 1단계에서 처리
  });

  renderAll();showToast(`${m}월 자동 채우기 완료`);
}

function getMondayWeekKey(y,m,d){
  const date=new Date(y,m-1,d);
  const day=date.getDay()||7;
  const mon=new Date(date);mon.setDate(d-(day-1));
  return mon.toISOString().slice(0,10);
}

