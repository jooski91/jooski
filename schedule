let rulesData={
  title:'<근무표 관련 우선순위 rule 정리> *2025년 8월부터',
  items:[
    '고정 휴무는 절대 변경하지 말것(사로 바꿔주는 것 금지)',
    '급한 개인 일정은 연차를 사용하여 쉴 것',
    'R은 평일 2인 근무일에 사용할 것 (주말 6일 이상 근무시 R 2개, 3일 이상 근무시 R 1개)',
    '특별히 근무가 돌아가지 않는 경우는 팀장과 상의 후 근무 결정 (연차 사용자가 양쪽 센터 모두 있는 경우 등)',
    '다음달 근무는 전달 15일까지 확정하여 공유',
    '모든R은 당월에 사용(근무일정이 안나와서 못쓰는 경우만 점장 컨펌후 이월)',
  ]
};
try{
  if(typeof _savedRulesData!=='undefined')rulesData=_savedRulesData;
  else{const s=localStorage.getItem('rulesData');if(s)rulesData=JSON.parse(s);}
}catch(e){}

function renderRules(){
  const tv=dom('rules-title-view');
  const rv=dom('rules-view');
  if(!tv||!rv)return;
  tv.innerHTML=rulesData.title+' <span id="rules-fold-btn" style="font-size:11px;color:var(--text3);transition:transform .2s;display:inline-block">▾</span>';
  rv.innerHTML=`<ol style="font-size:11px;color:var(--text2);line-height:1.85;padding-left:16px">${
    rulesData.items.map(i=>`<li>${i}</li>`).join('')
  }</ol>`;
  // 자동 접기: 연차현황 패널보다 규칙 패널이 길면 접기
  requestAnimationFrame(()=>autoFoldRulesIfNeeded());
}
function openRulesEdit(){
  dom('rules-view').style.display='none';
  dom('rules-edit-btn').style.display='none';
  dom('rules-title-input').value=rulesData.title;
  dom('rules-ta').value=rulesData.items.join('\n');
  dom('rules-edit-area').style.display='block';
  // 수정 중엔 body 강제 펼치기
  const rb=dom('rules-body');if(rb)rb.style.display='';
  const fb=dom('rules-fold-btn');if(fb){fb.style.transform='';_rulesFolded=false;}
  dom('rules-ta').focus();
}
function closeRulesEdit(){
  dom('rules-edit-area').style.display='none';
  dom('rules-view').style.display='';
  dom('rules-edit-btn').style.display='';
}
let _rulesFolded=false;
function toggleRulesBody(){
  const rb=dom('rules-body');
  const fb=dom('rules-fold-btn');
  if(!rb)return;
  _rulesFolded=!_rulesFolded;
  rb.style.display=_rulesFolded?'none':'';
  if(fb)fb.style.transform=_rulesFolded?'rotate(-90deg)':'';
}
function autoFoldRulesIfNeeded(){
  const rulesBox=dom('rules-box');
  const ip=dom('info-panel');
  if(!rulesBox||!ip)return;
  const annualEl=ip.querySelector('div:first-child');
  if(!annualEl)return;
  const annualH=annualEl.getBoundingClientRect().height;

  const rb=dom('rules-body');
  const fb=dom('rules-fold-btn');

  if(_rulesFolded){
    // 접혀있는 상태 — 펼쳤을 때 높이를 임시로 측정
    if(rb){rb.style.visibility='hidden';rb.style.display='';}
    requestAnimationFrame(()=>{
      const rulesH=rulesBox.getBoundingClientRect().height;
      if(rb){rb.style.visibility='';rb.style.display='none';}
      if(rulesH<=annualH){
        // 충분히 짧아졌으면 펼치기
        _rulesFolded=false;
        if(rb){rb.style.display='';}
        if(fb)fb.style.transform='';
      }
    });
  } else {
    // 펼쳐진 상태 — 현재 높이가 연차현황보다 길면 접기
    const rulesH=rulesBox.getBoundingClientRect().height;
    if(rulesH>annualH){
      _rulesFolded=true;
      if(rb)rb.style.display='none';
      if(fb)fb.style.transform='rotate(-90deg)';
    }
  }
}
function saveRules(){
  rulesData.title=dom('rules-title-input').value.trim()||rulesData.title;
  rulesData.items=dom('rules-ta').value.split('\n').map(s=>s.trim()).filter(Boolean);
  try{localStorage.setItem('rulesData',JSON.stringify(rulesData));}catch(e){}
  closeRulesEdit();
  renderRules();
  showToast('규칙 저장됨');
}


/* ─── DATE PICKER ─── */
let _dpTarget=null,_dpHiddenId=null,_dpViewY=0,_dpViewM=0,_dpMode='day'; // mode: day|month|year

function setDatePickerValue(hiddenId,val){
  const hidden=dom(hiddenId);
  const btn=dom(hiddenId+'-btn');
  if(!hidden||!btn)return;
  hidden.value=val||'';
  if(val){
    const [y,m,d]=val.split('-');
    btn.textContent=`${y}년 ${parseInt(m)}월 ${parseInt(d)}일 ▾`;
    btn.classList.remove('empty');btn.classList.add('has-value');
  } else {
    btn.textContent='날짜 선택 ▾';
    btn.classList.add('empty');btn.classList.remove('has-value');
  }
}

function openDatePicker(btnId, hiddenId){
  closeDatePicker();
  _dpTarget=btnId; _dpHiddenId=hiddenId;
  const hidden=dom(hiddenId);
  const cur=hidden?.value;
  const now=new Date();
  if(cur){const p=cur.split('-');_dpViewY=parseInt(p[0]);_dpViewM=parseInt(p[1]);}
  else{_dpViewY=now.getFullYear();_dpViewM=now.getMonth()+1;}
  _dpMode='day';
  renderDatePopup();
}

function closeDatePicker(){
  document.getElementById('_dp-popup')?.remove();
  _dpTarget=null;_dpHiddenId=null;
}

function renderDatePopup(){
  document.getElementById('_dp-popup')?.remove();
  const btn=dom(_dpTarget);
  if(!btn)return;
  const pop=document.createElement('div');
  pop.className='date-popup';pop.id='_dp-popup';

  if(_dpMode==='day'){
    const selVal=dom(_dpHiddenId)?.value||'';
    const [sy,sm,sd]=selVal?selVal.split('-').map(Number):[0,0,0];
    const today=new Date();
    const firstDOW=new Date(_dpViewY,_dpViewM-1,1).getDay();
    const days=new Date(_dpViewY,_dpViewM,0).getDate();
    const prevDays=new Date(_dpViewY,_dpViewM-1,0).getDate();
    const DOWS=['일','월','화','수','목','금','토'];

    let cells='';
    // 이전달 칸
    for(let i=0;i<firstDOW;i++){
      const d=prevDays-firstDOW+1+i;
      cells+=`<button class="dp-day other-month" disabled>${d}</button>`;
    }
    for(let d=1;d<=days;d++){
      const isSel=sy===_dpViewY&&sm===_dpViewM&&sd===d;
      const isToday=today.getFullYear()===_dpViewY&&today.getMonth()+1===_dpViewM&&today.getDate()===d;
      const sat=new Date(_dpViewY,_dpViewM-1,d).getDay()===6;
      const sun=new Date(_dpViewY,_dpViewM-1,d).getDay()===0;
      const col=isSel?'':(sat?'color:var(--sat-head-c)':(sun?'color:var(--sun-head-c)':''));
      cells+=`<button class="dp-day${isSel?' selected':''}${isToday&&!isSel?' today':''}" style="${col}" onclick="pickDate(${d})">${d}</button>`;
    }
    // 남은 칸
    const total=Math.ceil((firstDOW+days)/7)*7;
    for(let i=1;i<=total-firstDOW-days;i++) cells+=`<button class="dp-day other-month" disabled>${i}</button>`;

    pop.innerHTML=`
      <div class="dp-nav">
        <button class="dp-nav-btn" onclick="_dpViewM--;if(_dpViewM<1){_dpViewM=12;_dpViewY--;}renderDatePopup()">‹</button>
        <span class="dp-ym-label" onclick="_dpMode='month';renderDatePopup()">${_dpViewY}년 ${_dpViewM}월</span>
        <button class="dp-nav-btn" onclick="_dpViewM++;if(_dpViewM>12){_dpViewM=1;_dpViewY++;}renderDatePopup()">›</button>
      </div>
      <div class="dp-grid-head">${DOWS.map(d=>`<div class="dp-dow">${d}</div>`).join('')}</div>
      <div class="dp-grid">${cells}</div>
      <button class="dp-clear" onclick="setDatePickerValue(_dpHiddenId,'');closeDatePicker()">선택 해제</button>`;
  } else if(_dpMode==='month'){
    const MN=['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
    const btns=MN.map((mn,i)=>`<button class="dp-ym-btn${_dpViewM===i+1?' cur':''}" onclick="_dpViewM=${i+1};_dpMode='day';renderDatePopup()">${mn}</button>`).join('');
    pop.innerHTML=`
      <div class="dp-nav">
        <button class="dp-nav-btn" onclick="_dpViewY--;renderDatePopup()">‹</button>
        <span class="dp-ym-label" onclick="_dpMode='year';renderDatePopup()">${_dpViewY}년</span>
        <button class="dp-nav-btn" onclick="_dpViewY++;renderDatePopup()">›</button>
      </div>
      <div class="dp-month-grid">${btns}</div>`;
  } else {
    const base=_dpViewY-6;
    const btns=Array.from({length:16},(_,i)=>base+i).map(y=>
      `<button class="dp-ym-btn${_dpViewY===y?' cur':''}" onclick="_dpViewY=${y};_dpMode='month';renderDatePopup()">${y}</button>`).join('');
    pop.innerHTML=`
      <div class="dp-nav">
        <button class="dp-nav-btn" onclick="_dpViewY-=12;renderDatePopup()">‹</button>
        <span class="dp-ym-label" style="cursor:default">연도 선택</span>
        <button class="dp-nav-btn" onclick="_dpViewY+=12;renderDatePopup()">›</button>
      </div>
      <div class="dp-year-grid">${btns}</div>`;
  }

  // 위치 계산
  const rect=btn.getBoundingClientRect();
  pop.style.top=(rect.bottom+4)+'px';
  pop.style.left=rect.left+'px';
  document.body.appendChild(pop);

  // 팝업이 화면 밖으로 나가면 위로 띄우기
  const pr=pop.getBoundingClientRect();
  if(pr.bottom>window.innerHeight-8) pop.style.top=(rect.top-pr.height-4)+'px';
  if(pr.right>window.innerWidth-8) pop.style.left=(window.innerWidth-pr.width-8)+'px';
}

function pickDate(d){
  const val=`${_dpViewY}-${String(_dpViewM).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
  setDatePickerValue(_dpHiddenId, val);
  closeDatePicker();
}

document.addEventListener('mousedown',e=>{
  const pop=document.getElementById('_dp-popup');
  if(pop&&!pop.contains(e.target)&&!e.target.classList.contains('date-display-btn')) closeDatePicker();
},true);

renderRules();
init();
</script>
<script>
/* ─── RESIZE PERFORMANCE: transition 일시 중단 ─── */
(function(){
  let _rt=null;
  window.addEventListener('resize',function(){
    document.body.classList.add('no-transition');
    clearTimeout(_rt);
    _rt=setTimeout(function(){
      document.body.classList.remove('no-transition');
      autoFoldRulesIfNeeded();
    },150);
  },{passive:true});
})();
</script>


