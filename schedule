function updateBaseLabelAndKb(baseIdx, code){
  const newLabel=document.getElementById(`bl-label-${baseIdx}`)?.value.trim();
  if(!newLabel){showToast('이름을 입력하세요');return;}
  const LOCKED_COLORS=new Set(['O','C','휴','R']);
  const bgEl=LOCKED_COLORS.has(code)?null:document.getElementById(`bl-bg-${baseIdx}`);
  const fgEl=LOCKED_COLORS.has(code)?null:document.getElementById(`bl-fg-${baseIdx}`);
  const base=SHIFTS_BASE.find(t=>t.v===code);
  const prevOverride=customShifts.find(c=>c.v===code&&c._override);
  // 잠긴 항목은 기존 CSS 변수(기본색) 유지
  const newBg=bgEl?bgEl.value:(prevOverride&&!LOCKED_COLORS.has(code)?prevOverride.bg:base.bg);
  const newFg=fgEl?fgEl.value:(prevOverride&&!LOCKED_COLORS.has(code)?prevOverride.c:base.c);
  const idx=customShifts.findIndex(c=>c.v===code&&c._override);
  if(idx>=0) customShifts.splice(idx,1);
  customShifts.push({v:code,l:newLabel,bg:newBg,c:newFg,custom:false,_override:true});
  try{localStorage.setItem('customShifts',JSON.stringify(customShifts));}catch(e){}
  _saveKbFromInputs();
  renderLegendMgr();renderAll();showToast(`'${code}' 수정됨`);
}

function addLegend(){
  const code=dom('new-legend-code').value.trim();
  const label=dom('new-legend-label').value.trim();
  const bg=dom('new-legend-bg').value;
  const fg=dom('new-legend-fg').value;
  if(!code||!label){showToast('코드와 이름을 입력하세요');return;}
  if(getShifts().some(t=>t.v===code)){showToast('이미 사용 중인 코드예요');return;}
  customShifts.push({v:code,l:label,bg,c:fg,custom:true});
  try{localStorage.setItem('customShifts',JSON.stringify(customShifts));}catch(e){}
  dom('new-legend-code').value='';
  dom('new-legend-label').value='';
  renderLegendMgr();
  renderAll();
  showToast(`'${label}' 범례 추가됨`);
  // 추가 후 단축키 저장 (새 항목 포함)
  _saveKbFromInputs();
}

function _saveKbFromInputs(){
  const shifts=getShifts().filter(t=>t.v!=='');
  let kbMap={};
  try{const s=localStorage.getItem('kbMap');if(s)kbMap=JSON.parse(s);}catch(e){}
  const used=new Set(Object.values(kbMap));
  for(const t of shifts){
    const inp=document.getElementById(`le-kb-key-${t.v}`);
    if(!inp)continue;
    const k=inp.value.trim().toLowerCase();
    if(!k){delete kbMap[t.v];continue;}
    // 중복 체크 (본인 기존값 제외)
    const others=Object.entries(kbMap).filter(([v])=>v!==t.v).map(([,k])=>k);
    if(others.includes(k)){showToast(`'${k}' 키가 중복입니다`);return false;}
    kbMap[t.v]=k;
  }
  try{localStorage.setItem('kbMap',JSON.stringify(kbMap));}catch(e){}
  loadKB();renderKbHint();
  return true;
}

function updateLegendAndKb(i, code){
  const c=code;
  const label=document.getElementById(`le-label-${i}`)?.value.trim();
  const bg=document.getElementById(`le-bg-${i}`)?.value;
  const fg=document.getElementById(`le-fg-${i}`)?.value;
  if(!label){showToast('이름을 입력하세요');return;}
  customShifts[i]={...customShifts[i],v:c,l:label,bg,c:fg};
  try{localStorage.setItem('customShifts',JSON.stringify(customShifts));}catch(e){}
  if(!_saveKbFromInputs())return;
  renderLegendMgr();renderAll();showToast(`'${label}' 수정됨`);
}

function deleteLegend(i){
  const t=customShifts[i];
  customShifts.splice(i,1);
  try{localStorage.setItem('customShifts',JSON.stringify(customShifts));}catch(e){}
  renderLegendMgr();
  renderAll();
  showToast(`'${t.l}' 범례 삭제됨`);
}

