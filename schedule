  {v:'C', l:'마감',    bg:'var(--C-bg)',    c:'var(--C-c)',    custom:false},
  {v:'휴',l:'휴무',    bg:'var(--h-bg)',    c:'var(--h-c)',    custom:false},
  {v:'R', l:'리프레시',bg:'var(--R-bg)',    c:'var(--R-c)',    custom:false},
  {v:'V', l:'시설점검',bg:'var(--V-bg)',    c:'var(--V-c)',    custom:false},
  {v:'연',l:'연차',    bg:'var(--y-bg)',    c:'var(--y-c)',    custom:false},
  {v:'반',l:'반차',    bg:'var(--ban-bg)',  c:'var(--ban-c)',  custom:false},
  {v:'월',l:'월차',    bg:'var(--ban-bg)',  c:'var(--ban-c)',  custom:false},
  {v:'결',l:'결혼',    bg:'var(--g-bg)',    c:'var(--g-c)',    custom:false},
  {v:'출',l:'출산',    bg:'var(--birth-bg)',c:'var(--birth-c)',custom:false},
  {v:'S', l:'수성',    bg:'var(--ban-bg)',  c:'var(--ban-c)',  custom:false},
  {v:'D', l:'동대구',  bg:'var(--ban-bg)',  c:'var(--ban-c)',  custom:false},
  {v:'', l:'지우기',   bg:'transparent',   c:'#64748b',       custom:false},
];
let customShifts=(typeof _savedCustomShifts!=='undefined'?_savedCustomShifts:null)||[];
try{if(!_savedCustomShifts)customShifts=JSON.parse(localStorage.getItem('customShifts')||'[]');}catch(e){}
// O,C,휴,R 색상 고정: 저장된 커스텀 색상 무시
const LOCKED_COLOR_CODES=new Set(['O','C','휴','R']);
customShifts=customShifts.map(t=>{
  if(t._override&&LOCKED_COLOR_CODES.has(t.v)){
    const base=SHIFTS_BASE.find(b=>b.v===t.v);
    return base?{...t,bg:base.bg,c:base.c}:t;
  }
  return t;
});
function getShifts(){
  const overrides=customShifts.filter(t=>t._override);
  const base=SHIFTS_BASE.slice(0,-1).map(t=>{
    const ov=overrides.find(o=>o.v===t.v);
    return ov?{...t,l:ov.l}:t;
  });
  return [...base,...customShifts.filter(t=>!t._override),SHIFTS_BASE[SHIFTS_BASE.length-1]];
}
let countDisabled=new Set(typeof _savedCountDisabled!=='undefined'?_savedCountDisabled:['연','반','월','결','출','S','D']);
try{if(typeof _savedCountDisabled==='undefined'){const s=localStorage.getItem('countDisabled');if(s)countDisabled=new Set(JSON.parse(s));}}catch(e){}
function saveCountDisabled(){try{localStorage.setItem('countDisabled',JSON.stringify([...countDisabled]));}catch(e){}}
function toggleCountDisabled(v){
  if(countDisabled.has(v))countDisabled.delete(v);else countDisabled.add(v);
  saveCountDisabled();
  renderLegendMgr();renderAll();
}
function getCntTypes(){return getShifts().filter(t=>t.v!==''&&!countDisabled.has(t.v));}
function getShiftStyle(v){
  const custom=customShifts.find(t=>t.v===v&&!t._override);
  if(custom)return `background:${custom.bg};color:${custom.c}`;
  // CSS 클래스 없는 기본 항목(S, D 등): _override 색상도 inline style로 반환
  if(!LOCKED_COLOR_CODES.has(v)){
    const override=customShifts.find(t=>t.v===v&&t._override);
    if(override)return `background:${override.bg};color:${override.c}`;
    const base=SHIFTS_BASE.find(t=>t.v===v);
    if(base&&!base.bg.startsWith('var(--O')&&!base.bg.startsWith('var(--C')&&!base.bg.startsWith('var(--h')&&!base.bg.startsWith('var(--R')){
      return `background:${base.bg};color:${base.c}`;
    }
  }
  return '';
}
