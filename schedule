// 해당 직원이 year/month 에 재직 중인지 판단
function empActiveInMonth(e, y, m){
  // 입사일: hire가 있으면 그 이후 연월부터만 표시
  if(e.hire){
    const [hy,hm]=e.hire.split('-').map(Number);
    if(y<hy||(y===hy&&m<hm)) return false;
  }
  // 퇴사일: resign이 있으면 그 연월 이후는 표시 안 함
  if(e.resign){
    const [ry,rm]=e.resign.split('-').map(Number);
    if(y>ry||(y===ry&&m>rm)) return false;
  }
  return true;
}

