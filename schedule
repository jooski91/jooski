try{const s=localStorage.getItem('foldedMonths');if(s&&typeof _savedFolded==='undefined')foldedMonths=new Set(JSON.parse(s));}catch(e){}
function saveFoldedMonths(){try{localStorage.setItem('foldedMonths',JSON.stringify([...foldedMonths]));}catch(e){}}
function toggleMonth(block){
  const m=parseInt(block.dataset.month);
  if(foldedMonths.has(m))foldedMonths.delete(m);else foldedMonths.add(m);
  block.classList.toggle('folded');
  saveFoldedMonths();
}

let _renderTimer=null;
function renderAll(){
  if(_renderTimer)cancelAnimationFrame(_renderTimer);
  _renderTimer=requestAnimationFrame(()=>{
    _renderTimer=null;
    if(proMode){renderProAll();return;}
    // 운영팀 모드: pro-info-panel 숨김
    const proIp=dom('pro-info-panel');if(proIp)proIp.style.display='none';
    const root=dom('sched-root');
    renderInfoPanel();
    if(!emps.length){
      root.innerHTML='<div style="color:var(--text3);font-size:13px;padding:40px;text-align:center">왼쪽 패널에서 직원을 추가하세요</div>';
      return;
    }
    const frag=document.createDocumentFragment();
    for(let m=1;m<=12;m++)frag.appendChild(buildMonth(m));
    root.innerHTML='';
    root.appendChild(frag);
  });
}

