function renderKbSettings(){
  const el=dom('kb-settings-list');if(!el)return;
  // 현재 저장된 단축키 맵 (소문자→값)
  let kbMap={};
  try{const s=localStorage.getItem('kbMap');if(s)kbMap=JSON.parse(s);}catch(e){}
  // 기본값 fallback
  const defaultKeys={'O':'o','C':'c','휴':'g','R':'r','V':'v','연':'d','반':'q','결':'h','출':'j'};

  const shifts=getShifts().filter(t=>t.v!=='');
  el.innerHTML=shifts.map(t=>{
    // 현재 이 값에 매핑된 소문자 키 찾기
    const curKey=kbMap[t.v]??defaultKeys[t.v]??'';
    return `<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
      <span style="width:20px;height:18px;border-radius:3px;background:${t.bg};color:${t.c};font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;font-family:'Pretendard',sans-serif;flex-shrink:0">${t.v}</span>
      <span style="font-size:11px;color:var(--text);flex:1">${t.l}</span>
      <input id="kb-key-${t.v}" value="${curKey}" maxlength="1" placeholder="키"
        style="width:36px;padding:3px 6px;border:1px solid var(--border2);border-radius:5px;background:var(--surface2);color:var(--text);font-size:12px;font-family:'JetBrains Mono',monospace;outline:none;text-align:center"
        oninput="this.value=this.value.replace(/[^a-z]/gi,'').toLowerCase().slice(-1)">
    </div>`;
  }).join('');
  el.innerHTML+=`<button class="add-btn" style="margin-top:4px" onclick="saveKbSettings()">단축키 저장</button>`;
}

function saveKbSettings(){
  const shifts=getShifts().filter(t=>t.v!=='');
  const kbMap={};
  const used=new Set();
  for(const t of shifts){
    const inp=document.getElementById(`kb-key-${t.v}`);
    const k=inp?inp.value.trim().toLowerCase():'';
    if(!k)continue;
    if(used.has(k)){showToast(`'${k}' 키가 중복입니다`);return;}
    used.add(k);
    kbMap[t.v]=k;
  }
  try{localStorage.setItem('kbMap',JSON.stringify(kbMap));}catch(e){}
  loadKB();
  renderKbHint();
  showToast('단축키 저장됨');
}

function renderKbHint(){
  const el=dom('kb-hint');if(!el)return;
  // KB에서 값→키 역방향 맵
  const valToKey={};
  Object.entries(KB).forEach(([k,v])=>{if(k===k.toLowerCase())valToKey[v]=k;});
  const shifts=getShifts().filter(t=>t.v!=='');
  const parts=shifts.map(t=>{
    const k=valToKey[t.v];
    return k?`<span><kbd>${k.toUpperCase()}</kbd>${t.l}</span>`:'';
  }).filter(Boolean);
  parts.push(`<span><kbd>Del</kbd>삭제</span><span><kbd>←→↑↓</kbd>이동</span>`);
  el.innerHTML=parts.join('');
}

