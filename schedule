function buildProMonth(month, ps){
  const TOTAL_DAYS=31;
  const days=getDays(year,month);
  const PRO_CNT_TYPES=getCntTypes().filter(t=>t.v!=='O'&&t.v!=='C');const proLcN=PRO_CNT_TYPES.length;

  let cg=`<col class="col-name"><col class="col-team">`;
  for(let d=1;d<=TOTAL_DAYS;d++)cg+=`<col class="col-day">`;
  cg+=`<col class="col-note-fixed">`;
  for(let i=0;i<proLcN;i++)cg+=`<col class="col-lc-fixed">`;

  // header
  const _pTodayD=new Date();const _pty=_pTodayD.getFullYear(),_ptm=_pTodayD.getMonth()+1,_ptd=_pTodayD.getDate();
  let h1=`<tr><th class="th-base" rowspan="2" style="vertical-align:middle">이름</th><th class="th-base" rowspan="2" style="vertical-align:middle;border-right:2px solid var(--border-sep)!important">팀</th>`;
  for(let d=1;d<=TOTAL_DAYS;d++){
    if(d<=days){
      const hol=getHoliday(year,month,d);
      const isTodayH=(year===_pty&&month===_ptm&&d===_ptd);
      const sc=isTodayH?'th-today':(hol?'th-sun':isSat(year,month,d)?'th-sat':isSun(year,month,d)?'th-sun':'');
      const weSun=(hol||isSun(year,month,d))?'week-end':'';
      const dn=(dayNotes[year]&&dayNotes[year][month]&&dayNotes[year][month][d])||'';
      const dot=dn?`<div style="width:4px;height:4px;border-radius:50%;background:var(--accent);margin:1px auto 0"></div>`:'';
      h1+=`<th class="${sc} ${weSun}" style="cursor:pointer" onclick="openDayNote(event,this,${month},${d})" title="${hol||'날짜 메모'}"><div class="th-day">${d}</div>${dot}</th>`;
    } else {
      h1+=`<th class="th-base th-empty" rowspan="2"></th>`;
    }
  }
  h1+=`<th class="th-base" rowspan="2" style="vertical-align:middle;border-left:2px solid var(--border-sep)!important;border-right:2px solid var(--border-sep)!important">비고</th>`;
  h1+=`<th class="th-base" colspan="${proLcN}" style="font-size:8px;color:var(--text3)">count</th>`;
  h1+=`</tr>`;

  let h2=`<tr>`;
  for(let d=1;d<=TOTAL_DAYS;d++){
    if(d<=days){
      const hol=getHoliday(year,month,d);
      const isTodayH2=(year===_pty&&month===_ptm&&d===_ptd);
      const sc=isTodayH2?'th-today':(hol?'th-sun':isSat(year,month,d)?'th-sat':isSun(year,month,d)?'th-sun':'');
      const weSun2h=(hol||isSun(year,month,d))?'week-end':'';
      h2+=`<th class="${sc} ${weSun2h}"><div class="th-dow">${getDOW(year,month,d)}</div></th>`;
    }
  }
  PRO_CNT_TYPES.forEach(ct=>h2+=`<th class="th-dow" style="font-family:'Pretendard',sans-serif;font-weight:700;color:${ct.c};background:${ct.bg||'var(--surface3)'}">${ct.v}</th>`);
  h2+=`</tr>`;

  // body
  let body='';
  // 팀별 rowspan 계산
  const proTeamRowspan=new Map();
  let pi=0;
  while(pi<proEmps.length){
    const e=proEmps[pi];const team=e.team||'';
    let span=1;let j=pi+1;
    while(j<proEmps.length&&(proEmps[j].team||'')===team){span++;j++;}
    proTeamRowspan.set(e.id,span);
    for(let k=pi+1;k<j;k++)proTeamRowspan.set(proEmps[k].id,0);
    pi=j;
  }
  proEmps.forEach((e,idx)=>{
    const sch=(ps[month]&&ps[month][e.id])||{};
    const even=idx%2===1?'tr-even':'';
    const nextEmp=proEmps[idx+1];
    const isLastInTeam=!nextEmp||(e.team||'')!==(nextEmp.team||'');
    const sepStyle=isLastInTeam?'border-bottom:2px solid var(--border-sep)!important':'';
    const span=proTeamRowspan.get(e.id);
    const teamTd=span===0?'':
      `<td class="td-team" rowspan="${span}" style="vertical-align:middle;text-align:center;border-bottom:2px solid var(--border-sep)!important">${e.team||''}</td>`;
    body+=`<tr class="tr-data ${even}">
      <td class="td-name" style="${sepStyle}">${e.name}</td>
      ${teamTd}`;
    for(let d=1;d<=TOTAL_DAYS;d++){
      if(d<=days){
        const v=sch[d]||'';
        const csStyle=v?getShiftStyle(v):'';
        const weSun2=(getHoliday(year,month,d)||isSun(year,month,d))?'week-end':'';
        let bg=v?(csStyle?'cell-custom':`cell-${v}`):(getHoliday(year,month,d)||isSun(year,month,d)?'cell-sun-bg':isSat(year,month,d)?'cell-sat-bg':'cell-empty');
        const cn=getCellNote(`pro_${e.id}`,month,d);
        body+=`<td class="cell ${bg} ${weSun2}${cn?' has-cell-note':''}" tabindex="0" data-eid="pro_${e.id}" data-m="${month}" data-d="${d}" onclick="onCellClick(this,event)" oncontextmenu="onCtx(this,event)"${(csStyle||sepStyle)?` style="${[csStyle,sepStyle].filter(Boolean).join(';')}"`:''}${cn?` title="${cn}"`:''}>${v}</td>`;
      } else {
        body+=`<td class="cell-pad"></td>`;
      }
    }
    const note=proNotes[e.id]||'';
    body+=`<td class="td-note ${note?'has-note':''}" style="cursor:pointer;${sepStyle}" onclick="openProNoteInline(event,this,${e.id})">${note||''}</td>`;
    const proCnts={};PRO_CNT_TYPES.forEach(ct=>proCnts[ct.v]=0);
    for(let d=1;d<=days;d++){const v=sch[d]||'';if(proCnts[v]!==undefined)proCnts[v]++;}
    PRO_CNT_TYPES.forEach((ct,ci)=>{
      const val=proCnts[ct.v]||'';
      const lcBorder=ci===0?'border-left:2px solid var(--border-sep)!important;':'';
      body+=`<td class="td-lc" style="${lcBorder}color:${ct.c}">${val}</td>`;
    });
    body+=`</tr>`;
  });

  const wrap=document.createElement('div');
  wrap.className='month-block'+(proFoldedMonths.has(month)?' folded':'');
  wrap.dataset.month=month;
  const MN=['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
  wrap.innerHTML=`
    <div class="month-title"><span class="month-title-inner" onclick="toggleProMonth(this.closest('.month-block'))"><span class="month-fold-btn">▾</span>${year}년 ${MN[month-1]} <small>${days}일</small></span></div>
    <div class="table-wrap">
      <table class="sch-table"><colgroup>${cg}</colgroup>
        <thead>${h1}${h2}</thead>
        <tbody>${body}</tbody>
      </table>
    </div>`;
  return wrap;
}

function openProNoteInline(ev,td,eid){
  // 기존 노트팝업과 동일 방식
  const cur=proNotes[eid]||'';
  const pop=document.createElement('div');
  pop.id='cell-note-popup';pop.className='note-popup';
  pop.innerHTML=`<div class="note-popup-top"><span>${proEmps.find(e=>e.id===eid)?.name||''} 비고</span><span class="note-popup-x" onclick="document.getElementById('cell-note-popup')?.remove()">✕</span></div>
    <textarea id="pro-note-ta" style="width:100%;height:78px;resize:none;border:1px solid var(--border2);border-radius:6px;font-size:11px;font-family:inherit;padding:6px 8px;color:var(--text);outline:none;background:var(--surface2)">${cur}</textarea>
    <div class="note-btns">
      <button class="btn-s" onclick="saveProNote(${eid})">저장</button>
      <button class="btn-c" onclick="document.getElementById('cell-note-popup')?.remove()">취소</button>
    </div>`;
  const rect=td.getBoundingClientRect();
  pop.style.top=(rect.bottom+4)+'px';pop.style.left=rect.left+'px';
  document.body.appendChild(pop);
  const pr=pop.getBoundingClientRect();
  if(pr.bottom>window.innerHeight-8)pop.style.top=(rect.top-pr.height-4)+'px';
  if(pr.right>window.innerWidth-8)pop.style.left=(window.innerWidth-pr.width-8)+'px';
  pop.querySelector('textarea').focus();
  ev.stopPropagation();
}
function saveProNote(eid){
  proNotes[eid]=dom('pro-note-ta')?.value.trim()||'';
  try{localStorage.setItem('proNotes',JSON.stringify(proNotes));}catch(e){}
  document.getElementById('cell-note-popup')?.remove();
  renderAll();
}

