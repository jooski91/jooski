function buildMonth(month){
  const TOTAL_DAYS=31; // 항상 31칸 고정
  const days=getDays(year,month);
  const s=sched[month];
  const teams=[...new Set(emps.filter(e=>e.team).map(e=>e.team))];
  const CNT_TYPES=getCntTypes();const lcN=CNT_TYPES.length;

  // colgroup — 항상 31칸 + 비고 330px 고정
  let cg=`<col class="col-name"><col class="col-rank"><col class="col-team">`;
  for(let d=1;d<=TOTAL_DAYS;d++)cg+=`<col class="col-day">`;
  cg+=`<col class="col-note-fixed">`;
  for(let i=0;i<lcN;i++)cg+=`<col class="col-lc-fixed">`;

  // header row1 — 날짜 헤더 (실제 날짜 + 빈칸)
  const _todayD=new Date();const _ty=_todayD.getFullYear(),_tm=_todayD.getMonth()+1,_td=_todayD.getDate();
  let h1=`<tr><th class="th-base" rowspan="2" style="vertical-align:middle">이름</th><th class="th-base" rowspan="2" style="vertical-align:middle">직급</th><th class="th-base" rowspan="2" style="vertical-align:middle;border-right:2px solid var(--border-sep)!important">팀</th>`;
  for(let d=1;d<=TOTAL_DAYS;d++){
    if(d<=days){
      const hol=getHoliday(year,month,d);
      const isToday=(year===_ty&&month===_tm&&d===_td);
      const sc=isToday?'th-today':(hol?'th-sun':isSat(year,month,d)?'th-sat':isSun(year,month,d)?'th-sun':'');
      const dn=(dayNotes[year]&&dayNotes[year][month]&&dayNotes[year][month][d])||'';
      const dot=dn?`<div style="width:4px;height:4px;border-radius:50%;background:var(--accent);margin:1px auto 0"></div>`:'';
      const titleText=[hol,dn].filter(Boolean).join(' / ')||'날짜 메모';
      const weSun=(hol||isSun(year,month,d))?'week-end':'';
      h1+=`<th class="${sc} ${weSun}" style="cursor:pointer" onclick="openDayNote(event,this,${month},${d})" title="${titleText}"><div class="th-day">${d}</div>${dot}</th>`;
    } else {
      h1+=`<th class="th-base th-empty" rowspan="2"></th>`; // 빈 날짜 셀 — 두 행 통합
    }
  }
  h1+=`<th class="th-base" rowspan="2" style="vertical-align:middle;border-left:2px solid var(--border-sep)!important;border-right:2px solid var(--border-sep)!important">비고</th>`;
  h1+=`<th class="th-base" colspan="${lcN}" style="font-size:8px;color:var(--text3)">count</th>`;
  h1+=`</tr>`;

  // header row2 — 요일 헤더
  let h2=`<tr>`;
  for(let d=1;d<=TOTAL_DAYS;d++){
    if(d<=days){
      const hol=getHoliday(year,month,d);
      const isToday2=(year===_ty&&month===_tm&&d===_td);
      const sc=isToday2?'th-today':(hol?'th-sun':isSat(year,month,d)?'th-sat':isSun(year,month,d)?'th-sun':'');
      const weSun2h=(hol||isSun(year,month,d))?'week-end':'';
      h2+=`<th class="${sc} ${weSun2h}"><div class="th-dow">${getDOW(year,month,d)}</div></th>`;
    }
    // 빈 날짜는 h1에서 rowspan="2"로 처리했으므로 h2에선 생략
  }
  CNT_TYPES.forEach(ct=>h2+=`<th class="th-dow" style="font-family:'Pretendard',sans-serif;font-weight:700;color:${ct.c};background:${ct.bg||'var(--surface3)'}">${ct.v}</th>`);
  h2+=`</tr>`;

  // rows
  // 팀 열 rowspan 계산
  const activeEmps=emps.filter(e=>empActiveInMonth(e,year,month));
  // 각 직원이 팀열에서 몇 행을 차지하는지 (owner=2, staff=1)
  // 연속된 같은 팀 그룹별로 rowspan 합산
  const teamRowspanMap=new Map(); // empId → rowspan (첫 직원만 값, 나머지 -1=생략)
  let gi=0;
  while(gi<activeEmps.length){
    const e=activeEmps[gi];
    const team=e.role==='owner'?'__owner__':e.team;
    let span=e.role==='owner'?2:1;
    let j=gi+1;
    while(j<activeEmps.length){
      const ne=activeEmps[j];
      const nt=ne.role==='owner'?'__owner__':ne.team;
      if(nt!==team) break;
      span+=ne.role==='owner'?2:1;
      j++;
    }
    teamRowspanMap.set(e.id,'first:'+span);
    for(let k=gi+1;k<j;k++) teamRowspanMap.set(activeEmps[k].id,'skip');
    gi=j;
  }

  let body='';
  emps.forEach((e,idx)=>{
    if(!empActiveInMonth(e, year, month)) return;
    const sch=s[e.id]||{};
    const even=idx%2===1?'tr-even':'';
    const ownr=e.role==='owner'?'tr-owner':'';
    const nextActive=emps.slice(idx+1).find(x=>empActiveInMonth(x,year,month));
    const prevActive=emps.slice(0,idx).reverse().find(x=>empActiveInMonth(x,year,month));
    // 팀 경계 구분선: 팀이 바뀌거나 owner 인접 시
    const sepN=(nextActive&&e.team!==nextActive.team)||nextActive?.role==='owner'?'sep-bottom':'';
    const sepTop=e.role==='owner'||(prevActive&&prevActive.role==='owner')?'sep-top':'';

    if(e.role==='owner'){
      const ownerTeams=teams.slice(0,2);
      ['O','C'].forEach((rowType,ri)=>{
        const subKey=`${e.id}_${rowType}`;
        const subSch=s[subKey]||{};
        const isLast=ri===1;
        // owner 첫 행: 위 구분선 / 마지막 행: 아래 구분선
        const sepRow=isLast?'sep-bottom':'';
        const sepTopRow=ri===0?'sep-top':'';
        body+=`<tr class="tr-data ${even} ${ownr} ${sepRow} ${sepTopRow}">`;
        if(ri===0){
          body+=`<td class="td-name" rowspan="2" style="vertical-align:middle">${e.name}</td>
            <td class="td-rank" rowspan="2" style="vertical-align:middle">${e.rank||''}</td>`;
        }
        body+=`<td class="td-team" style="font-size:9px;color:var(--text3);text-align:center">${ownerTeams[ri]||''}</td>`;
        for(let d=1;d<=TOTAL_DAYS;d++){
          if(d<=days){
            const v=subSch[d]||'';
            const csStyle=v?getShiftStyle(v):'';
            const weSun2=(getHoliday(year,month,d)||isSun(year,month,d))?'week-end':'';
            let bg=v?(csStyle?'cell-custom':`cell-${v}`):(getHoliday(year,month,d)||isSun(year,month,d)?'cell-sun-bg':isSat(year,month,d)?'cell-sat-bg':'cell-empty');
            const cn=getCellNote(`${e.id}_${rowType}`,month,d);
            body+=`<td class="cell ${bg} ${weSun2}${cn?' has-cell-note':''}" tabindex="0" data-eid="${e.id}_${rowType}" data-m="${month}" data-d="${d}" onclick="onCellClick(this,event)" oncontextmenu="onCtx(this,event)"${csStyle?` style="${csStyle}"`:''}${cn?` title="${cn}"`:''}>${v}</td>`;
          } else {
            body+=`<td class="cell-pad"></td>`; // 빈 패딩 셀
          }
        }
        if(ri===0){
          const note=notes[`${month}_${e.id}`]||'';
          body+=`<td class="td-note ${note?'has-note':''}" rowspan="2" data-month="${month}" style="vertical-align:middle;cursor:pointer" onclick="openNoteInline(event,this,${e.id},${month})">${note?note:''}</td>`;
        }
        const ownCnts={};CNT_TYPES.forEach(ct=>ownCnts[ct.v]=0);
        for(let d=1;d<=days;d++){const v=subSch[d]||'';if(ownCnts[v]!==undefined)ownCnts[v]++;}
        CNT_TYPES.forEach((ct,ci)=>{
          const val=ownCnts[ct.v]||'';
          const lcBorder=ci===0?'border-left:2px solid var(--border-sep)!important;':'';
          body+=`<td class="td-lc" style="${lcBorder}color:${ct.c}">${val}</td>`;
        });
        body+=`</tr>`;
      });
    } else {
      const cnts={};CNT_TYPES.forEach(ct=>cnts[ct.v]=0);
      for(let d=1;d<=days;d++){const v=sch[d]||'';if(cnts[v]!==undefined)cnts[v]++;}
      const _trs=teamRowspanMap.get(e.id);
      const _teamTd=_trs==='skip'?'':
        `<td class="td-team" rowspan="${_trs&&_trs.startsWith('first:')?parseInt(_trs.split(':')[1]):1}" style="vertical-align:middle;text-align:center">${e.team||''}</td>`;
      body+=`<tr class="tr-data ${even} ${ownr} ${sepN} ${sepTop}">
        <td class="td-name">${e.name}</td>
        <td class="td-rank">${e.rank||''}</td>
        ${_teamTd}`;
      for(let d=1;d<=TOTAL_DAYS;d++){
        if(d<=days){
          const v=sch[d]||'';
          const csStyle=v?getShiftStyle(v):'';
          const weSun2=(getHoliday(year,month,d)||isSun(year,month,d))?'week-end':'';
          let bg=v?(csStyle?'cell-custom':`cell-${v}`):(getHoliday(year,month,d)||isSun(year,month,d)?'cell-sun-bg':isSat(year,month,d)?'cell-sat-bg':'cell-empty');
          const cn=getCellNote(`${e.id}`,month,d);
          body+=`<td class="cell ${bg} ${weSun2}${cn?' has-cell-note':''}" tabindex="0" data-eid="${e.id}" data-m="${month}" data-d="${d}" onclick="onCellClick(this,event)" oncontextmenu="onCtx(this,event)"${csStyle?` style="${csStyle}"`:''}${cn?` title="${cn}"`:''}>${v}</td>`;
        } else {
          body+=`<td class="cell-pad"></td>`;
        }
      }
      const note=notes[`${month}_${e.id}`]||'';
      body+=`<td class="td-note ${note?'has-note':''}" data-month="${month}" style="cursor:pointer" onclick="openNoteInline(event,this,${e.id},${month})">${note?note:''}</td>`;
      CNT_TYPES.forEach((ct,ci)=>{
        const val=cnts[ct.v]||'';
        const lcBorder=ci===0?'border-left:2px solid var(--border-sep)!important;':'';
        body+=`<td class="td-lc" style="${lcBorder}color:${ct.c}">${val}</td>`;
      });
      body+=`</tr>`;
    }
  });

  // coverage rows — 31칸 고정
  const ownerRowKey=['O','C'];
  teams.forEach((team,ti)=>{
    const te=emps.filter(e=>e.team===team&&empActiveInMonth(e,year,month));
    ['O','C'].forEach((type,typeIdx)=>{
      const isFirstCov=ti===0&&type==='O';
      // 팀명 셀은 OPEN 행에만 rowspan=2로 출력, CLOSE 행에서는 생략
      const teamCell=typeIdx===0
        ?`<td class="cov-label" rowspan="2" style="border-right:2px solid var(--border-sep)!important;vertical-align:middle">${team}</td>`
        :'';
      body+=`<tr class="tr-cov${isFirstCov?' sep-top':''}"><td class="cov-label" colspan="2">${type==='O'?'OPEN':'CLOSE'}</td>${teamCell}`;
      for(let d=1;d<=TOTAL_DAYS;d++){
        if(d<=days){
          let cnt=te.filter(e=>(s[e.id]||{})[d]===type).length;
          emps.filter(e=>e.role==='owner').forEach(e=>{
            const subKey=`${e.id}_${ownerRowKey[ti]}`;
            if((s[subKey]||{})[d]===type) cnt++;
          });
          const weSunC=(getHoliday(year,month,d)||isSun(year,month,d))?'week-end':'';
          body+=`<td class="${cnt>0?'cov-ok':'cov-zero'} ${weSunC}">${cnt||'✕'}</td>`;
        } else {
          body+=`<td class="cell-pad"></td>`;
        }
      }
      body+=`<td style="border-left:2px solid var(--border-sep)!important;border-right:2px solid var(--border-sep)!important"></td><td colspan="${lcN}" style="border-left:2px solid var(--border-sep)!important"></td></tr>`;
    });
  });

  const wrap=document.createElement('div');
  wrap.className='month-block'+(foldedMonths.has(month)?' folded':'');
  wrap.dataset.month=month;
  const MN=['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
  wrap.innerHTML=`
    <div class="month-title"><span class="month-title-inner" onclick="toggleMonth(this.closest('.month-block'))"><span class="month-fold-btn">▾</span>${year}년 ${MN[month-1]} <small>${days}일</small></span></div>
    <div class="table-wrap">
      <table class="sch-table"><colgroup>${cg}</colgroup>
        <thead>${h1}${h2}</thead>
        <tbody>${body}</tbody>
      </table>
    </div>`;
  return wrap;
}

/* ─── KEYBOARD ─── */
let sel=null,justSel=false,composing=false,kbTimer=null;

/* ─── UNDO ─── */
const UNDO_LIMIT=50;
const undoStack=[];
function snapshotForUndo(){
  undoStack.push(JSON.stringify(sched));
  if(undoStack.length>UNDO_LIMIT)undoStack.shift();
}
function undo(){
  if(!undoStack.length){showToast('더 이상 되돌릴 수 없습니다');return;}
  const prev=undoStack.pop();
  const parsed=JSON.parse(prev);
  for(const k of Object.keys(sched))delete sched[k];
  Object.assign(sched,parsed);
  renderAll();
  if(sel){
    const e_=sel.dataset.eid,m_=sel.dataset.m,d_=sel.dataset.d;
    requestAnimationFrame(()=>{
      const r=document.querySelector(`td.cell[data-eid="${e_}"][data-m="${m_}"][data-d="${d_}"]`);
      if(r)selectCell(r);
    });
  }
  showToast('되돌리기 완료');
}

document.addEventListener('compositionstart',()=>{composing=true;});
document.addEventListener('compositionend',e=>{
  composing=false;
  if(!sel)return;
  const map={'오':'O','마':'C','휴':'휴','리':'R','연':'연','반':'반','결':'결','출':'출'};
  const v=map[e.data]||getShifts().find(t=>t.l.startsWith(e.data))?.v;
  if(v!==undefined)setVal(v);
});

function selectCell(td){
  if(sel)sel.classList.remove('sel');
  sel=td;td.classList.add('sel');
  try{td.focus({preventScroll:false});}catch(ex){}
  showHint();justSel=true;setTimeout(()=>justSel=false,200);
}
function deselect(){if(sel){sel.classList.remove('sel');sel=null;}hideHint();}
function showHint(){const h=dom('kb-hint');h.classList.add('show');clearTimeout(kbTimer);kbTimer=setTimeout(hideHint,4000);}
function hideHint(){dom('kb-hint').classList.remove('show');}

function onCellClick(td,ev){ev.stopPropagation();selectCell(td);}
document.addEventListener('click',e=>{
  if(justSel)return;
  if(sel&&!e.target.closest('td.cell')&&!e.target.closest('.ctx-menu'))deselect();
});

document.addEventListener('keydown',e=>{
  if((e.ctrlKey||e.metaKey)&&e.key==='s'){e.preventDefault();exportData(true);return;}
  if((e.ctrlKey||e.metaKey)&&e.key==='z'){e.preventDefault();undo();return;}
  if(dom('edit-ov').classList.contains('open'))return;
  if(document.getElementById('cell-note-popup')||document.getElementById('day-note-popup'))return;
  if(document.querySelector('.modal-ov'))return;
  // textarea나 input에 포커스가 있으면 단축키 무시 (메모 입력 중)
  const ae=document.activeElement;
  if(ae&&(ae.tagName==='TEXTAREA'||ae.tagName==='INPUT'))return;
  if(!sel){
    if(['ArrowRight','ArrowLeft','ArrowDown','ArrowUp'].includes(e.key)){
      const a=allCells();if(a.length){selectCell(a[0]);e.preventDefault();}
    }
    return;
  }
  if(e.key==='ArrowRight'||(e.key==='Tab'&&!e.shiftKey)){move('right');e.preventDefault();return;}
  if(e.key==='ArrowLeft'||(e.key==='Tab'&&e.shiftKey)){move('left');e.preventDefault();return;}
  if(e.key==='ArrowDown'||e.key==='Enter'){move('down');e.preventDefault();return;}
  if(e.key==='ArrowUp'){move('up');e.preventDefault();return;}
  if(e.key==='Escape'){closeCtx();deselect();e.preventDefault();return;}
  if(e.key==='Delete'||e.key==='Backspace'){setVal('');e.preventDefault();return;}
  // IME 한글 입력 중에도 물리 키(e.code) 기준으로 단축키 시도

  if(!Object.keys(KB).length)KB={...KB_DEFAULT};
  const _pk=e.code.startsWith('Key')?e.code.slice(3).toLowerCase():null;
  const v=KB[_pk]!==undefined?KB[_pk]:KB[e.key];
  if(v!==undefined){setVal(v);e.preventDefault();composing=false;return;}
  if(composing)return;
});

function allCells(){return Array.from(document.querySelectorAll('td.cell[tabindex="0"]'));}
function move(dir){
  if(!sel)return;
  const all=allCells(),idx=all.indexOf(sel);if(idx<0)return;
  const {eid,m,d}=sel.dataset;
  let next=null;
  if(dir==='right')next=all.slice(idx+1).find(t=>t.dataset.eid===eid&&t.dataset.m===m)||all[idx+1];
  else if(dir==='left')next=all.slice(0,idx).reverse().find(t=>t.dataset.eid===eid&&t.dataset.m===m)||all[idx-1];
  else if(dir==='down'){next=all.slice(idx+1).find(t=>t.dataset.m===m&&t.dataset.d===d);if(!next)next=all.find(t=>t.dataset.m===String(parseInt(m)+1)&&t.dataset.d===d);}
  else if(dir==='up')next=all.slice(0,idx).reverse().find(t=>t.dataset.m===m&&t.dataset.d===d);
  if(next)selectCell(next);
}
function setVal(v){
  if(!sel)return;
  snapshotForUndo();
  const eid=sel.dataset.eid,m=parseInt(sel.dataset.m),d=parseInt(sel.dataset.d);
  if(eid.startsWith('pro_')){
    const pid=parseInt(eid.slice(4));
    const ps=getProYearSched(year);
    if(!ps[m][pid])ps[m][pid]={};
    if(v==='')delete ps[m][pid][d];else ps[m][pid][d]=v;
  } else {
    if(!sched[m][eid])sched[m][eid]={};
    if(v==='')delete sched[m][eid][d];else sched[m][eid][d]=v;
  }
  const{eid:e_,m:m_,d:d_}=sel.dataset;
  renderAll();
  requestAnimationFrame(()=>{
    const r=document.querySelector(`td.cell[data-eid="${e_}"][data-m="${m_}"][data-d="${d_}"]`);
    if(r)selectCell(r);
  });
}

/* ─── CONTEXT MENU ─── */
function onCtx(td,ev){
  ev.preventDefault();ev.stopPropagation();selectCell(td);
  const rawEid=td.dataset.eid;
  const baseEid=parseInt(rawEid);
  const emp=emps.find(x=>x.id===baseEid);
  const hasOff=emp&&emp.off&&emp.off.length>=2&&emp.off.includes(getDOW(year,parseInt(td.dataset.m),parseInt(td.dataset.d)));
  const cn=getCellNote(rawEid,parseInt(td.dataset.m),parseInt(td.dataset.d));
  const menu=dom('ctx-menu');
  menu.innerHTML=`<div class="ctx-title">근무 유형 선택</div>`+
    getShifts().map(t=>`<div class="ctx-item" onclick="setVal('${t.v}');closeCtx()">
      <span class="ctx-badge" style="background:${t.bg};color:${t.c}">${t.v||'✕'}</span>
      <span>${t.l}</span></div>`).join('')+
    (hasOff?`<div style="height:1px;background:var(--border);margin:4px 0"></div>
      <div class="ctx-title">격주 휴무</div>
      <div class="ctx-item" onclick="startBiweekly(this);closeCtx()">
        <span class="ctx-badge" style="background:var(--h-bg);color:var(--h-c)">휴</span>
        <span>이날부터 격주 패턴 채우기<br><small style="color:var(--text3);font-size:9px">${emp.off.join('→')}</small></span>
      </div>`:'')+
    `<div style="height:1px;background:var(--border);margin:4px 0"></div>
     <div class="ctx-item" onclick="openCellNote(event);closeCtx()">
       <span class="ctx-badge" style="background:var(--surface2);color:var(--accent);font-size:13px">✎</span>
       <span>${cn?'메모 수정':'메모 추가'}${cn?` <small style="color:var(--text3);max-width:90px;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;vertical-align:bottom">${cn}</small>`:''}</span>
     </div>`;
  menu.dataset.eid=rawEid;
  menu.style.display='block';
  menu.style.left=Math.min(ev.clientX,innerWidth-180)+'px';
  menu.style.top=Math.min(ev.clientY+4,innerHeight-460)+'px';
}
function closeCtx(){dom('ctx-menu').style.display='none';}
document.addEventListener('mousedown',e=>{if(!dom('ctx-menu').contains(e.target))closeCtx();});

function startBiweekly(el){
  if(!sel)return;
  const rawEid=sel.dataset.eid;
  const baseEid=parseInt(rawEid);
  const m=parseInt(sel.dataset.m);
  const startD=parseInt(sel.dataset.d);
  const emp=emps.find(x=>x.id===baseEid);
  if(!emp||!emp.off||emp.off.length<1)return;

  const off=emp.off; // 순서 그대로 사용 (일월토수 → 일월토수)
  const days=getDays(year,m);
  const keys=emp.role==='owner'?[`${baseEid}_O`,`${baseEid}_C`]:[baseEid];
  let filled=0;

  // off 배열 순서대로 날짜 목록 생성: 시작일부터 off[0]요일, off[1]요일, ... 순서로
  // 달력에서 각 요일이 등장하는 날짜를 off 순서에 맞게 뽑아냄
  const offDaySlots=[]; // {d, offIdx} — off 배열 몇번째 요일인지
  let offIdx=0; // 현재 채워야 할 off 배열 인덱스
  // 시작일의 요일이 off 배열에서 몇 번째인지 찾기
  const startDow=getDOW(year,m,startD);
  const startOffIdx=off.indexOf(startDow);
  if(startOffIdx<0){showToast('시작일이 휴무 요일이 아닙니다');return;}
  offIdx=startOffIdx;

  // 시작일부터 순회하며 off 패턴 순서대로 날짜 배정
  for(let d=startD;d<=days;d++){
    const dow=getDOW(year,m,d);
    if(dow!==off[offIdx])continue;
    offDaySlots.push({d,offIdx});
    offIdx=(offIdx+1)%off.length;
  }

  keys.forEach(key=>{
    if(!sched[m][key])sched[m][key]={};
    const sc=sched[m][key];
    offDaySlots.forEach(({d})=>{
      if(PRESERVE.includes(sc[d]))return;
      sc[d]='휴';filled++;
    });
  });

  const r=document.querySelector(`td.cell[data-eid="${sel.dataset.eid}"][data-m="${sel.dataset.m}"][data-d="${sel.dataset.d}"]`);
  renderAll();
  if(r){const nr=document.querySelector(`td.cell[data-eid="${rawEid}"][data-m="${m}"][data-d="${startD}"]`);if(nr)selectCell(nr);}
  showToast(`${m}월 격주 휴무 ${filled}칸 채움`);
}

