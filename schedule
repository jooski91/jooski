let _savedProAnnualTotals=${JSON.stringify(proAnnualTotals)};
let _savedShiftTableData=${JSON.stringify(shiftTableData)};
let _savedAutoFillConfig=${JSON.stringify(autoFillConfig)};
let _savedRulesData=${JSON.stringify(rulesData)};
`;
  const html='<!DOCTYPE html>\n'+document.documentElement.outerHTML;
  const now=new Date();
  const stamp=`${now.getFullYear()}${String(now.getMonth()+1).padStart(2,'0')}${String(now.getDate()).padStart(2,'0')}`;
  const fileName=`schedule_${stamp}.html`;
  const blob=new Blob([html],{type:'text/html;charset=utf-8'});

  if(window.showSaveFilePicker){
    try{
      // 기존 파일 핸들 있으면 바로 덮어쓰기
      if(silent&&_fileHandle){
        const writable=await _fileHandle.createWritable();
        await writable.write(blob);
        await writable.close();
        _showSavedMark();
        return;
      }
      // 새 저장 위치 선택
      const fh=await window.showSaveFilePicker({
        suggestedName:fileName,
        types:[{description:'HTML 파일',accept:{'text/html':['.html']}}],
      });
      _fileHandle=fh;
      const writable=await fh.createWritable();
