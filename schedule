.toast{position:fixed;bottom:22px;right:22px;background:var(--surface2);border:1px solid var(--border2);color:var(--text);padding:9px 15px;border-radius:8px;font-size:12px;box-shadow:0 4px 20px var(--shadow);animation:fadeup .2s;z-index:99999;pointer-events:none}
