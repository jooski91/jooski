];
let lsLessons=[], lsLessonId=1, lsDayOffset=0, lsEditId=null, lsHolidays={};
let lsView='all'; // 'all' | 'pro'
let lsSelectedPro=0;

// Calendar state
let calYear=new Date().getFullYear(), calMonth=new Date().getMonth();

function lsProColor(i){ return LS_COLORS[i%LS_COLORS.length]; }
function lsProColorByName(name){ const i=lsPros.findIndex(p=>p.name===name); return i>=0?lsProColor(i):'#999'; }
function lsDateKey(d){ return d.getFullYear()+'-'+(d.getMonth()+1).toString().padStart(2,'0')+'-'+d.getDate().toString().padStart(2,'0'); }
function lsCurrentDate(){ const d=new Date(); d.setDate(d.getDate()+lsDayOffset); return d; }
const DAY_KO=['일','월','화','수','목','금','토'];
function isToday(d){ return lsDateKey(d)===lsDateKey(new Date()); }

function lsDayMove(n){ lsDayOffset+=n; lsRender(); }
function lsGoToday(){ lsDayOffset=0; lsRender(); }
