function mbdTdSave(){
  var m = members.find(function(x){ return x.id === mbDetailId; });
  if(!m || _mbdDetailTicketIdx === null) return;
  var tk = m.tickets[_mbdDetailTicketIdx];
  tk.startDate = document.getElementById('mbd-td-startdate').value;
  tk.endDate   = document.getElementById('mbd-td-enddate').value || '';
  tk.pro       = document.getElementById('mbd-td-pro').value;
  // 판매내역 연동: 결제방법 수정 → 미수금 재계산
  var payMethod = document.getElementById('mbd-td-pay').value;
  if(m.sales && tk.id){
    var sale = m.sales.find(function(s){ return s.ticketId === tk.id; });
    if(sale){
      sale.payMethod = payMethod;
      sale.unpaid    = payMethod ? 0 : sale.payAmount;
      sale.saleStatus= sale.unpaid > 0 ? '미수금' : '결제완료';
      sale.completedAt = sale.unpaid === 0 ? Date.now() : null;
    }
  }
  saveState();
  document.getElementById('mbd-ticket-detail-ov').style.display = 'none';
  mbdRenderTickets();
  mbdRenderSales();
  // 변경내역 기록
  tkChangeLogPush(mbDetailId, '기간변경', tkLogName(tk),
    '기간 '+tk.startDate+(tk.endDate?' ~ '+tk.endDate:''),
    '담당: '+(tk.pro||'없음'));
}

function mbdTdDelete(){
  var m = members.find(function(x){ return x.id === mbDetailId; });
  if(!m) return;
  if(_mbdDetailTicketIdx === null || _mbdDetailTicketIdx === undefined) return;
  if(!m.tickets || !m.tickets[_mbdDetailTicketIdx]) return;
  var idx = _mbdDetailTicketIdx;
  var tk = m.tickets[idx];
  var g  = tkGroups.find(function(x){ return +x.id === +tk.groupId; });
  var it = tkItems.find(function(x){ return +x.id === +tk.itemId; });
  var name = (g && it) ? g.name+' / '+it.name : '이용권';

  // 연결된 레슨 수 파악
  var linkedLessons = lsLessons.filter(function(l){
    if(l.memberId !== m.id) return false;
    if(tk.id && l.ticketId === tk.id) return true;
    if(l.ticketIdx === idx) return true;
    return false;
  });

  var msg = '「'+name+'」을 삭제하시겠습니까?';
  if(linkedLessons.length > 0) msg += '\n\n연결된 레슨 예약 '+linkedLessons.length+'건도 함께 삭제됩니다.';

  if(!confirm(msg)) return;

  // ① 연결된 레슨 삭제
  lsLessons = lsLessons.filter(function(l){
    if(l.memberId !== m.id) return true;
    if(tk.id && l.ticketId === tk.id) return false;
    if(l.ticketIdx === idx) return false;
    return true;
  });

  // ② ticketIdx 재정렬 (삭제된 idx 이후 -1)
  lsLessons.forEach(function(l){
    if(l.memberId === m.id && l.ticketIdx != null && l.ticketIdx > idx){
      l.ticketIdx -= 1;
    }
  });

  // ③ 포인트 차감 (이 이용권으로 적립된 2% 환수)
  var saleRec = (m.sales||[]).find(function(s){ return s.ticketId === tk.id; });
  if(saleRec && saleRec.payAmount > 0){
    var earned = Math.floor(saleRec.payAmount * 0.02);
    if(earned > 0 && m.points){
      m.points = Math.max(0, m.points - earned);
      if(!m.pointHistory) m.pointHistory = [];
      m.pointHistory.push({
        type: 'deduct',
        amount: earned,
        reason: '이용권 삭제 포인트 환수 ('+name+')',
        balanceAfter: m.points,
        createdAt: Date.now()
      });
    }
  }

  // ④ 판매내역 삭제
  if(m.sales && tk.id){
    m.sales = m.sales.filter(function(s){ return s.ticketId !== tk.id; });
  }

  // ⑤ 이용권 삭제
  m.tickets.splice(idx, 1);
  _mbdDetailTicketIdx = null;

  saveState();
  lsRender();
  document.getElementById('mbd-ticket-detail-ov').style.display = 'none';
  mbdRenderTickets();
  mbdRenderSales();
  mbdRenderHome();
  try{ mbdRenderPointHistory(); }catch(e){}
  showToast('이용권 삭제 완료' + (linkedLessons.length > 0 ? ' · 레슨 '+linkedLessons.length+'건 삭제됨' : ''), 'ok');
}

