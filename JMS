function ciRenderSide(id, dateStr){
  var m = members.find(function(x){ return x.id===id; });
  if(!m){
    document.getElementById('ci-side-empty').style.display='flex';
    document.getElementById('ci-side-info').style.display='none';
    return;
  }
  document.getElementById('ci-side-empty').style.display='none';
  document.getElementById('ci-side-info').style.display='flex';
  var isFemale = m.gender==='여';
  var avEl = document.getElementById('ci-side-avatar');
  avEl.innerHTML = isFemale
    ? '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" width="26" height="26"><ellipse cx="32" cy="18" rx="11" ry="12" fill="#be185d" opacity=".8"/><path d="M14 54c0-10.5 8-17 18-17s18 6.5 18 17" fill="#be185d" opacity=".8"/><path d="M22 37c0 0-2 4-2 8h24c0-4-2-8-2-8" fill="#be185d" opacity=".6"/><path d="M26 37 Q32 43 38 37" fill="#be185d" opacity=".5"/></svg>'
    : '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" width="26" height="26"><ellipse cx="32" cy="18" rx="11" ry="12" fill="#fff" opacity=".9"/><path d="M14 54c0-10.5 8-17 18-17s18 6.5 18 17" fill="#fff" opacity=".9"/><rect x="24" y="36" width="16" height="10" rx="2" fill="#fff" opacity=".7"/></svg>';
  document.getElementById('ci-side-name').textContent   = m.name;
  document.getElementById('ci-side-gender').textContent = m.gender||'';
  document.getElementById('ci-side-phone').textContent  = '전화번호: '+(m.phone||'—');
  var mnEl = document.getElementById('ci-side-membernum');
  if(mnEl) mnEl.textContent = m.num ? '회원번호: '+m.num : '';

  // 이용권 (잔여횟수 + 유효기간 표시)
  var tkEl = document.getElementById('ci-side-tickets');
  var today = ciTodayStr();
  var activeTks = (m.tickets||[]).filter(function(tk){ return !tk.refunded && (!tk.endDate||tk.endDate>=today); });
  if(!activeTks.length){
    tkEl.innerHTML='<div style="font-size:11px;color:#aaa">유효한 이용권 없음</div>';
  } else {
    tkEl.innerHTML = activeTks.map(function(tk){
      var tkIdx = m.tickets.indexOf(tk);
      var g = tkGroups.find(function(x){ return +x.id===+tk.groupId; });
      var it = tkItems.find(function(x){ return +x.id===+tk.itemId; });
      var gName = g ? g.name : '이용권';
      var itName = it ? it.name : '';
      var meta = tkCatMeta(g ? g.cat : '');
      var bc = (meta.badgeCls||'#eee:#666').split(':');
      // 잔여횟수
      var usedC = lsLessons.filter(function(l){
        if(l.memberId!==m.id) return false;
        if(tk.id && l.ticketId===tk.id) return true;
        if(l.ticketIdx===tkIdx) return true;
        return false;
      }).filter(function(l){ return l.status==='attend'||l.status==='absent'; }).length;
      var totalC = it && it.count ? +it.count : null;
      var remC = totalC !== null ? Math.max(0, totalC - usedC) : null;
      var remColor = remC===null?'#888':remC===0?'#dc2626':remC<=3?'#d97706':'#16a34a';
      var remBg    = remC===null?'#f1f5f9':remC===0?'#fee2e2':remC<=3?'#fef3c7':'#f0fdf4';
      var countBadge = remC!==null
        ? '<span style="font-size:10px;font-weight:700;padding:2px 6px;border-radius:4px;background:'+remBg+';color:'+remColor+'">잔여 '+remC+'/'+totalC+'회</span>'
        : '';
      // 유효기간
      var resolvedEnd = tk.endDate || '';
      if(!resolvedEnd && tk.startDate && it && g){ try{ resolvedEnd=_calcEndDate(tk.startDate,it.days,it.validDays,g.cat); }catch(e){} }
      var expBadge = '';
      if(resolvedEnd){
        var diffD = Math.round((new Date(resolvedEnd)-new Date(today))/(1000*60*60*24));
        var expColor = diffD<=0?'#dc2626':diffD<=7?'#d97706':'#555';
        var expBg    = diffD<=0?'#fee2e2':diffD<=7?'#fef3c7':'#f1f5f9';
        expBadge = '<span style="font-size:10px;font-weight:700;padding:2px 6px;border-radius:4px;background:'+expBg+';color:'+expColor+'">~'+resolvedEnd+(diffD<=7&&diffD>0?' ('+diffD+'일)':diffD===0?' (오늘)':diffD<0?' (만료)':'')+'</span>';
      } else {
        expBadge = '<span style="font-size:10px;color:#aaa;padding:2px 6px">기간 무제한</span>';
      }
      return '<div style="padding:8px 10px;border:1px solid #e8ecf0;border-radius:7px;background:#fafafa">'+
        '<div style="display:flex;align-items:center;gap:5px;margin-bottom:5px">'+
          '<span style="font-size:10px;font-weight:700;padding:2px 6px;border-radius:4px;flex-shrink:0;background:'+bc[0]+';color:'+bc[1]+'">'+meta.badge+'</span>'+
          '<span style="font-size:12px;font-weight:700;color:#111;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1">'+esc(gName)+(itName?' / '+esc(itName):'')+'</span>'+
        '</div>'+
        '<div style="display:flex;gap:5px;flex-wrap:wrap">'+
          countBadge+expBadge+
        '</div>'+
      '</div>';
    }).join('');
  }

  // 메모
  var memoWrap = document.getElementById('ci-side-memo-wrap');
  var memoEl   = document.getElementById('ci-side-memo');
  if(memoEl){
    var memoText = (m.memo||'').trim();
    memoEl.textContent = memoText || '';
    if(memoWrap) memoWrap.style.display='block';
  }
}
