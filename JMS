function mbGetExpiry(m){
  var today = new Date().toISOString().slice(0,10);
  var active = (m.tickets||[]).filter(function(tk){ return !tk.endDate||tk.endDate>=today; });
  if(!active.length){
    var all = (m.tickets||[]).filter(function(tk){ return tk.endDate; });
    if(!all.length) return '—';
    all.sort(function(a,b){ return b.endDate.localeCompare(a.endDate); });
    return '<span style="color:#dc2626">'+all[0].endDate+'</span>';
  }
  var dates = active.filter(function(tk){ return tk.endDate; }).map(function(tk){ return tk.endDate; });
  if(!dates.length) return '무제한';
  dates.sort();
  var d = dates[0];
  var diff = Math.round((new Date(d)-new Date(today))/(1000*60*60*24));
  var color = diff<=7 ? '#dc2626' : diff<=30 ? '#c07000' : '#333';
  return '<span style="color:'+color+'">'+d+'</span>';
}

function mbGetRemainCount(m){
  var today = new Date().toISOString().slice(0,10);
  var active = (m.tickets||[]).filter(function(tk){ return !tk.endDate||tk.endDate>=today; });
  if(!active.length) return '—';
  var total = 0, found = false;
  active.forEach(function(tk, idx){
    var it = tkItems.find(function(x){ return +x.id===+tk.itemId; });
    var tc = tk.totalCount!=null ? tk.totalCount : (it&&it.count ? +it.count : null);
    if(tc===null) return;
    found = true;
    var used = lsLessons.filter(function(l){
      if(l.memberId!==m.id) return false;
      if(tk.id && l.ticketId===tk.id) return true;
      var origIdx = (m.tickets||[]).indexOf(tk);
      if(l.ticketIdx===origIdx) return true;
      return false;
    }).length;
    total += Math.max(0, tc - used);
  });
  if(!found) return '—';
  return '<span style="font-weight:700;color:#1a5fa0">'+total+'회</span>';
}

var _mbFiltered = [];

function mbExportExcel(){
  var today = new Date().toISOString().slice(0,10);
  var rows = [['#','지점','이름','성별','연락처','이용권','담당프로','만료일','잔여횟수','포인트','회원번호']];
  _mbFiltered.forEach(function(m, i){
    var active = (m.tickets||[]).filter(function(tk){ return !tk.endDate||tk.endDate>=today; });
    var tkName = active.length ? (function(){
      var tk=active[active.length-1];
      var g=tkGroups.find(function(x){return +x.id===+tk.groupId;});
      var it=tkItems.find(function(x){return +x.id===+tk.itemId;});
      return (g&&it)?g.name+'/'+it.name:(it?it.name:'');
    })() : '';
    var pro = active.length ? (active[active.length-1].pro||'') : '';
    var expiry = (function(){
      var dates=active.filter(function(tk){return tk.endDate;}).map(function(tk){return tk.endDate;});
      if(!dates.length) return active.length?'무제한':'';
      dates.sort(); return dates[0];
    })();
    var remain = (function(){
      var total=0,found=false;
      active.forEach(function(tk){
        var it=tkItems.find(function(x){return +x.id===+tk.itemId;});
        var tc=tk.totalCount!=null?tk.totalCount:(it&&it.count?+it.count:null);
        if(tc===null) return; found=true;
        var used=lsLessons.filter(function(l){
          if(l.memberId!==m.id) return false;
          if(tk.id&&l.ticketId===tk.id) return true;
          return l.ticketIdx===(m.tickets||[]).indexOf(tk);
        }).length;
        total+=Math.max(0,tc-used);
      });
      return found?total:'';
    })();
    rows.push([i+1,m.branch||'동대구센터',m.name,m.gender||'',m.phone||'',tkName,pro,expiry,remain,(m.points||0),m.num||'']);
  });
  var csv = rows.map(function(r){ return r.map(function(c){ return '"'+(c+'').replace(/"/g,'""')+'"'; }).join(','); }).join('\n');
  var blob = new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'});
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = '회원리스트_'+today+'.csv';
  a.click();
}

function mbRender(){
  mbSyncBranchSelects();
  // select 옵션 동적 갱신
  const tkSel=document.getElementById('mb-filter-ticket');
  if(tkSel){ const cur=tkSel.value; tkSel.innerHTML='<option value="">전체</option>'; tkGroups.forEach(function(g){ var o=document.createElement('option'); o.value=g.name; o.textContent=g.name; tkSel.appendChild(o); }); if(cur) tkSel.value=cur; }
  const proSel2=document.getElementById('mb-filter-pro');
  if(proSel2){ const cur=proSel2.value; proSel2.innerHTML='<option value="">전체</option>'; lsPros.forEach(function(p){ var o=document.createElement('option'); o.value=p.name; o.textContent=p.name; proSel2.appendChild(o); }); if(cur) proSel2.value=cur; }

  const q=(document.getElementById('mb-search')||{}).value||'';
  const grEl=document.querySelector('input[name="mb-gender-r"]:checked');
  const gf=grEl?grEl.value:'';
  const stEl=document.querySelector('input[name="mb-status-r"]:checked');
  const statusF=stEl?stEl.value:'valid';
  const sort=(document.getElementById('mb-sort')||{}).value||'newest';
  const branch=(document.getElementById('mb-filter-branch')||{}).value||'';
  const dateFrom=(document.getElementById('mb-filter-date-from')||{}).value||'';
  const dateTo=(document.getElementById('mb-filter-date-to')||{}).value||'';
  const filterTicket=(document.getElementById('mb-filter-ticket')||{}).value||'';
  const filterPro=(document.getElementById('mb-filter-pro')||{}).value||'';
  const filterRemainRaw=(document.getElementById('mb-filter-remain')||{}).value;
  const filterRemain=filterRemainRaw!==''?parseInt(filterRemainRaw):null;
  const filterExpire=(document.getElementById('mb-filter-expire')||{}).value||'';
  const today=new Date().toISOString().slice(0,10);

  // 회원 유효 여부 헬퍼
  function mbIsValid(m){
    if(!m.tickets||!m.tickets.length) return false;
    return m.tickets.some(function(tk){
      if(!tk.endDate) return true; // 만료일 없으면 유효
      return tk.endDate >= today;
    });
  }
  // 회원 남은 횟수 헬퍼 (활성 이용권 전체 합산)
  function mbRemainCount(m){
    if(!m.tickets||!m.tickets.length) return null;
    var active=m.tickets.filter(function(tk){ return !tk.endDate||tk.endDate>=today; });
    if(!active.length) return null;
    var total=0, found=false;
    active.forEach(function(tk){
      var it=tkItems.find(function(x){ return +x.id===+tk.itemId; });
      var tc=tk.totalCount!=null?tk.totalCount:(it&&it.count?+it.count:null);
      if(tc===null) return;
      found=true;
      var origIdx=(m.tickets||[]).indexOf(tk);
      var used=lsLessons.filter(function(l){
        if(l.memberId!==m.id) return false;
        if(tk.id&&l.ticketId===tk.id) return true;
        if(l.ticketIdx===origIdx) return true;
        return false;
      }).length;
      total+=Math.max(0,tc-used);
    });
    return found?total:null;
  }

  let filtered=members.filter(m=>{
    const matchQ=!q||m.name.includes(q)||(m.phone||'').includes(q)||(m.num||'').includes(q);
    const matchG=!gf||(m.gender||'')===gf;
    const matchB=!branch||(m.branch||'').includes(branch);
    let matchD=true;
    if(dateFrom||dateTo){
      const addedDate=m.addedAt?new Date(m.addedAt).toISOString().slice(0,10):'';
      if(dateFrom&&addedDate<dateFrom) matchD=false;
      if(dateTo&&addedDate>dateTo) matchD=false;
    }
    // 이용권 종류
    let matchT=true;
    if(filterTicket){
      matchT=!!(m.tickets&&m.tickets.some(function(tk){
        var g=tkGroups.find(function(x){return +x.id===+tk.groupId;});
        return g&&g.name===filterTicket;
      }));
    }
    // 담당 프로
    let matchP=true;
    if(filterPro){
      matchP=!!(m.tickets&&m.tickets.some(function(tk){ return tk.pro===filterPro; }));
    }
    // 남은 횟수 이하
    let matchR=true;
    if(filterRemain!==null){
      var rc=mbRemainCount(m);
      matchR=(rc!==null && rc<=filterRemain);
    }
    // 만료일 기준
    let matchE=true;
    if(filterExpire){
      matchE=!!(m.tickets&&m.tickets.some(function(tk){
        return tk.endDate && tk.endDate<=filterExpire;
      }));
    }
    // 회원 상태
    let matchS=true;
    if(statusF==='valid')   matchS=mbIsValid(m);
    if(statusF==='expired') matchS=!mbIsValid(m);

    return matchQ&&matchG&&matchB&&matchD&&matchT&&matchP&&matchR&&matchE&&matchS;
  });

  // 정렬
  filtered=[...filtered];
  if(sort==='newest') filtered.sort((a,b)=>(b.addedAt||0)-(a.addedAt||0));
  else if(sort==='oldest') filtered.sort((a,b)=>(a.addedAt||0)-(b.addedAt||0));
  else if(sort==='name') filtered.sort((a,b)=>a.name.localeCompare(b.name,'ko'));
  else if(sort==='num') filtered.sort((a,b)=>(a.num||'').localeCompare(b.num||'','ko',{numeric:true}));

  const totalEl=document.getElementById('mb-total');
  const isFiltered=q||gf||branch||dateFrom||dateTo||filterTicket||filterPro||filterRemain!==null||filterExpire||statusF!=='valid';
  if(totalEl) totalEl.textContent = members.length;
  const badge=document.getElementById('mb-filter-badge');
  const filteredCount=document.getElementById('mb-filtered-count');
  if(badge) badge.style.display = isFiltered ? '' : 'none';
  if(filteredCount) filteredCount.textContent = filtered.length;

  const tbody=document.getElementById('mb-tbody');
  const empty=document.getElementById('mb-empty');

  if(!filtered.length){
    tbody.innerHTML='';
    empty.style.display='block';
    document.getElementById('mb-pagination').innerHTML='';
    return;
  }
  empty.style.display='none';

  // 페이지네이션
  _mbFiltered = filtered;
  const total = filtered.length;
  const pageCount = Math.ceil(total / mbPerPage);
  if(mbCurrentPage > pageCount) mbCurrentPage = 1;
  const start = (mbCurrentPage-1)*mbPerPage;
  const paged = filtered.slice(start, start+mbPerPage);

  tbody.innerHTML=paged.map((m,i)=>`
    <tr style="border-bottom:1px solid #f0f0f0;cursor:pointer" onclick="mbDetailOpen(${m.id})" onmouseover="this.style.background='#f0f6ff'" onmouseout="this.style.background=''">
      <td style="padding:9px 14px;color:#bbb;font-size:11px">${start+i+1}</td>
      <td style="padding:9px 14px;color:#888;font-size:12px">${esc(m.branch||'동대구센터')}</td>
      <td style="padding:9px 14px;font-weight:700;color:#111">${esc(m.name)}</td>
      <td style="padding:9px 14px">${m.gender==='남'?'<span style="color:#3b82f6;font-size:11px;font-weight:700">남</span>':m.gender==='여'?'<span style="color:#ec4899;font-size:11px;font-weight:700">여</span>':''}</td>
      <td style="padding:9px 14px;color:#555;font-size:12px">${esc(m.phone||'—')}</td>
      <td style="padding:9px 14px;font-size:12px">${mbGetTicketBadge(m)}</td>
      <td style="padding:9px 14px;font-size:12px;color:#1a5fa0;font-weight:600">${esc(mbGetActivePro(m))}</td>
      <td style="padding:9px 14px;font-size:12px">${mbGetExpiry(m)}</td>
      <td style="padding:9px 14px;font-size:12px;text-align:center">${mbGetRemainCount(m)}</td>
      <td style="padding:9px 14px;font-size:12px;text-align:right;color:#7c3aed;font-weight:600">${(m.points||0).toLocaleString()}P</td>
      <td style="padding:9px 14px;color:#666;font-size:12px">${esc(m.num||'—')}</td>
    </tr>`).join('');

  // 페이지 버튼
  const pgEl = document.getElementById('mb-pagination');
  if(pgEl){
    if(pageCount<=1){ pgEl.innerHTML=''; return; }
    let ph='<div style="display:flex;gap:4px;justify-content:center;padding:12px">';
    ph+=`<button onclick="mbCurrentPage=1;mbRender()" style="padding:4px 9px;border:1px solid #ddd;border-radius:5px;background:#fff;cursor:pointer;font-size:12px" ${mbCurrentPage===1?'disabled':''}>«</button>`;
    ph+=`<button onclick="mbCurrentPage=Math.max(1,mbCurrentPage-1);mbRender()" style="padding:4px 9px;border:1px solid #ddd;border-radius:5px;background:#fff;cursor:pointer;font-size:12px" ${mbCurrentPage===1?'disabled':''}>‹</button>`;
    const s=Math.max(1,mbCurrentPage-2), e2=Math.min(pageCount,s+4);
    for(let p=s;p<=e2;p++){
      ph+=`<button onclick="mbCurrentPage=${p};mbRender()" style="padding:4px 9px;border:1px solid ${p===mbCurrentPage?'#1a5fa0':'#ddd'};border-radius:5px;background:${p===mbCurrentPage?'#1a5fa0':'#fff'};color:${p===mbCurrentPage?'#fff':'#333'};cursor:pointer;font-size:12px;font-weight:${p===mbCurrentPage?'700':'400'}">${p}</button>`;
    }
    ph+=`<button onclick="mbCurrentPage=Math.min(pageCount,mbCurrentPage+1);mbRender()" style="padding:4px 9px;border:1px solid #ddd;border-radius:5px;background:#fff;cursor:pointer;font-size:12px" ${mbCurrentPage===pageCount?'disabled':''}>›</button>`;
    ph+=`<button onclick="mbCurrentPage=pageCount;mbRender()" style="padding:4px 9px;border:1px solid #ddd;border-radius:5px;background:#fff;cursor:pointer;font-size:12px" ${mbCurrentPage===pageCount?'disabled':''}>»</button>`;
    ph+='</div>';
    pgEl.innerHTML=ph;
  }
}


