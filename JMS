/* 기타 스케줄 차단 여부 */
function lsIsBlockedByOther(proName, dateStr, slotHhmm){
  var slotEnd = calcEndTime(slotHhmm, 30);
  return lsOtherScheds.some(function(s){
    return s.date===dateStr && s.start<slotEnd && s.end>slotHhmm && s.pro===proName;
  });
}

