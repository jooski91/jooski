/* ── 날짜 헬퍼 ── */
function ciTodayStr(){
  var d = new Date(); return d.getFullYear()+'-'+(d.getMonth()+1+'').padStart(2,'0')+'-'+(d.getDate()+'').padStart(2,'0');
}
function ciOffsetDate(offset){
  var d = new Date(); d.setDate(d.getDate()+offset);
  return d.getFullYear()+'-'+(d.getMonth()+1+'').padStart(2,'0')+'-'+(d.getDate()+'').padStart(2,'0');
}
function ciDateLabel(dateStr){
  var p = dateStr.split('-'); var d = new Date(+p[0],+p[1]-1,+p[2]);
  var wd=['일','월','화','수','목','금','토'][d.getDay()];
  var today = ciTodayStr();
  return p[0]+'년 '+parseInt(p[1])+'월 '+parseInt(p[2])+'일 ('+wd+')';
}
function ciDayMove(n){ ciDateOffset+=n; ciRender(); }
function ciGoToday(){ ciDateOffset=0; ciRender(); }
function ciSetDate(val){
  if(!val) return;
  var today = ciTodayStr();
  var tp = today.split('-'); var vp = val.split('-');
  var td = new Date(+tp[0],+tp[1]-1,+tp[2]);
  var vd = new Date(+vp[0],+vp[1]-1,+vp[2]);
  ciDateOffset = Math.round((vd-td)/(1000*60*60*24));
  ciRender();
}
function ciSetFilter(f){
  ciFilter = f;
  var sel = document.getElementById('ci-filter-select');
  if(sel) sel.value = f;
  ciRender();
}

