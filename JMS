function lsTimeSlots(){
  const s=[];
  for(let h=LS_START_H;h<LS_END_H;h++){
    s.push({h,m:0,label:pad(h)+':00',isHour:true});
    s.push({h,m:30,label:pad(h)+':30',isHour:false});
  }
  return s;
}
function timeToSlotIdx(hhmm){
  const[h,m]=hhmm.split(':').map(Number);
  return (h-LS_START_H)*2+(m>=30?1:0);
}

