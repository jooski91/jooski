function acrGetRange(){
  var now = new Date(); now.setHours(0,0,0,0);
  var s, e, label;
  if(_acrUnit === 'day'){
    s = new Date(now); s.setDate(s.getDate() + _acrOffset);
    e = new Date(s);
    label = s.getFullYear()+'.'+(s.getMonth()+1).toString().padStart(2,'0')+'.'+s.getDate().toString().padStart(2,'0');
  } else if(_acrUnit === 'week'){
    var mon = new Date(now); mon.setDate(mon.getDate() - ((mon.getDay()+6)%7) + _acrOffset*7);
    s = new Date(mon); e = new Date(mon); e.setDate(e.getDate()+6);
    label = (s.getMonth()+1)+'/'+s.getDate()+' ~ '+(e.getMonth()+1)+'/'+e.getDate();
  } else {
    s = new Date(now.getFullYear(), now.getMonth() + _acrOffset, 1);
    e = new Date(now.getFullYear(), now.getMonth() + _acrOffset + 1, 0);
    label = s.getFullYear()+'년 '+(s.getMonth()+1)+'월';
  }
  s.setHours(0,0,0,0); e.setHours(23,59,59,999);
  return {s:s, e:e, label:label};
}

