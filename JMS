    if(!w.drinkId){
      drinkBadge='<button class="btn-sm" style="font-size:10px;padding:2px 7px;border-color:#f59e0b;color:#92400e;background:#fffbeb" onclick="toggleDrink('+w.id+')">🥤 음료 선택</button>';
    } else if(w.drinkId==='none'){
      drinkBadge='<button class="btn-sm" style="font-size:10px;padding:2px 7px;border-color:#ccc;color:#888;background:#f5f5f5" onclick="toggleDrink('+w.id+')">🚫 음료없음</button>';
    } else if(!w.drinkDone){
      drinkBadge='<span style="display:inline-flex;align-items:center;gap:3px">'+
        '<button class="btn-sm" style="font-size:10px;padding:2px 7px;border-color:#ffc069;color:#d46b08;background:#fff7e6" onclick="toggleDrink('+w.id+')">⏳ '+esc(dl)+'</button>'+
        '<button class="btn-sm ok" style="font-size:10px;padding:2px 7px;font-weight:700" onclick="markDrinkDone('+w.id+')">제공완료</button>'+
        '</span>';
    } else {
      drinkBadge='<button class="btn-sm" style="font-size:10px;padding:2px 7px;border-color:#8cc870;color:#1a5010;background:#f0faf4" onclick="toggleDrink('+w.id+')">✅ '+esc(dl)+'</button>';
    }
    // 배치 예상
    let bayHtml='';
    if(!r.bayKey){
      bayHtml='<span style="font-size:11px;color:#e53e3e;font-weight:600">⚠ 배치 불가</span>';
    } else {
      const lbl=r.kind==='room'?'R'+r.num+' 룸':r.num+'번 타석';
      const zoneTxt='';
      if(r.endMin===0){
        bayHtml='<span class="fc-bay ok assignable" data-wid="'+w.id+'" data-key="'+r.bayKey+'" style="font-size:11px">✓ '+lbl+zoneTxt+' <span class="fc-time">탭하여 배정</span></span>';
      } else {
        const cls=r.endMin<=15?'wait':'ok';
        bayHtml='<span class="fc-bay '+cls+'" data-baykey="'+r.bayKey+'" style="font-size:11px">→ '+lbl+zoneTxt+' <span class="fc-time">약 '+r.endMin+'분 후</span></span>';
      }
    }
    return '<div class="wi">'+
      '<div class="wi-top">'+
      '<div class="wrank '+(i===0?'first':'')+'">'+(i+1)+'</div>'+
      '<div class="winfo">'+
      '<div class="wname">'+esc(w.name)+'</div>'+
      '<div class="wmeta">'+typeBadge+(w.memo?'<span style="color:#aaa"> · </span>'+esc(w.memo):'')+' · <span class="w-wait-time" data-addedat="'+w.addedAt+'">'+wTime(w.addedAt)+'</span></div>'+
      '</div>'+
      drinkBadge+
      '</div>'+
      '<div class="wi-bot" style="justify-content:flex-end;margin-top:6px">'+
      bayHtml+
      '</div></div>';
  }).join('');
  el.querySelectorAll('.fc-bay.assignable').forEach(btn=>{
    btn.addEventListener('click',function(){
      assignFromForecast(+this.dataset.wid, this.dataset.key);
    });
  });
}

function assignFromForecast(wid, bayKey){
  const w=waiting.find(x=>x.id===wid);if(!w)return;
  const isRoom=bayKey.startsWith('r');
  const num=parseInt(bayKey.slice(1));
  const arr=isRoom?rooms:bays;
  const slot=arr.find(b=>b.num===num);
  if(!slot){alert('타석을 찾을 수 없습니다.');return;}
  if(slot.status!=='empty'){alert('이미 사용 중인 타석입니다.');return;}
  slot.status='occupied';slot.name=w.name;slot.type=w.type;slot.startTime=N();slot.dur=isRoom?RD():SD();slot.mark='';slot.markNote='';
  slot.drinkId=w.drinkId||null;slot.drinkTemp=w.drinkTemp||null;slot.drinkDone=w.drinkDone||false;
  waiting=waiting.filter(x=>x.id!==wid);
  renderBays();renderW();renderW2();renderBaySummary();updateStats();
  if(fcActive||fcActive1)runForecast();
  if(lesHL)calcLesson();
}


