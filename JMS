function mMbKeydown(e){
  const dd=document.getElementById('m-mb-dropdown');
  if(!dd||dd.style.display==='none')return;
  const items=dd.querySelectorAll('[data-idx]');
  if(!items.length)return;
  if(e.key==='ArrowDown'){e.preventDefault();_mMbIdx=Math.min(_mMbIdx+1,items.length-1);}
  else if(e.key==='ArrowUp'){e.preventDefault();_mMbIdx=Math.max(_mMbIdx-1,0);}
  else if(e.key==='Enter'&&_mMbIdx>=0){e.preventDefault();items[_mMbIdx].dispatchEvent(new MouseEvent('mousedown'));return;}
  else if(e.key==='Escape'){dd.style.display='none';return;}
  else{return;}
  items.forEach((el,i)=>el.style.background=i===_mMbIdx?'#e8f0ff':'');
}

