/* ===== TOPBAR ===== */
:root{--tb-h:56px;--stb-h:28px;--total-h:84px}
/* ── 슈퍼 탑바 (파란 최상단 바) ── */
.super-topbar{
  position:fixed;top:0;left:0;right:0;height:var(--stb-h);
  background:#1a5fa0;z-index:201;
  display:flex;align-items:center;
}
.super-topbar-logo{
  padding:0 18px;font-size:13px;font-weight:800;color:#fff;
  letter-spacing:.3px;white-space:nowrap;flex-shrink:0;
  border-right:1px solid rgba(255,255,255,.2);height:100%;
  display:flex;align-items:center;min-width:140px;cursor:pointer;
}
.super-topbar-actions{
  display:flex;align-items:center;gap:2px;padding:0 8px;
  border-right:1px solid rgba(255,255,255,.2);flex-shrink:0;
}
.stb-btn{
  background:none;border:none;cursor:pointer;color:rgba(255,255,255,.82);
  width:30px;height:30px;border-radius:6px;
  display:flex;align-items:center;justify-content:center;
  font-size:16px;transition:all .12s;
}
.stb-btn:hover{color:#fff;background:rgba(255,255,255,.18)}
.super-topbar-search{
  display:flex;align-items:center;padding:0 12px;
  border-right:1px solid rgba(255,255,255,.2);flex-shrink:0;
}
.stb-search-wrap{
  display:flex;align-items:center;
  border:1px solid rgba(255,255,255,.35);border-radius:14px;
  background:rgba(255,255,255,.15);overflow:hidden;
  transition:border-color .15s,background .15s;
}
.stb-search-wrap:focus-within{border-color:rgba(255,255,255,.7);background:rgba(255,255,255,.25)}
.stb-search-wrap input{
  border:none;background:none;padding:4px 6px 4px 10px;
  font-size:12px;font-family:inherit;outline:none;width:140px;color:#fff;
}
.stb-search-wrap input::placeholder{color:rgba(255,255,255,.6)}
.stb-search-btn{
  background:none;border:none;cursor:pointer;
  padding:3px 8px 3px 2px;color:rgba(255,255,255,.7);font-size:12px;
  display:flex;align-items:center;
}
.stb-search-btn:hover{color:#fff}
.super-topbar-nav{display:flex;align-items:center;height:100%;flex-shrink:0}
.stb-item{
  display:flex;align-items:center;height:100%;
  padding:0 15px;font-size:12px;font-weight:600;color:rgba(255,255,255,.82);
  cursor:pointer;border:none;background:none;
  font-family:inherit;transition:all .15s;white-space:nowrap;
  border-right:1px solid rgba(255,255,255,.12);
}
.stb-item:hover{color:#fff;background:rgba(255,255,255,.13)}
.stb-item.active{color:#fff;background:rgba(255,255,255,.2);font-weight:700}
.stb-hamburger{
  display:none;align-items:center;justify-content:center;
  width:36px;height:36px;margin-right:4px;
  border:none;background:none;cursor:pointer;border-radius:7px;
  color:rgba(255,255,255,.85);transition:background .12s;flex-shrink:0;
}
.stb-hamburger:hover{background:rgba(255,255,255,.18)}
@media(max-width:768px){
  .super-topbar-nav{display:none}
  .stb-hamburger{display:flex}
  .super-topbar-logo{min-width:auto;padding:0 10px}
}
.topbar{
  position:fixed;top:var(--stb-h);left:0;right:0;height:var(--tb-h);
  background:#fff;z-index:200;
  display:flex;align-items:center;gap:0;
  border-bottom:1px solid #e0e4ea;
  box-shadow:0 1px 6px rgba(0,0,0,.06);
}
.topbar-logo{
  padding:0 16px;font-size:14px;font-weight:800;color:#1a5fa0;
  letter-spacing:.3px;white-space:nowrap;flex-shrink:0;
  border-right:1px solid #eaecf0;height:100%;display:flex;align-items:center;justify-content:center;
  min-width:130px;
}
.topbar-nav{display:flex;align-items:center;height:100%;flex-shrink:0}
.topbar-item{
  display:flex;align-items:center;gap:6px;height:100%;
  padding:0 16px;font-size:13px;font-weight:600;color:#666;
  cursor:pointer;border:none;background:none;
  font-family:inherit;transition:all .15s;white-space:nowrap;
  border-right:1px solid #f0f0f0;
}
.topbar-item:hover{color:#1a5fa0;background:#f5f9ff}
.topbar-item.active{color:#1a5fa0;background:#f0f6ff}
.topbar-divider{width:1px;height:24px;background:#eee;margin:0 4px;flex-shrink:0}
/* 상단 버튼 그룹 (홈/뒤로/새로고침) */
.topbar-actions{display:flex;align-items:center;gap:2px;padding:0 8px;border-right:1px solid #eaecf0;flex-shrink:0}
.tb-btn{
  background:none;border:none;cursor:pointer;color:#666;
  width:40px;height:40px;border-radius:7px;
  display:flex;align-items:center;justify-content:center;
  font-size:22px;transition:all .12s;
}
.tb-btn:hover{color:#1a5fa0;background:#eaf3fc}
/* 회원 검색 */
.topbar-search{
  display:flex;align-items:center;padding:0 12px;
  border-right:1px solid #eaecf0;flex-shrink:0;
}
.topbar-search-wrap{
  display:flex;align-items:center;
  border:1px solid #e0e0e0;border-radius:18px;
  background:#f8f9fa;transition:border-color .15s,background .15s;
  overflow:hidden;
}
.topbar-search-wrap:focus-within{border-color:#90bce0;background:#fff}
.topbar-search-wrap input{
  border:none;background:none;padding:6px 8px 6px 12px;
  font-size:13px;font-family:inherit;outline:none;width:160px;
  color:#333;
}
.topbar-search-wrap input:focus{width:150px}
.topbar-search-wrap input::placeholder{color:#bbb}
.topbar-search-btn{
  background:none;border:none;cursor:pointer;
  padding:4px 10px 4px 4px;color:#aaa;font-size:13px;
  display:flex;align-items:center;transition:color .12s;
  flex-shrink:0;
}
.topbar-search-btn:hover{color:#1a5fa0}

/* Layout shift — topbar 대신 상단 여백 */
body{margin-left:0;margin-top:var(--total-h);transition:none}
