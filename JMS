function lsRenderMemberTicketPanel(m, preselIdx){
  const panel=document.getElementById('ls-member-ticket-panel');
  const inner=document.getElementById('ls-member-ticket-inner');
  const instructor=document.getElementById('ls-instructor').value;
  const tkList=lsGetMemberLessonTickets(m, instructor);
  const avatarColor=m.gender==='여'?'#be185d':'#1d4ed8';
  let html=`<div class="ls-tk-panel-header">
    <div class="ls-tk-member-chip">
      <div class="ls-member-avatar" style="background:${avatarColor};width:28px;height:28px;font-size:12px">${esc(m.name.charAt(0))}</div>
      <div><div class="ls-tk-chip-name">${esc(m.name)}</div><div class="ls-tk-chip-meta">${esc(m.phone||'—')}</div></div>
    </div>
    <button class="ls-tk-change-btn" onclick="lsClearStudent();document.getElementById('ls-student-search').focus()">변경</button>
  </div>`;
  html+='<div class="ls-tk-tickets">';
  if(!tkList.length){
    html+='<div class="ls-tk-no-ticket">⚠ 해당 프로의 레슨 이용권이 없습니다</div>';
  } else {
    html+='<div style="font-size:11px;font-weight:700;color:#888;margin-bottom:7px">레슨 이용권 선택 <span style="color:#e53e3e">*</span></div>';
    // preselIdx 없으면 첫 번째 이용권 기본 선택
    const defaultIdx = (preselIdx !== null) ? preselIdx : tkList[0]._origIdx;
    if(_lsSelectedTicketIdx === null) _lsSelectedTicketIdx = defaultIdx;
    tkList.forEach((tk,i)=>{
      const it=tkItems.find(x=>+x.id===+tk.itemId);
      const g=tkGroups.find(x=>+x.id===+tk.groupId);
      const meta=g?tkCatMeta(g.cat):null;
      const cols=meta?meta.badgeCls.split(':'):['#eee','#666'];
      const isSel=(tk._origIdx === defaultIdx);
      if(isSel) _lsSelectedTicketIdx=tk._origIdx;
      const parts=[];
      if(it&&it.count) parts.push(it.count+'회');
      if(it&&it.days)  parts.push(it.days+'일');
      // 유효기간
      const today2=ciTodayStr();
      let expStr='기간 무제한';
      let expColor='#aaa';
      if(tk.endDate){
        const dLeft=Math.round((new Date(tk.endDate)-new Date(today2))/(1000*60*60*24));
        expColor=dLeft<=7?'#dc2626':dLeft<=30?'#d97706':'#6b7280';
        expStr='~'+tk.endDate+(dLeft<0?' (만료)':dLeft===0?' (오늘)':' ('+dLeft+'일)');
      }
      html+=`<button class="ls-tk-ticket-row${isSel?' selected':''}" onclick="lsSelTicket(this,${tk._origIdx})">
        <span style="font-size:11px;font-weight:700;padding:2px 7px;border-radius:6px;background:${cols[0]};color:${cols[1]};flex-shrink:0">${esc(meta?meta.badge:'')}</span>
        <div style="flex:1;display:flex;flex-direction:column;gap:2px;min-width:0">
          <span style="font-size:12px;font-weight:700;color:#222">${esc(it?it.name:g?g.name:'이용권')}</span>
          <span style="font-size:10px;color:${expColor}">${expStr}</span>
        </div>
        <span style="font-size:11px;color:#888;flex-shrink:0">${parts.join(' · ')}</span>
      </button>`;
    });
  }
  html+='</div>';
  inner.innerHTML=html;
  panel.style.display='block';
  // 기본 선택된 이용권으로 레슨 시간 자동 세팅
  if(tkList.length){
    var defBtn = inner.querySelector('.ls-tk-ticket-row.selected');
    if(defBtn) lsSelTicket(defBtn, _lsSelectedTicketIdx);
  }
}
function lsSelTicket(btn, origIdx){
  document.querySelectorAll('.ls-tk-ticket-row').forEach(b=>{b.classList.remove('selected');});
  btn.classList.add('selected');
  _lsSelectedTicketIdx=origIdx;
  // 이용권 카테고리로 레슨 시간 자동 세팅
  var mid = document.getElementById('ls-selected-member-id').value;
  if(mid){
    var m = members.find(function(x){ return x.id===+mid; });
    if(m && m.tickets && m.tickets[origIdx]){
      var tk = m.tickets[origIdx];
      var g = tkGroups.find(function(x){ return +x.id===+tk.groupId; });
      if(g){
        var durEl = document.getElementById('ls-duration');
        if(g.cat==='레슨-30분' && durEl) durEl.value='30';
        else if(g.cat==='레슨-50분' && durEl) durEl.value='50';
      }
    }
  }
}
/* 해당 회원의 레슨 이용권 중 현재 프로가 담당인 것만 반환 */
function lsGetMemberLessonTickets(m, instructor){
  if(!m||!m.tickets) return [];
  return m.tickets
    .map((tk,i)=>({...tk,_origIdx:i}))
    .filter(tk=>{
      const g=tkGroups.find(x=>+x.id===+tk.groupId);
      if(!g) return false;
      const isLesson=g.cat==='레슨-30분'||g.cat==='레슨-50분';
      if(!isLesson) return false;
      // 담당 프로 일치 여부 (프로 미선택 시 모두 표시)
      if(instructor && tk.pro && tk.pro!==instructor) return false;
      return true;
    });
}
