/* ── 환불 취소 (환불 이전 상태로 되돌림) ── */
function mbdRefundCancel(idx){
  var m = members.find(function(x){ return x.id===mbDetailId; });
  if(!m||!m.sales||!m.sales[idx]) return;
  var s = m.sales[idx];
  if(s.saleStatus !== '환불'){ showToast('환불 상태가 아닙니다','warn'); return; }
  if(!confirm('환불을 취소하고 원래 판매 상태로 되돌리겠습니까?')) return;
  // 환불 전 상태 복원
  s.saleStatus  = s._prevSaleStatus || (s.unpaid > 0 ? '미수금' : '결제완료');
  s.refundAmount  = undefined;
  s.refundPenalty = undefined;
  s.refundReason  = undefined;
  s.refundAt      = undefined;
  s._prevSaleStatus = undefined;
  // unpaid 복원: payMethod 있으면 0, 없으면 payAmount
  if(s.payMethod){
    s.unpaid = 0;
    s.saleStatus = '결제완료';
  } else {
    s.unpaid = s.payAmount || 0;
    s.saleStatus = '미수금';
  }

  // 연결된 이용권 만료 복원
  var _rtkc = m.tickets ? m.tickets.find(function(t){ return t.id === s.ticketId; }) : null;
  if(_rtkc && _rtkc.refunded){
    _rtkc.refunded = false;
    _rtkc.refundedAt = undefined;
    if(_rtkc._origEndDate !== undefined){
      _rtkc.endDate = _rtkc._origEndDate;
      _rtkc._origEndDate = undefined;
    }
  }

  // 삭제된 예약 레슨은 복원하지 않음 (환불 취소해도 레슨 예약은 유지 안 됨)
  if(s._canceledLessons) s._canceledLessons = undefined;

  // 차감된 포인트 복원 (환불금액의 2%)
  if(s.refundAmount > 0){
    var restorePt = Math.floor(s.refundAmount * 0.02);
    if(restorePt > 0){
      if(!m.points) m.points = 0;
      m.points += restorePt;
      if(!m.pointHistory) m.pointHistory = [];
      m.pointHistory.push({
        type: 'earn',
        amount: restorePt,
        reason: '환불 취소 · 포인트 복원',
        balanceAfter: m.points,
        createdAt: Date.now()
      });
    }
  }

  saveState();
  lsRender();
  mbdRenderSales();
  mbdRenderTickets();
  mbdRenderHome();
  mbdRenderRefundHistory();
  mbdRenderExpiredTickets();
  mbdRenderPointHistory();
  // 변경내역 기록
  tkChangeLogPush(mbDetailId, '환불취소', tkLogNameById(s.groupId, s.itemId), '환불 취소 · 판매상태 복원', s.saleStatus);
  showToast('환불이 취소되었습니다', 'ok');
}

