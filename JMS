/* ── 판매 계산 (실시간) ── */
function mbdTkCalcPayment(){
  var price    = parseFloat(document.getElementById('mbd-tk-price').value)||0;
  var discount = parseFloat(document.getElementById('mbd-tk-discount').value)||0;
  var point    = parseFloat(document.getElementById('mbd-tk-point').value)||0;
  var salePrice = Math.max(0, price - discount);
  var payAmount = Math.max(0, salePrice - point);
  var summaryEl = document.getElementById('mbd-tk-price-summary');
  var salePriceWrap = document.getElementById('mbd-tk-sale-price-wrap');
  if(price > 0 || discount > 0 || point > 0){
    summaryEl.style.display = 'block';
    document.getElementById('mbd-tk-pay-amount-lbl').textContent = payAmount.toLocaleString()+'원';
    if(discount > 0 || point > 0){
      salePriceWrap.style.display = 'block';
      document.getElementById('mbd-tk-sale-price-lbl').textContent = salePrice.toLocaleString()+'원';
    } else {
      salePriceWrap.style.display = 'none';
    }
  } else {
    summaryEl.style.display = 'none';
  }
  mbdPayInputChanged(); // 복합결제 미수금 재계산
}

