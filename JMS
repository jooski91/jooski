var tkGroups = [];   // [{id, name, cat}]  cat: '연습장-횟수'|'연습장-기간'|'레슨-30분'|'레슨-50분'
var tkItems  = [];   // [{id, groupId, name, count, days, validDays, price, note}]
var tkGid = 1;       // group id counter
var tkIid = 1;       // item id counter
var tkSelGroupId = null;
var tkEditGroupId = null;  // null=신규
var tkEditItemId  = null;  // null=신규

var TK_CAT = [
  {v:'연습장-횟수', lbl:'연습장 횟수권', group:'연습장', badge:'횟수제', badgeCls:'#dcfce7:#166534'},
  {v:'연습장-기간', lbl:'연습장 기간권', group:'연습장', badge:'기간제', badgeCls:'#dbeafe:#1d4ed8'},
  {v:'레슨-30분',   lbl:'레슨 30분',    group:'레슨',   badge:'30분',   badgeCls:'#fce7f3:#9d174d'},
  {v:'레슨-50분',   lbl:'레슨 50분',    group:'레슨',   badge:'50분',   badgeCls:'#ede9ff:#5b21b6'},
];

function tkCatMeta(v){
  for(var i=0;i<TK_CAT.length;i++) if(TK_CAT[i].v===v) return TK_CAT[i];
  return {v:v,lbl:v,group:'',badge:v,badgeCls:'#eee:#666'};
}

// ── 저장/불러오기 ──
function tkSave(){
  try{
    localStorage.setItem('tdf_tk2', JSON.stringify({
      tkGroups:tkGroups, tkItems:tkItems, tkGid:tkGid, tkIid:tkIid
    }));
  }catch(e){}
}
function tkLoad(){
  try{
    var d = JSON.parse(localStorage.getItem('tdf_tk2')||'{}');
    if(d.tkGroups) tkGroups = d.tkGroups.map(function(g){ return Object.assign({},g,{id:+g.id}); });
    if(d.tkItems)  tkItems  = d.tkItems.map(function(x){ return Object.assign({},x,{id:+x.id,groupId:+x.groupId}); });
    if(d.tkGid) tkGid = +d.tkGid;
    if(d.tkIid) tkIid = +d.tkIid;
  }catch(e){}
}
tkLoad();

// ── 사이드바 + 상세 렌더 ──
function tkRender(){
  var sidebar = document.getElementById('tk-sidebar-list');
  if(!sidebar) return;

  var groups = {
    '연습장': tkGroups.filter(function(g){ return tkCatMeta(g.cat).group==='연습장'; }),
    '레슨':   tkGroups.filter(function(g){ return tkCatMeta(g.cat).group==='레슨'; }),
  };

  var html = '';
  var groupLabels = [
    {key:'연습장', label:'연습장 이용권'},
    {key:'레슨',   label:'레슨 이용권'},
  ];
  groupLabels.forEach(function(gl){
    var list = groups[gl.key];
    if(!list.length) return;
    html += '<div class="tk-sidebar-group-title">' + gl.label + '</div>';
    list.forEach(function(g){
      var meta = tkCatMeta(g.cat);
      var bc = meta.badgeCls.split(':');
      var active = (+g.id === +tkSelGroupId) ? ' active' : '';
      var cnt = tkItems.filter(function(x){ return +x.groupId===+g.id; }).length;
      html += '<button class="tk-sidebar-item' + active + '" onclick="tkSelectGroup(' + g.id + ')">'
            + '<span class="tk-sidebar-item-name">' + esc(g.name) + '</span>'
            + '<span class="tk-sidebar-item-badge" style="background:' + bc[0] + ';color:' + bc[1] + '">' + meta.badge + '</span>'
            + '</button>';
    });
  });

  if(!tkGroups.length){
    html = '<div style="padding:30px 16px;text-align:center;color:#ccc;font-size:13px">이용권을 추가하세요</div>';
  }
  sidebar.innerHTML = html;

  // 선택된 그룹 상세 유지
  if(tkSelGroupId && tkGroups.find(function(g){ return +g.id===+tkSelGroupId; })){
    tkShowDetail(tkSelGroupId);
  } else {
    tkSelGroupId = null;
    var de = document.getElementById('tk-detail-empty');
    var dc = document.getElementById('tk-detail-content');
    if(de) de.style.display = 'flex';
    if(dc) dc.style.display = 'none';
  }
}

function tkIsMobile(){ return window.innerWidth <= 700; }

function tkSelectGroup(id){
  tkSelGroupId = +id;
  tkRender();
  if(tkIsMobile()){
    var layout = document.querySelector('.tk-layout');
    if(layout) layout.classList.add('mobile-detail');
  }
}

function tkGoBack(){
  var layout = document.querySelector('.tk-layout');
  if(layout) layout.classList.remove('mobile-detail');
  tkSelGroupId = null;
  tkRender();
}

function tkShowDetail(gid){
  var g = tkGroups.find(function(x){ return +x.id===+gid; });
  if(!g) return;
  var meta = tkCatMeta(g.cat);
  var de = document.getElementById('tk-detail-empty');
  var dc = document.getElementById('tk-detail-content');
  if(!de||!dc) return;
  de.style.display = 'none';
  dc.style.display = 'block';

  document.getElementById('tk-detail-title').textContent = g.name;
  document.getElementById('tk-detail-sub').textContent = meta.lbl;

  var items = tkItems.filter(function(x){ return +x.groupId===+gid; });
  var rows = '';
  if(!items.length){
    rows = '<div style="padding:30px;text-align:center;color:#ccc;font-size:13px">상품이 없습니다. 아래 버튼으로 추가하세요.</div>';
  } else {
    items.forEach(function(item){
      var meta2 = '';
      if(g.cat==='연습장-횟수') meta2 = (item.count||'—')+'회' + (item.validDays?' / 유효 '+item.validDays+'일':'');
      else if(g.cat==='연습장-기간') meta2 = (item.days||'—')+'일 이용';
      else meta2 = (item.count||'—')+'회' + (item.validDays?' / 유효 '+item.validDays+'일':'');
      if(item.note) meta2 += (meta2?' · ':'')+item.note;
      var price = item.price ? Number(item.price).toLocaleString()+'원' : '—';
      rows += '<div class="tk-item-row">'
            + '<div>'
            + '<div class="tk-item-name">' + esc(item.name) + '</div>'
            + '<div class="tk-item-meta">' + meta2 + '</div>'
            + '</div>'
            + '<div class="tk-item-right">'
            + '<div class="tk-item-price">' + price + '</div>'
            + '<span class="tk-item-status">판매중</span>'
            + '<button class="tk-btn-edit" onclick="tkEditItem(' + item.id + ')">수정</button>'
            + '<button class="tk-btn-del" onclick="tkDeleteItem(' + item.id + ')">삭제</button>'
            + '</div>'
            + '</div>';
    });
  }
  var body = document.getElementById('tk-detail-rows');
  if(body) body.innerHTML = '<div class="tk-detail-body">' + rows + '</div>';
}

// ── 이용권 추가/수정 ──
function tkAddGroup(){
  tkEditGroupId = null;
  tkOpenGroupModal(null);
}
function tkEditGroup(gid){
  tkEditGroupId = +gid;
  var g = tkGroups.find(function(x){ return +x.id===tkEditGroupId; });
  tkOpenGroupModal(g);
}
function tkOpenGroupModal(g){
  var catBtns = '';
  var curCat = g ? g.cat : TK_CAT[0].v;
  TK_CAT.forEach(function(c){
    var sel = c.v===curCat ? ' selected' : '';
    catBtns += '<button type="button" class="tk-type-opt' + sel + '" onclick="tkSelCat(this,\'' + c.v + '\')">'
             + '<span class="tko-lbl">' + c.lbl + '</span></button>';
  });
  document.getElementById('tk-ttl').textContent = g ? '이용권 수정' : '이용권 추가';
  document.getElementById('tk-body').innerHTML =
    '<div class="mr"><label>이용권 이름 *</label>'
    + '<input id="tk-name" type="text" placeholder="이용권 이름 입력" value="' + (g ? esc(g.name) : '') + '"/></div>'
    + '<div class="mr"><label>종류 *</label>'
    + '<div class="tk-type-grid">' + catBtns + '</div>'
    + '<input type="hidden" id="tk-cat" value="' + curCat + '"/></div>'
    + '<div class="mbtns">'
    + '<button class="m-cx" onclick="tkCloseModal()">취소</button>'
    + '<button class="m-ok" onclick="tkConfirmGroup()">저장</button>'
    + '</div>';
  document.getElementById('tk-ov').style.display = 'flex';
  // focus removed to prevent iOS zoom
}
function tkConfirmGroup(){
  var name = (document.getElementById('tk-name').value||'').trim();
  var cat  = document.getElementById('tk-cat').value;
  if(!name){ alert('이름을 입력해주세요.'); return; }
  if(tkEditGroupId){
    var idx = tkGroups.findIndex(function(g){ return +g.id===tkEditGroupId; });
    if(idx>=0) tkGroups[idx] = Object.assign({}, tkGroups[idx], {name:name, cat:cat});
  } else {
    tkGroups.push({id:tkGid++, name:name, cat:cat});
    tkSelGroupId = tkGid - 1;
  }
  tkSave(); tkCloseModal(); tkRender();
}
function tkDeleteGroup(gid){
  var g = tkGroups.find(function(x){ return +x.id===+gid; });
  if(!g) return;
  var cnt = tkItems.filter(function(x){ return +x.groupId===+gid; }).length;
  var msg = cnt ? '「'+g.name+'」 및 상품 '+cnt+'개를 삭제하시겠습니까?' : '「'+g.name+'」을 삭제하시겠습니까?';
  if(!confirm(msg)) return;
  tkGroups = tkGroups.filter(function(x){ return +x.id!==+gid; });
  tkItems  = tkItems.filter(function(x){ return +x.groupId!==+gid; });
  tkSelGroupId = null;
  if(document.querySelector('.tk-layout')) document.querySelector('.tk-layout').classList.remove('mobile-detail');
  tkSave(); tkRender();
}

// ── 상품 추가/수정 ──
function tkAddItem(){
  tkEditItemId = null;
  var g = tkGroups.find(function(x){ return +x.id===+tkSelGroupId; });
  if(!g) return;
  tkOpenItemModal(g, null);
}
function tkEditItem(iid){
  tkEditItemId = +iid;
  var item = tkItems.find(function(x){ return +x.id===tkEditItemId; });
  var g = item ? tkGroups.find(function(x){ return +x.id===+item.groupId; }) : null;
  if(!g) return;
  tkOpenItemModal(g, item);
}
function tkOpenItemModal(g, item){
  var meta = tkCatMeta(g.cat);
  document.getElementById('tk-ttl').textContent = item ? '상품 수정' : '상품 추가';

  var countVal   = item && item.count    ? item.count    : '';
  var daysVal    = item && item.days     ? item.days     : '';
  var validVal   = item && item.validDays? item.validDays: '';
  var priceVal   = item && item.price    ? item.price    : '';
  var noteVal    = item && item.note     ? esc(item.note): '';
  var nameVal    = item ? esc(item.name) : '';

  var fields = '';
  if(g.cat==='연습장-횟수'){
    fields = '<div class="mr"><label>횟수 *</label><input id="tk-count" type="number" min="1" placeholder="횟수 입력" value="' + countVal + '"/></div>'
           + '<div class="mr"><label>유효기간 (일)</label><input id="tk-validDays" type="number" min="1" placeholder="기간 입력" value="' + validVal + '"/></div>';
  } else if(g.cat==='연습장-기간'){
    fields = '<div class="mr"><label>이용기간 (일) *</label><input id="tk-days" type="number" min="1" placeholder="기간 입력" value="' + daysVal + '"/></div>';
  } else {
    fields = '<div class="mr"><label>횟수 *</label><input id="tk-count" type="number" min="1" placeholder="횟수 입력" value="' + countVal + '"/></div>'
           + '<div class="mr"><label>유효기간 (일)</label><input id="tk-validDays" type="number" min="1" placeholder="기간 입력" value="' + validVal + '"/></div>';
  }

  document.getElementById('tk-body').innerHTML =
    '<div class="mr"><label>상품명 *</label>'
    + '<input id="tk-name" type="text" placeholder="상품명 입력" value="' + nameVal + '"/></div>'
    + '<div class="mr" style="background:#f8fafc;padding:8px 10px;border-radius:8px;font-size:12px;color:#888">종류: ' + meta.lbl + '</div>'
    + fields
    + '<div class="mr"><label>가격 (원)</label><input id="tk-price" type="number" min="0" placeholder="판매가 입력" value="' + priceVal + '"/></div>'
    + '<div class="mr"><label>메모 (선택)</label><input id="tk-note" type="text" placeholder="특이사항 등" value="' + noteVal + '"/></div>'
    + '<div class="mbtns">'
    + '<button class="m-cx" onclick="tkCloseModal()">취소</button>'
    + '<button class="m-ok" onclick="tkConfirmItem()">저장</button>'
    + '</div>';

  document.getElementById('tk-ov').style.display = 'flex';
  // focus removed to prevent iOS zoom
}
function tkConfirmItem(){
  var name  = (document.getElementById('tk-name').value||'').trim();
  var price = (document.getElementById('tk-price')||{value:''}).value||'';
  var note  = ((document.getElementById('tk-note')||{value:''}).value||'').trim();
  var count = (document.getElementById('tk-count')||{value:''}).value||'';
  var days  = (document.getElementById('tk-days')||{value:''}).value||'';
  var validDays = (document.getElementById('tk-validDays')||{value:''}).value||'';
  if(!name){ alert('상품 이름을 입력해주세요.'); return; }
  var obj = {groupId:tkSelGroupId, name:name, price:price, note:note,
             count:count?+count:'', days:days?+days:'', validDays:validDays?+validDays:''};
  if(tkEditItemId){
    var idx = tkItems.findIndex(function(x){ return +x.id===tkEditItemId; });
    if(idx>=0) tkItems[idx] = Object.assign({}, tkItems[idx], obj);
  } else {
    tkItems.push(Object.assign({id:tkIid++}, obj));
  }
  tkSave(); tkCloseModal(); tkShowDetail(tkSelGroupId);
}
function tkDeleteItem(iid){
  var item = tkItems.find(function(x){ return +x.id===+iid; });
  if(!item) return;
  if(!confirm('「'+item.name+'」를 삭제하시겠습니까?')) return;
  tkItems = tkItems.filter(function(x){ return +x.id!==+iid; });
  tkSave(); tkShowDetail(tkSelGroupId);
}

// ── 공통 ──
function tkSelCat(btn, val){
  document.querySelectorAll('#tk-body .tk-type-opt').forEach(function(b){
    b.classList.remove('selected');
  });
  btn.classList.add('selected');
  var catEl = document.getElementById('tk-cat');
  if(catEl) catEl.value = val;
}
function tkCloseModal(){
  document.getElementById('tk-ov').style.display = 'none';
  tkEditGroupId = null;
  tkEditItemId = null;
}
document.getElementById('tk-ov').addEventListener('click', function(e){ if(e.target===this) tkCloseModal(); });




/* ══════════════════════════════════════════
   회원 상세 — 이용권 탭
