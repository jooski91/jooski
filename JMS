function makeBay(bay,idx,kind){
  const div=document.createElement('div');
  const r=bay.startTime?rem(bay.startTime,bay.dur):null;
  let cls='bay ';
  if(bay.status!=='empty'){
    cls+=tCls(bay.type);
    if(r!==null&&r<=5)cls+=' urg-hi';
    else if(r!==null&&r<=10)cls+=' urg-lo';
    // 선택된 타석 강조 (단계1 완료)
    if(movePendingMode&&movePendingMode.idx===idx&&movePendingMode.kind===kind) cls+=' move-source';
    // 이동 중 소스 타석 강조 (단계2)
    if(moveMode&&moveMode.idx===idx&&moveMode.kind===kind) cls+=' move-source';
  }else{
    cls+='empty';
    if(assignMode){
      const okRoom=assignMode.isRoom&&kind==='room';
      const okNormal=!assignMode.isRoom&&kind==='normal';
      if(okRoom||okNormal) cls+=' assign-target';
      else cls+=' assign-dim';
    }
    // 단계2: 이동 가능한 빈 타석 강조 (모든 빈 타석 허용)
    if(moveMode){
      cls+=' move-target';
    }
  }

  let badge='';
  if(lesHL&&kind==='normal'){
    if(lesHL.sug&&lesHL.sug.includes(bay.num)){cls+=' sug-best';badge='<span class="b-sug-badge">✓ 레슨 가능</span>'}
    else if(lesHL.blk&&lesHL.blk.includes(bay.num)){cls+=' sug-blk';badge='<span class="b-blk-badge">✗ 레슨 불가</span>'}
  }
  // Forecast highlight (only when no other highlight)
  if(fcHL&&!badge){
    const bk=(kind==='room'?'r':'n')+bay.num;
    const rm=fcHL.rankMap&&fcHL.rankMap[bk];
    const rankTxt=rm?rm.rank+'번째 · '+esc(rm.name):'';
