    document.addEventListener('mouseup',   onUp);
  }

  function onMove(e){
    if(!_rsz) return;
    var l = lsLessons.find(function(x){ return x.id===_rsz.lessonId; });
    if(!l) return;
    var slotH = _rsz.slotH;
    var slots = Math.round((e.clientY - _rsz.startY) / slotH);
    var startMin = timeToMin(_rsz.origStart);
    var endMin   = Math.max(startMin + SLOT_MIN, Math.min(timeToMin(_rsz.origEnd) + slots * SLOT_MIN, 24*60));
    _rsz.previewEnd = minToTime(endMin);
    // 블록 높이만 시각적으로 변경
    var newH = Math.round(((endMin - startMin)/30) * slotH) - 2;
    _rsz.block.style.height = newH + 'px';
    // 시간 텍스트 업데이트
    var timeEl = _rsz.block.querySelector('.ls-block-time');
    if(timeEl) timeEl.textContent = l.start+'~'+_rsz.previewEnd+(l.bay?' · '+l.bay:'');
  }

  function onUp(){
    if(!_rsz) return;
    var l = lsLessons.find(function(x){ return x.id===_rsz.lessonId; });
    var newEnd = _rsz.previewEnd;
    var origEnd = _rsz.origEnd;
    if(_rsz.block) _rsz.block.style.cursor='';
    _rsz=null;
    document.removeEventListener('mousemove', onMove);
    document.removeEventListener('mouseup',   onUp);
    if(!l || newEnd===origEnd) return;
    if(confirm((l.student||'레슨')+'\n'+l.start+'~'+origEnd+' → '+l.start+'~'+newEnd+'\n\n시간을 변경하시겠습니까?')){
      l.end=newEnd; l.duration=timeToMin(newEnd)-timeToMin(l.start);
      saveState(); lsRender();
      showToast('시간이 변경되었습니다','ok');
    } else {
      lsRender(); // 원복
    }
  }

  function timeToMin(t){ var p=t.split(':'); return +p[0]*60+ +p[1]; }
  function minToTime(m){ return String(Math.floor(m/60)).padStart(2,'0')+':'+String(m%60).padStart(2,'0'); }

  window.lsBindResize = function(block, lessonId){
    var handle = document.createElement('div');
    handle.style.cssText='position:absolute;bottom:0;left:0;right:0;height:6px;cursor:s-resize;background:transparent;z-index:10;border-radius:0 0 3px 3px';
    handle.addEventListener('mousedown', function(e){ startResize(e, lessonId, block); });
    block.style.position='relative';
    block.appendChild(handle);
  };
})();

/* ══════════════════════════════════════════
   기타 스케줄 드래그 + 리사이즈
══════════════════════════════════════════ */
(function(){
  var MOVE_THRESHOLD = 5;
  var _drag = null, _rsz = null, _drop = null;

  function timeToMin(t){ var p=t.split(':'); return +p[0]*60+ +p[1]; }
  function minToTime(m){ return String(Math.floor(m/60)).padStart(2,'0')+':'+String(m%60).padStart(2,'0'); }

  /* ── 드래그 ── */
  function startDrag(e, sid, block){
    e.stopPropagation(); e.preventDefault();
    var s = lsOtherScheds.find(function(x){ return x.id===sid; });
    if(!s) return;
    var rect = block.getBoundingClientRect();
    // 고스트
    var ghost = document.createElement('div');
    ghost.style.cssText='position:fixed;z-index:9998;pointer-events:none;opacity:.7;background:#bdbdbd;border-left:3px solid #999;border-radius:3px;padding:3px 6px;font-size:11px;font-weight:700;color:#333;white-space:nowrap;box-shadow:0 4px 12px rgba(0,0,0,.2)';
    ghost.textContent=(s.memo||'기타 스케줄')+' '+s.start+'~'+s.end;
    ghost.style.width = rect.width+'px';
    ghost.style.height= rect.height+'px';
    document.body.appendChild(ghost);
    block.style.opacity='0.3';
    _drag={ sid:sid, block:block, ghost:ghost,
            ox:e.clientX-rect.left, oy:e.clientY-rect.top,
            startX:e.clientX, startY:e.clientY, dragging:false };
    document.addEventListener('mousemove', onDMove);
    document.addEventListener('mouseup',   onDUp);
  }

  function onDMove(e){
    if(!_drag) return;
    var dx=e.clientX-_drag.startX, dy=e.clientY-_drag.startY;
    if(!_drag.dragging && Math.sqrt(dx*dx+dy*dy)<MOVE_THRESHOLD) return;
    _drag.dragging=true;
    _drag.ghost.style.left=(e.clientX-_drag.ox)+'px';
    _drag.ghost.style.top =(e.clientY-_drag.oy)+'px';
    _drag.ghost.style.display='none';
    if(_drop && _drop._el){ _drop._el.style.background=''; _drop._el.style.outline=''; }
    _drop=null;
    var el=document.elementFromPoint(e.clientX, e.clientY);
    _drag.ghost.style.display='';
    var slot = el ? el.closest('.ls-slot') : null;
    if(slot && slot.dataset.dk && slot.dataset.sl){
      slot.style.background='rgba(80,80,80,.15)';
      slot.style.outline='2px solid #888';
      _drop={dk:slot.dataset.dk, sl:slot.dataset.sl, pn:slot.dataset.pn||'', _el:slot};
    }
  }

  function onDUp(){
    if(!_drag){ return; }
    var d=_drag, dt=_drop;
    d.ghost.remove();
    d.block.style.opacity='';
    if(dt && dt._el){ dt._el.style.background=''; dt._el.style.outline=''; }
    _drag=null; _drop=null;
    document.removeEventListener('mousemove', onDMove);
    document.removeEventListener('mouseup',   onDUp);
    if(!d.dragging || !dt) return;
    var s = lsOtherScheds.find(function(x){ return x.id===d.sid; });
    if(!s) return;
    var dur = timeToMin(s.end)-timeToMin(s.start);
    var newStart=dt.sl, newEnd=minToTime(timeToMin(dt.sl)+dur);
    var newPro=dt.pn||s.pro, newDk=dt.dk;
    if(newDk===s.date && newStart===s.start && newPro===s.pro) return;
    if(confirm((s.memo||'기타 스케줄')+'\n'+s.date+' '+s.start+'~'+s.end+' → '+newDk+' '+newStart+'~'+newEnd+(newPro?' ('+newPro+')':'')+'\n\n이동하시겠습니까?')){
      s.date=newDk; s.start=newStart; s.end=newEnd; s.pro=newPro;
      lsSaveOtherScheds(); lsRender();
      showToast('기타 스케줄이 이동되었습니다','ok');
    }
  }

  /* ── 리사이즈 ── */
  function startResize(e, sid){
    e.stopPropagation(); e.preventDefault();
    var s = lsOtherScheds.find(function(x){ return x.id===sid; });
    if(!s) return;
    // 현재 블록 요소 찾기
    var block = e.target.parentElement;
    var slotH = window.SLOT_H||28;
    _rsz={sid:sid, startY:e.clientY, origEnd:s.end, block:block,
          origH:block.offsetHeight, slotH:slotH, previewEnd:s.end};
    block.style.cursor='s-resize';
    document.addEventListener('mousemove', onRMove);
    document.addEventListener('mouseup',   onRUp);
  }

  function onRMove(e){
    if(!_rsz) return;
    var s = lsOtherScheds.find(function(x){ return x.id===_rsz.sid; });
    if(!s) return;
    var slotH = _rsz.slotH;
    var slots = Math.round((e.clientY-_rsz.startY)/slotH);
    var startMin=timeToMin(s.start);
    var endMin  =Math.max(startMin+30, Math.min(timeToMin(_rsz.origEnd)+slots*30, 24*60));
    _rsz.previewEnd = minToTime(endMin);
    // 블록 높이만 시각적으로 변경 (렌더 없이)
    var newH = ((endMin - startMin)/30) * slotH - 4;
    _rsz.block.style.height = newH + 'px';
    // 시간 텍스트 업데이트
    var timeEl = _rsz.block.querySelector('div:nth-child(2)');
    if(timeEl) timeEl.textContent = s.start+'~'+_rsz.previewEnd;
  }

  function onRUp(){
    if(!_rsz) return;
    var s = lsOtherScheds.find(function(x){ return x.id===_rsz.sid; });
    var newEnd = _rsz.previewEnd;
    var origEnd = _rsz.origEnd;
    if(_rsz.block) _rsz.block.style.cursor='';
    _rsz=null;
    document.removeEventListener('mousemove', onRMove);
    document.removeEventListener('mouseup',   onRUp);
    if(!s || newEnd===origEnd) return;
    if(confirm((s.memo||'기타 스케줄')+'\n'+s.start+'~'+origEnd+' → '+s.start+'~'+newEnd+'\n\n시간을 변경하시겠습니까?')){
      s.end=newEnd;
      lsSaveOtherScheds(); lsRender();
      showToast('시간이 변경되었습니다','ok');
    } else {
      lsRender(); // 원복
    }
  }

  window.lsBindOtherDragResize = function(block, sid){
    block.style.cursor='grab';
    block.style.position='relative';
    block.addEventListener('mousedown', function(e){
      if(e.button!==0) return;
      startDrag(e, sid, block);
    });
    // 리사이즈 핸들
    var handle = document.createElement('div');
    handle.style.cssText='position:absolute;bottom:0;left:0;right:0;height:6px;cursor:s-resize;background:transparent;z-index:10;border-radius:0 0 3px 3px';
    handle.addEventListener('mousedown', function(e){
      e.stopPropagation();
      startResize(e, sid);
    });
    block.appendChild(handle);
  };
})();

