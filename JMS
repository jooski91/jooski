<script>
var _gtaPendingSec = 0;
function gtaTargets(){
  var list = [];
  if(typeof bays !== 'undefined'){
    bays.forEach(function(b){ if(b.startTime && b.status!=='empty') list.push(b); });
  }
  if(typeof rooms !== 'undefined'){
    rooms.forEach(function(r){ if(r.startTime && r.status!=='empty') list.push(r); });
  }
  return list;
}
function gtaFormatSec(sec){
  var sign = sec < 0 ? '-' : (sec > 0 ? '+' : '');
  var abs = Math.abs(sec);
  var m = Math.floor(abs/60);
  var s = abs%60;
  var parts = [];
  if(m>0) parts.push(m+'분');
  if(s>0 || m===0) parts.push(s+'초');
  return sign + parts.join(' ');
}
function gtaUpdateTotalUI(){
  var el = document.getElementById('gta-total-val');
  el.textContent = gtaFormatSec(_gtaPendingSec);
  el.className = 'gta-total-val' + (_gtaPendingSec<0?' neg':(_gtaPendingSec>0?' pos':''));
  document.getElementById('gta-apply-btn').disabled = (_gtaPendingSec === 0);
}
function gtaStage(deltaSec){
  _gtaPendingSec += deltaSec;
  gtaUpdateTotalUI();
}
function gtaManualStep(d){
  var inp = document.getElementById('gta-manual-inp');
  var cur = parseInt(inp.value, 10) || 0;
  inp.value = cur + d;
}
function gtaManualCommit(){
  var inp = document.getElementById('gta-manual-inp');
  var min = parseInt(inp.value, 10) || 0;
  if(min === 0){ showToast('조정할 시간을 입력해주세요','warn'); return; }
  gtaStage(min*60);
  inp.value = '';
}
function gtaReset(){
  _gtaPendingSec = 0;
  document.getElementById('gta-manual-inp').value = '';
  gtaUpdateTotalUI();
}
function openGlobalTimeAdjust(){
  _gtaPendingSec = 0;
  var n = gtaTargets().length;
  document.getElementById('gta-count').textContent = n>0 ? ('현재 적용 대상: '+n+'개 타석') : '현재 이용중인 타석이 없습니다';
  document.getElementById('gta-manual-inp').value = '';
  gtaUpdateTotalUI();
  document.getElementById('gta-ov').classList.add('open');
}
function closeGlobalTimeAdjust(){
  document.getElementById('gta-ov').classList.remove('open');
}
function gtaApply(){
  if(_gtaPendingSec === 0) return;
  var targets = gtaTargets();
  if(!targets.length){ showToast('이용중인 타석이 없습니다','warn'); return; }
  var deltaMin = _gtaPendingSec/60;
  targets.forEach(function(t){
    var newDur = (t.dur||0) + deltaMin;
    t.dur = newDur > (1/60) ? newDur : (1/60);
  });
  if(typeof saveState === 'function') saveState();
  if(typeof renderBays === 'function') renderBays();
  showToast(gtaFormatSec(_gtaPendingSec)+' · '+targets.length+'개 타석에 동시 적용됨','ok');
  _gtaPendingSec = 0;
  gtaUpdateTotalUI();
  closeGlobalTimeAdjust();
}
</script>
