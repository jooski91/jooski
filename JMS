function mbdSaleEditCalc(){
  var price    = parseFloat(document.getElementById('mse-price').value)||0;
  var discount = parseFloat(document.getElementById('mse-discount').value)||0;
  var point    = parseFloat(document.getElementById('mse-point').value)||0;
  var salePrice = Math.max(0, price - discount);
  var payAmt    = Math.max(0, salePrice - point);
  // 복합결제 합산
  var card     = parseFloat(document.getElementById('mse-pay-card').value)||0;
  var cash     = parseFloat(document.getElementById('mse-pay-cash').value)||0;
  var transfer = parseFloat(document.getElementById('mse-pay-transfer').value)||0;
  var paidTotal = card + cash + transfer;
  // hidden paymethod 업데이트
  var parts = [];
  if(card)     parts.push('카드 '+card);
  if(cash)     parts.push('현금 '+cash);
  if(transfer) parts.push('이체 '+transfer);
  document.getElementById('mse-paymethod').value = parts.join('+');
  var unpaid = paidTotal > 0 ? Math.max(0, payAmt - paidTotal) : payAmt;
  document.getElementById('mse-summary').style.display = 'block';
  document.getElementById('mse-saleprice-lbl').textContent = salePrice.toLocaleString()+'원';
  document.getElementById('mse-payamt-lbl').textContent    = payAmt.toLocaleString()+'원';
  // 복합결제 상세
  var splitEl = document.getElementById('mse-split-detail');
  if(splitEl){
    if(parts.length > 0){
      var splitStr = parts.map(function(p){ var m=p.match(/^(.+?)\s+([0-9]+)$/); return m?m[1]+' '+parseInt(m[2]).toLocaleString()+'원':p; }).join(' + ');
      splitEl.innerHTML = '( '+splitStr+' ) &nbsp;·&nbsp; ';
    } else {
      splitEl.textContent = '';
    }
  }
  document.getElementById('mse-unpaid-lbl').textContent = unpaid.toLocaleString()+'원';
  document.getElementById('mse-unpaid-lbl').style.color = unpaid > 0 ? '#c03030' : '#16a34a';
}

