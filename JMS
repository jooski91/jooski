function mbdConfirmAddTicket(){
  if(!_mbdSelGroupId || !_mbdSelItemId){ alert('이용권을 선택해주세요.'); return; }
  var startDate = document.getElementById('mbd-tk-startdate').value;
  if(!startDate){ alert('시작일을 입력해주세요.'); return; }
  var saleDate = document.getElementById('mbd-tk-saledate').value;
  if(!saleDate){ alert('판매일을 입력해주세요.'); return; }
  var pro = document.getElementById('mbd-tk-pro').value;
  var selG = tkGroups.find(function(x){ return +x.id===+_mbdSelGroupId; });
  var selIt = tkItems.find(function(x){ return +x.id===+_mbdSelItemId; });
  var tkName = (selG && selIt) ? selG.name+' / '+selIt.name : '이용권';
  var isLesson = selG && selG.cat !== '연습장-횟수' && selG.cat !== '연습장-기간';
  if(isLesson && !pro){ alert('담당 프로를 선택해주세요.'); return; }
  var m = members.find(function(x){ return x.id === mbDetailId; });
  if(!m){ alert('회원 정보를 찾을 수 없습니다.'); return; }
  if(!m.tickets) m.tickets = [];
  if(!m.sales) m.sales = [];

  var endDate     = document.getElementById('mbd-tk-enddate').value;
  var payMethod   = document.getElementById('mbd-tk-pay').value; // "카드 100000원+현금 50000원" 형태
  var priceVal    = parseFloat(document.getElementById('mbd-tk-price').value)||0;
  var discountVal = parseFloat(document.getElementById('mbd-tk-discount').value)||0;
  var pointVal    = parseFloat(document.getElementById('mbd-tk-point').value)||0;
  var salePrice   = Math.max(0, priceVal - discountVal);
  var payAmount   = Math.max(0, salePrice - pointVal);
  // 복합결제 합산
  var cardAmt     = parseFloat(document.getElementById('mbd-pay-card').value)||0;
  var cashAmt     = parseFloat(document.getElementById('mbd-pay-cash').value)||0;
  var transferAmt = parseFloat(document.getElementById('mbd-pay-transfer').value)||0;
  var paidTotal   = cardAmt + cashAmt + transferAmt;
  var unpaid      = (paidTotal === 0) ? payAmount : Math.max(0, payAmount - paidTotal);
  var saleStatus  = unpaid > 0 ? '미수금' : '결제완료';
  var completedAt = unpaid === 0 ? Date.now() : null;

  var ticketId = Date.now();
  m.tickets.push({
    id: ticketId,
    groupId:   _mbdSelGroupId,
    itemId:    _mbdSelItemId,
    startDate: startDate,
    endDate:   endDate || '',
    pro:       pro,
    addedAt:   ticketId
  });

  m.sales.push({
    ticketId:    ticketId,
    groupId:     _mbdSelGroupId,
    itemId:      _mbdSelItemId,
    pro:         pro,
    branch:      m.branch || '동대구센터',
    saleDate:    saleDate,
    saleStatus:  saleStatus,
    listPrice:   priceVal,
    discount:    discountVal,
    pointUsed:   pointVal,
    salePrice:   salePrice,
    payAmount:   payAmount,
    unpaid:      unpaid,
    payMethod:   payMethod || '',
    payCard:     cardAmt || 0,
    payCash:     cashAmt || 0,
    payTransfer: transferAmt || 0,
    completedAt: completedAt,
    createdAt:   Date.now()
  });

  saveState();
  mbdCloseAddTicket();
  mbdRenderTickets();
  mbdRenderSales();
  // 변경내역 기록
  tkChangeLogPush(mbDetailId, '이용권결제', tkName,
    '결제금액 '+payAmount.toLocaleString()+'원'+(unpaid>0?' (미수금 '+unpaid.toLocaleString()+'원)':''),
    '결제: '+(payMethod||'미지정')+(saleDate?' · 판매일 '+saleDate:''));
  // 포인트 2% 적립 (결제완료인 경우에만)
  if(saleStatus === '결제완료' && payAmount > 0){
    var earnedPoints = Math.floor(payAmount * 0.02);
    if(earnedPoints > 0){
      if(!m.points) m.points = 0;
      m.points += earnedPoints;
      if(!m.pointHistory) m.pointHistory = [];
      m.pointHistory.push({
        type: 'earn',
        amount: earnedPoints,
        reason: '이용권 결제 2% 적립 ('+tkName+')',
        balanceAfter: m.points,
        createdAt: Date.now()
      });
      saveState();
      mbdRenderHome();
      showToast('이용권 판매 완료 · 포인트 '+earnedPoints+'P 적립', 'ok');
    } else {
      showToast('이용권 판매 완료', 'ok');
    }
  } else {
    showToast('이용권 판매 완료', 'ok');
  }
}

function mbdGoToTicketDetail(ticketIdx){
  var m = members.find(function(x){ return x.id === mbDetailId; });
  if(!m || !m.tickets || !m.tickets[ticketIdx]) return;
  _mbdDetailTicketIdx = Number(ticketIdx);
  var tk = m.tickets[ticketIdx];
  var g  = tkGroups.find(function(x){ return +x.id === +tk.groupId; });
  var it = tkItems.find(function(x){ return +x.id === +tk.itemId; });
  var meta = g ? tkCatMeta(g.cat) : null;

  // 제목
  document.getElementById('mbd-td-title').textContent = (g && it) ? g.name + ' / ' + it.name : (it ? it.name : '—');
  document.getElementById('mbd-td-type').textContent  = meta ? meta.lbl : '';

  // 필드 채우기
  document.getElementById('mbd-td-startdate').value = tk.startDate || '';
  document.getElementById('mbd-td-enddate').value = tk.endDate || '';
  // 저장된 endDate 없으면 자동 계산
  if(!tk.endDate) mbdTdCalcEnd();
  // 결제방법 복원 (sales 레코드에서)
  var payMethod = '';
  if(m && m.sales && tk.id){
    var saleRec = m.sales.find(function(s){ return s.ticketId === tk.id; });
    if(saleRec) payMethod = saleRec.payMethod || '';
  }
  document.getElementById('mbd-td-pay').value = payMethod;
  document.getElementById('mbd-td-pro').value = tk.pro || '';

  // 결제 내역 표시 (읽기 전용)
  var payInfoEl = document.getElementById('mbd-td-pay-info');
  var payDetailEl = document.getElementById('mbd-td-pay-detail');
  if(payInfoEl && payDetailEl){
    if(saleRec){
      var pdLines = [];
      var pm = saleRec.payMethod || '';
      if(pm){
        // 복합결제 파싱
        var pmParts = pm.split('+');
        pmParts.forEach(function(p){
          p = p.trim();
          var match = p.match(/^(카드|현금|이체)\s*([\d,]+)/);
          if(match){
            var amt = parseInt(match[2].replace(/,/g,''), 10);
            pdLines.push(match[1]+' <strong>'+amt.toLocaleString()+'원</strong>');
          } else if(p === '카드'||p === '현금'||p === '이체') pdLines.push(p);
        });
      }
      if(saleRec.payAmount) pdLines.push('결제금액 <strong>'+Number(saleRec.payAmount).toLocaleString()+'원</strong>');
      if(saleRec.unpaid > 0) pdLines.push('<span style="color:#dc2626">미수금 '+Number(saleRec.unpaid).toLocaleString()+'원</span>');
      payDetailEl.innerHTML = pdLines.length ? pdLines.join(' &nbsp;·&nbsp; ') : '결제 정보 없음';
      payInfoEl.style.display = 'block';
    } else {
      payInfoEl.style.display = 'none';
    }
  }

  // 담당 프로 select 채우기
  var proSel = document.getElementById('mbd-td-pro');
  proSel.innerHTML = '<option value="">없음</option>';
  lsPros.forEach(function(p){
    var o = document.createElement('option');
    o.value = p.name; o.textContent = p.name;
    if(p.name === tk.pro) o.selected = true;
    proSel.appendChild(o);
  });

  // 연습장 이용권이면 담당프로 숨기기
  var proRow2 = document.getElementById('mbd-td-pro-row');
  if(g && (g.cat==='연습장-횟수'||g.cat==='연습장-기간')){
    if(proRow2) proRow2.style.display='none';
  } else {
    if(proRow2) proRow2.style.display='block';
  }

  // 이용권 정보 요약
  var parts = [];
  if(it){
    if(it.count) parts.push(it.count+'회');
    if(it.days)  parts.push(it.days+'일');
    if(it.validDays) parts.push('유효 '+it.validDays+'일');
    if(it.price) parts.push(Number(it.price).toLocaleString()+'원');
  }
  document.getElementById('mbd-td-info').textContent = parts.join(' · ') || '—';

  document.getElementById('mbd-ticket-detail-ov').style.display = 'flex';
}

