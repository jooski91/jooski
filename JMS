function runForecastCalc(){
  if(!waiting.length){fcHL=null;return[];}

  const now=N();
  const pool=[];
  bays.forEach(b=>{
    if(b.status==='empty'&&!b.mark) pool.push({key:'n'+b.num,kind:'normal',num:b.num,availAt:0,endMin:0,zn:zone(b.num)});
    else if(b.status!=='empty'&&b.startTime){
      const endMs=b.startTime+b.dur*60000;
      const endMin=Math.max(0,Math.ceil((endMs-now)/60000));
      pool.push({key:'n'+b.num,kind:'normal',num:b.num,availAt:endMs,endMin,zn:zone(b.num),curType:b.type});
    }
  });
  rooms.forEach(r=>{
    if(r.status==='empty'&&!r.mark) pool.push({key:'r'+r.num,kind:'room',num:r.num,availAt:0,endMin:0,zn:null});
    else if(r.status!=='empty'&&r.startTime){
      const endMs=r.startTime+r.dur*60000;
      const endMin=Math.max(0,Math.ceil((endMs-now)/60000));
      pool.push({key:'r'+r.num,kind:'room',num:r.num,availAt:endMs,endMin,zn:null,curType:r.type});
    }
  });
  pool.sort((a,b)=>a.availAt-b.availAt);

  const usedKeys=new Set();
  const zoneLessonTime={};
  const results=[];

  // 룸레슨 대기자 수만큼 룸 슬롯 예약
  const roomLessonCount=waiting.filter(w=>w.type==='룸레슨').length;
  const hasRoomLesson=roomLessonCount>0;
  const roomPool=pool.filter(s=>s.kind==='room').slice(0,roomLessonCount);
  const reservedRoomKeys=new Set(roomPool.map(s=>s.key));

  waiting.forEach(w=>{
    const isRoom=w.type==='룸레슨';
    const isLesson=w.type==='레슨';

    let candidates=pool.filter(s=>{
      if(usedKeys.has(s.key))return false;
      if(isRoom) return s.kind==='room';
      if(w.type==='시설이용') return s.kind==='normal';
      // 레슨: 일반타석 우선 후보
      // 룸레슨 대기자가 없으면 룸도 사용 가능, 있으면 예약된 룸 제외
      return s.kind==='normal'||(s.kind==='room'&&(!hasRoomLesson||!reservedRoomKeys.has(s.key)));
    });

    if(isLesson){
      // 일반타석 중 구역 레슨 간격 필터
      const normalCands=candidates.filter(s=>{
        if(s.kind==='room')return false;
        const z=s.zn;
        if(!zoneLessonTime[z])return true;
        return s.availAt>=zoneLessonTime[z];
      });
      // 일반타석 후보가 있으면 일반 우선, 없으면 룸(룸레슨 대기자 없는 경우)
      if(normalCands.length){
        candidates=normalCands;
      } else {
        candidates=candidates.filter(s=>s.kind==='room');
      }
    }

    if(!candidates.length){
      results.push({w,bayKey:null,endMin:null,note:'배치 불가'});
      return;
    }

    const pick=candidates[0];
    usedKeys.add(pick.key);

    if(isLesson&&pick.kind==='normal'&&pick.zn){
      zoneLessonTime[pick.zn]=pick.availAt+SD*60000;
    }

    results.push({w,bayKey:pick.key,endMin:pick.endMin,availAt:pick.availAt,zn:pick.zn,kind:pick.kind,num:pick.num});
  });

  const assignedKeys=results.filter(r=>r.bayKey).map(r=>r.bayKey);
  const soonKeys=results.filter(r=>r.bayKey&&r.endMin>0&&r.endMin<=15).map(r=>r.bayKey);
  const rankMap={};
  results.forEach((r,i)=>{if(r.bayKey)rankMap[r.bayKey]={rank:i+1,name:r.w.name,type:r.w.type};});
  fcHL={assigned:assignedKeys,soon:soonKeys,rankMap};
  return results;
}

function renderForecastResult(results,targetId){
