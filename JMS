<script>
/* ══════════════════════════════════════════
   이용권 변경내역 로그 (tkChangeLog)
══════════════════════════════════════════ */

/* ─ 타입별 색상·아이콘 ─ */
var TK_LOG_META = {
  '이용권결제': { icon:'💳', bg:'#eff6ff', color:'#1d4ed8', border:'#bfdbfe' },
  '미수금결제': { icon:'💰', bg:'#f0fdf4', color:'#15803d', border:'#bbf7d0' },
  '판매취소':   { icon:'🚫', bg:'#fff7ed', color:'#c2410c', border:'#fed7aa' },
  '출석':       { icon:'✅', bg:'#f0fdf4', color:'#15803d', border:'#bbf7d0' },
  '결석':       { icon:'❌', bg:'#fff1f2', color:'#be123c', border:'#fecdd3' },
  '횟수변경':   { icon:'🔢', bg:'#faf5ff', color:'#7e22ce', border:'#e9d5ff' },
  '중지':       { icon:'⏸', bg:'#fff7ed', color:'#b45309', border:'#fde68a' },
  '중지해제':   { icon:'▶️', bg:'#f0fdf4', color:'#15803d', border:'#bbf7d0' },
  '환불':       { icon:'↩️', bg:'#fff1f2', color:'#be123c', border:'#fecdd3' },
  '환불취소':   { icon:'↪️', bg:'#eff6ff', color:'#1d4ed8', border:'#bfdbfe' },
  '기간변경':   { icon:'📅', bg:'#f0f9ff', color:'#0369a1', border:'#bae6fd' },
};
function tkLogMeta(type){ return TK_LOG_META[type] || { icon:'📋', bg:'#f8fafc', color:'#475569', border:'#e2e8f0' }; }

/* ─ 로그 추가 ─ */
function tkChangeLogPush(memberId, type, tkName, detail, extra){
  var m = members.find(function(x){ return x.id===memberId; });
  if(!m) return;
  if(!m.tkChangeLogs) m.tkChangeLogs = [];
  m.tkChangeLogs.unshift({
    id: Date.now()+'_'+Math.random().toString(36).slice(2,5),
    type: type,
    tkName: tkName || '',
    detail: detail || '',
    extra: extra || '',
    at: Date.now()
  });
  saveState();
}

/* ─ 이용권명 헬퍼 ─ */
function tkLogName(tk){
  if(!tk) return '이용권';
  var g = tkGroups.find(function(x){ return +x.id===+tk.groupId; });
  var it = tkItems.find(function(x){ return +x.id===+tk.itemId; });
  return (g&&it) ? g.name+' / '+it.name : (it ? it.name : '이용권');
}
function tkLogNameById(gid, iid){
  var g = tkGroups.find(function(x){ return +x.id===+gid; });
  var it = tkItems.find(function(x){ return +x.id===+iid; });
  return (g&&it) ? g.name+' / '+it.name : '이용권';
}

/* ─ 렌더 ─ */
function tkChangeLogRender(){
  var m = members.find(function(x){ return x.id===mbDetailId; });
  var el = document.getElementById('mbd-changelog-list');
  if(!el) return;
  if(!m){ el.innerHTML='<div class="mbd-empty-tab"><div class="mbd-empty-icon">📋</div>변경 내역이 없습니다</div>'; return; }

  // 이용권 필터 옵션 채우기
  var tkSel = document.getElementById('tklog-filter-tk');
  if(tkSel){
    var curTkVal = tkSel.value;
    var tkNames = [...new Set((m.tkChangeLogs||[]).map(function(l){ return l.tkName; }).filter(Boolean))];
    var tkOpts = '<option value="">전체 이용권</option>' + tkNames.map(function(n){ return '<option value="'+esc(n)+'"'+(curTkVal===n?' selected':'')+'>'+esc(n)+'</option>'; }).join('');
    tkSel.innerHTML = tkOpts;
  }

  var typeFilter = (document.getElementById('tklog-filter-type')||{}).value||'';
  var tkFilter   = (document.getElementById('tklog-filter-tk')||{}).value||'';
  var logs = (m.tkChangeLogs||[]).filter(function(l){
    if(typeFilter && l.type !== typeFilter) return false;
    if(tkFilter && l.tkName !== tkFilter) return false;
    return true;
  });

  if(!logs.length){
    el.innerHTML='<div class="mbd-empty-tab"><div class="mbd-empty-icon">📋</div>'+(typeFilter||tkFilter?'조건에 맞는 내역이 없습니다':'변경 내역이 없습니다')+'</div>';
    return;
  }

  var html = logs.map(function(log){
    var meta = tkLogMeta(log.type);
    var dt = new Date(log.at);
    var dateStr = dt.getFullYear()+'-'+String(dt.getMonth()+1).padStart(2,'0')+'-'+String(dt.getDate()).padStart(2,'0');
    var timeStr = String(dt.getHours()).padStart(2,'0')+':'+String(dt.getMinutes()).padStart(2,'0');
    return '<div style="display:flex;align-items:flex-start;gap:10px;padding:10px 12px;border:1px solid '+meta.border+';border-radius:10px;background:'+meta.bg+';margin-bottom:7px">'+
      '<div style="font-size:18px;line-height:1;flex-shrink:0;margin-top:1px">'+meta.icon+'</div>'+
      '<div style="flex:1;min-width:0">'+
        '<div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:3px">'+
          '<span style="font-size:11px;font-weight:800;padding:2px 8px;border-radius:5px;background:'+meta.border+';color:'+meta.color+'">'+esc(log.type)+'</span>'+
          (log.tkName ? '<span style="font-size:11px;font-weight:700;color:#555">'+esc(log.tkName)+'</span>' : '')+
        '</div>'+
        (log.detail ? '<div style="font-size:12px;color:#333;font-weight:600;margin-bottom:2px">'+esc(log.detail)+'</div>' : '')+
        (log.extra  ? '<div style="font-size:11px;color:#888">'+esc(log.extra)+'</div>' : '')+
      '</div>'+
      '<div style="font-size:10px;color:#aaa;white-space:nowrap;flex-shrink:0;text-align:right;line-height:1.6">'+
        '<div>'+dateStr+'</div><div>'+timeStr+'</div>'+
      '</div>'+
    '</div>';
  }).join('');
  el.innerHTML = html;
}

/* ─ 전체 삭제 ─ */
function tkChangeLogClear(){
  var m = members.find(function(x){ return x.id===mbDetailId; });
  if(!m||!m.tkChangeLogs||!m.tkChangeLogs.length){ showToast('삭제할 내역이 없습니다','warn'); return; }
  if(!confirm('변경내역을 모두 삭제하시겠습니까?')) return;
  m.tkChangeLogs = [];
  saveState();
  tkChangeLogRender();
}

/* ─ mbdTab 확장: 변경내역 탭 열릴 때 렌더 ─ */
var _origMbdTab = (typeof mbdTab === 'function') ? mbdTab : null;
(function(){
  var _orig = mbdTab;
  mbdTab = function(btn, paneId){
    _orig(btn, paneId);
    if(paneId === 'mbd-pane-change') tkChangeLogRender();
  };
})();
</script>

<script>
/* ══════════════════════════════════════════
   연습기록 (Practice Log) 관리
══════════════════════════════════════════ */
var _pracLogs = [];

/* localStorage 키 */
var PRACLOG_KEY = 'tdf_pracLogs';

/* 초기 로드 */
(function praclogInit(){
  try{
    var s = localStorage.getItem(PRACLOG_KEY);
    if(s) _pracLogs = JSON.parse(s);
  }catch(e){ _pracLogs=[]; }
})();

function praclogSave(){
  try{ localStorage.setItem(PRACLOG_KEY, JSON.stringify(_pracLogs)); }catch(e){}
}

/* 새 기록 추가 */
function praclogPush(rec){
  rec.id = Date.now() + '_' + Math.random().toString(36).slice(2,6);
  _pracLogs.unshift(rec);
  praclogSave();
}

/* 렌더 */
function praclogRender(){
  var filterDate = (document.getElementById('praclog-filter-date')||{}).value||'';
  var filterName = ((document.getElementById('praclog-filter-name')||{}).value||'').trim();
  var list = _pracLogs.filter(function(r){
    if(filterDate && r.date !== filterDate) return false;
    if(filterName && r.name.indexOf(filterName)<0) return false;
    return true;
  });

  var countEl = document.getElementById('praclog-count-badge');
  if(countEl) countEl.textContent = list.length+'건';

  var body = document.getElementById('praclog-table-body');
  if(!body) return;

  if(!list.length){
    body.innerHTML='<div style="text-align:center;padding:32px;color:#bbb;font-size:13px"><div style="font-size:28px;margin-bottom:8px">📋</div>'+(filterDate||filterName?'조건에 맞는 기록이 없습니다':'연습기록이 없습니다')+'</div>';
    return;
  }

  var todayStr = new Date().toISOString().slice(0,10);
  var today = todayStr;
  var html = list.map(function(r, i){
    var isToday = r.date === today;
    var rowBg = i%2===0 ? '#fff' : '#fafbfc';
    if(isToday) rowBg = '#f0f7ff';
    var bayColor = r.bayKind==='room' ? '#8878c8' : '#1a5fa0';
    var bayBg    = r.bayKind==='room' ? '#f0eeff' : '#e8f0fa';
    // 이용시간 계산
    var durMin = r.startMs && r.endMs ? Math.round((r.endMs-r.startMs)/60000) : null;
    var durStr = durMin!=null ? durMin+'분' : '';

    // 전화번호 마스킹 (가운데 4자리 *)
    var phoneMasked = r.phone ? r.phone.replace(/(\d{3})-(\d{3,4})-(\d{4})/, function(_,a,b,c){ return a+'-'+b.replace(/./g,'*')+'-'+c; }) : '—';

    return '<div style="display:grid;grid-template-columns:80px 90px 1fr 120px 100px 90px 80px;background:'+rowBg+';border-bottom:1px solid #edf2f7;align-items:center;transition:background .1s" onmouseover="this.style.background=\'#e8f4ff\'" onmouseout="this.style.background=\''+rowBg+'\'">'+
      '<div style="padding:11px 16px"><span style="font-size:11px;font-weight:800;padding:3px 7px;border-radius:6px;background:'+bayBg+';color:'+bayColor+'">'+esc(r.bayLabel)+'</span></div>'+
      '<div style="padding:11px 14px;font-size:11px;color:#555;font-weight:600">'+esc(r.date ? r.date.slice(5).replace('-','/') : '—')+(isToday?'<span style="font-size:9px;font-weight:800;color:#1a5fa0;background:#dbeafe;padding:1px 4px;border-radius:3px;margin-left:4px">오늘</span>':'')+'</div>'+
      '<div style="padding:11px 14px">'+
        '<div style="font-size:13px;font-weight:700;color:#111">'+esc(r.name||'—')+'</div>'+
        (durStr?'<div style="font-size:10px;color:#94a3b8;margin-top:1px">⏱ '+durStr+'</div>':'')+
      '</div>'+
      '<div style="padding:11px 14px;font-size:11px;color:#666;font-family:monospace;letter-spacing:.3px">'+esc(phoneMasked)+'</div>'+
      '<div style="padding:11px 14px;font-size:11px;color:#666">'+esc(r.mbNum||'—')+'</div>'+
      '<div style="padding:11px 14px;font-size:12px;font-weight:700;color:#555;font-family:monospace">'+esc(r.startStr||'—')+'</div>'+
      '<div style="padding:11px 14px;font-size:12px;font-weight:700;color:#c03030;font-family:monospace">'+esc(r.endStr||'—')+'</div>'+
    '</div>';
  }).join('');
  body.innerHTML = html;
}

/* 전체 삭제 */
function praclogClearAll(){
  var filterDate = (document.getElementById('praclog-filter-date')||{}).value||'';
  var filterName = ((document.getElementById('praclog-filter-name')||{}).value||'').trim();
  var msg = filterDate||filterName ? '현재 필터에 해당하는 기록을 모두 삭제하시겠습니까?' : '연습기록 전체를 삭제하시겠습니까? 복구가 불가합니다.';
  if(!confirm(msg)) return;
  if(filterDate||filterName){
    _pracLogs = _pracLogs.filter(function(r){
      if(filterDate && r.date!==filterDate) return true;
      if(filterName && r.name.indexOf(filterName)<0) return true;
      return false;
    });
  } else {
    _pracLogs = [];
  }
  praclogSave();
  praclogRender();
}
</script>

<script>
/* ══════════════════════════════════════════
   이용권 중지 모달 로직
══════════════════════════════════════════ */
var _suspMemberId   = null;
var _suspTicketIdx  = null;
var _suspMode       = 'new';   // 'new' | 'edit'
var _suspEditLogIdx = null;
var _suspCalYear    = 0;
var _suspCalMonth   = 0;
var _suspCalStart   = null;   // 'YYYY-MM-DD'
var _suspCalEnd     = null;   // 'YYYY-MM-DD'
var _suspCalStep    = 0;      // 0=시작선택 1=종료선택
var _suspDaysVal    = 0;
var _suspTab        = 'cal';
var _suspReleaseLogIdx = null;

/* ─ 유틸 ─ */
function suspDateAdd(ymd, days){
  var d = new Date(ymd+'T00:00:00');
  d.setDate(d.getDate()+days);
  return d.toISOString().slice(0,10);
}
function suspDateDiff(a,b){
  var da=new Date(a+'T00:00:00'), db=new Date(b+'T00:00:00');
  return Math.round((db-da)/(1000*60*60*24));
}
function suspFmtDate(ymd){
  if(!ymd) return '—';
  var p=ymd.split('-');
  return p[0]+'년 '+parseInt(p[1])+'월 '+parseInt(p[2])+'일';
}
function suspToday(){
  return new Date().toISOString().slice(0,10);
}

/* ─ 모달 열기 ─ */
function openSuspendModal(memberId, ticketIdx){
  _suspMemberId  = memberId;
  _suspTicketIdx = ticketIdx;
  _suspMode      = 'new';
  _suspCalStart  = null;
  _suspCalEnd    = null;
  _suspCalStep   = 0;
  _suspDaysVal   = 0;
  _suspTab       = 'cal';

  var m  = members.find(function(x){ return x.id === memberId; });
  var tk = m && m.tickets && m.tickets[ticketIdx];
  if(!tk){ showToast('이용권을 찾을 수 없습니다','warn'); return; }

  // 이미 활성 중지 중이면 중지 이력 보여주되 새 등록 탭을 disabled 처리
  var g  = tkGroups.find(function(x){ return +x.id===+tk.groupId; });
  var it = tkItems.find(function(x){ return +x.id===+tk.itemId; });
  var tname = (g&&it) ? g.name+' / '+it.name : (it ? it.name : '이용권');
  document.getElementById('susp-tk-name').textContent = tname;
  var period = (tk.startDate||'—') + ' ~ ' + (tk.endDate||'—');
  document.getElementById('susp-tk-period').textContent = '기간: '+period;

  // 달력 초기화 (오늘 기준)
  var td = new Date();
  _suspCalYear  = td.getFullYear();
  _suspCalMonth = td.getMonth();
  suspRenderCal();

  // 일수 초기화
  document.querySelectorAll('.susp-days-opt').forEach(function(b){ b.classList.remove('selected'); });
  document.getElementById('susp-days-custom-inp').value='';
  document.getElementById('susp-days-result').style.display='none';
  document.getElementById('susp-memo').value = '';

  // 탭 초기화
  suspSwitchTab('cal');

  // 이력 렌더
  suspRenderLog();

  // 현재 중지 상태면 제출버튼 텍스트 변경
  var activeSusp = (tk.pauseLogs||[]).find(function(l){ return l.active; });
  var btn = document.getElementById('susp-submit-btn');
  if(activeSusp){
    btn.textContent = '중지 추가 등록';
  } else {
    btn.textContent = '중지 적용';
  }

  document.getElementById('susp-ov').classList.add('open');
}

/* ─ 모달 닫기 ─ */
function suspClose(){
  document.getElementById('susp-ov').classList.remove('open');
}

/* ─ 탭 전환 ─ */
function suspSwitchTab(tab){
  _suspTab = tab;
  document.querySelectorAll('.susp-tab').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.susp-tab-pane').forEach(function(p){ p.classList.remove('active'); });
  document.getElementById('susp-tab-'+tab).classList.add('active');
  document.getElementById('susp-pane-'+tab).classList.add('active');
}

/* ─ 달력 렌더 ─ */
function suspRenderCal(){
  var monthNames=['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
  document.getElementById('susp-cal-month').textContent = _suspCalYear+'년 '+monthNames[_suspCalMonth];
  var today = suspToday();
  var firstDay = new Date(_suspCalYear, _suspCalMonth, 1).getDay();
  var daysInMonth = new Date(_suspCalYear, _suspCalMonth+1, 0).getDate();
  var grid = document.getElementById('susp-cal-grid');
  var html = '';
  for(var i=0;i<firstDay;i++) html+='<div class="susp-cal-day other"></div>';
  for(var d=1;d<=daysInMonth;d++){
    var ymd = _suspCalYear+'-'+String(_suspCalMonth+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    var cls = 'susp-cal-day';
    if(ymd < today) cls += ' past';
    if(ymd === today) cls += ' today';
    if(_suspCalStart && _suspCalEnd){
      if(ymd===_suspCalStart) cls += ' range-start';
      else if(ymd===_suspCalEnd) cls += ' range-end';
      else if(ymd>_suspCalStart && ymd<_suspCalEnd) cls += ' in-range';
    } else if(_suspCalStart && ymd===_suspCalStart){
      cls += ' selected';
    }
    html += '<div class="'+cls+'" onclick="suspCalClick(\''+ymd+'\')">'+d+'</div>';
  }
  grid.innerHTML = html;
  // 결과 업데이트
  suspUpdateCalResult();
}
function suspCalMove(dir){
  _suspCalMonth += dir;
  if(_suspCalMonth<0){ _suspCalMonth=11; _suspCalYear--; }
  if(_suspCalMonth>11){ _suspCalMonth=0; _suspCalYear++; }
  suspRenderCal();
}
function suspCalClick(ymd){
  var today = suspToday();
  if(ymd < today) return; // 과거 클릭 방지
  if(_suspCalStep===0 || (_suspCalStart && _suspCalEnd)){
    _suspCalStart = ymd; _suspCalEnd = null; _suspCalStep = 1;
  } else {
    if(ymd < _suspCalStart){ _suspCalEnd = _suspCalStart; _suspCalStart = ymd; }
    else if(ymd === _suspCalStart){ _suspCalEnd = null; _suspCalStep = 0; }
    else { _suspCalEnd = ymd; _suspCalStep = 0; }
  }
  suspRenderCal();
}
function suspCalClear(){
  _suspCalStart = null; _suspCalEnd = null; _suspCalStep = 0;
  suspRenderCal();
  document.getElementById('susp-cal-result').style.display='none';
}
function suspUpdateCalResult(){
  var el = document.getElementById('susp-cal-result');
  var txt = document.getElementById('susp-cal-result-text');
  if(_suspCalStart){
    var msg = '📅 ' + suspFmtDate(_suspCalStart);
    if(_suspCalEnd){ msg += ' ~ ' + suspFmtDate(_suspCalEnd); var days=suspDateDiff(_suspCalStart,_suspCalEnd); msg+=' ('+days+'일)'; }
    else { msg += ' (종료일 선택 또는 당일 다시 클릭 시 단일일)'; }
    txt.textContent = msg;
    el.style.display='flex';
  } else {
    el.style.display='none';
  }
}

/* ─ 일수 선택 ─ */
function suspDaysSel(days){
  document.querySelectorAll('.susp-days-opt').forEach(function(b){ b.classList.remove('selected'); });
  var btn = document.querySelector('.susp-days-opt[data-days="'+days+'"]');
  if(btn) btn.classList.add('selected');
  if(days===0){
    document.getElementById('susp-days-custom-wrap').style.display='flex';
    document.getElementById('susp-days-custom-inp').focus();
    _suspDaysVal = 0;
    document.getElementById('susp-days-result').style.display='none';
  } else {
    document.getElementById('susp-days-custom-wrap').style.display='none';
    document.getElementById('susp-days-custom-inp').value='';
    _suspDaysVal = days;
    suspUpdateDaysResult(days);
  }
}
function suspDaysCustomInput(){
  var v = parseInt(document.getElementById('susp-days-custom-inp').value,10);
  if(v>0){ _suspDaysVal=v; suspUpdateDaysResult(v); }
  else { _suspDaysVal=0; document.getElementById('susp-days-result').style.display='none'; }
}
function suspUpdateDaysResult(days){
  var start = suspToday();
  var end   = suspDateAdd(start, days-1);
  var el    = document.getElementById('susp-days-result');
  el.textContent = '📅 '+suspFmtDate(start)+' ~ '+suspFmtDate(end)+' ('+days+'일)';
  el.style.display='block';
}

/* ─ 이력 렌더 ─ */
function suspRenderLog(){
  var m  = members.find(function(x){ return x.id===_suspMemberId; });
  var tk = m && m.tickets && m.tickets[_suspTicketIdx];
  var el = document.getElementById('susp-log-list');
  if(!tk){ el.innerHTML='<div class="susp-log-empty">정보 없음</div>'; return; }
  var logs = tk.pauseLogs || [];
  if(!logs.length){ el.innerHTML='<div class="susp-log-empty">중지 이력이 없습니다</div>'; return; }
  var html = '';
  logs.slice().reverse().forEach(function(log, ri){
    var realIdx = logs.length-1-ri;
    var isActive = log.active;
    var dot = isActive ? 'active' : 'done';
    var badge = isActive ? '<span class="susp-log-badge active">중지중</span>' : '<span class="susp-log-badge done">해제완료</span>';
    var period = suspFmtDate(log.start) + (log.end ? ' ~ '+suspFmtDate(log.end) : ' (종료일 미정)');
    var days = log.end ? suspDateDiff(log.start,log.end)+'일' : '—';
    var detail = days + (log.memo ? '  |  '+log.memo : '');
    var actions = '<div class="susp-log-actions">'+
      '<button class="susp-log-edit-btn" onclick="suspLogEdit('+realIdx+')">기간변경</button>'+
      (isActive ? '<button class="susp-log-del-btn" onclick="suspLogRelease('+realIdx+')">해제</button>' :
                  '<button class="susp-log-del-btn" onclick="suspLogDelete('+realIdx+')">삭제</button>')+
    '</div>';
    html += '<div class="susp-log-item">'+
      '<div class="susp-log-dot '+dot+'"></div>'+
      '<div class="susp-log-info">'+
        '<div class="susp-log-period">'+period+'</div>'+
        '<div class="susp-log-detail">'+detail+'</div>'+
      '</div>'+badge+actions+
    '</div>';
  });
  el.innerHTML = html;
}

/* ─ 제출 ─ */
function suspSubmit(){
  var m  = members.find(function(x){ return x.id===_suspMemberId; });
  var tk = m && m.tickets && m.tickets[_suspTicketIdx];
  if(!tk){ showToast('이용권을 찾을 수 없습니다','warn'); return; }

  var startDate='', endDate='';
  if(_suspTab==='cal'){
    if(!_suspCalStart){ showToast('시작일을 선택해주세요','warn'); return; }
    startDate = _suspCalStart;
    endDate   = _suspCalEnd || '';
  } else {
    if(!_suspDaysVal){ showToast('일수를 선택해주세요','warn'); return; }
    startDate = suspToday();
    endDate   = suspDateAdd(startDate, _suspDaysVal-1);
  }

  var memo = document.getElementById('susp-memo').value.trim();
  if(!tk.pauseLogs) tk.pauseLogs=[];

  // 기존 active 해제
  tk.pauseLogs.forEach(function(l){ if(l.active) l.active=false; });

  var log = {
    start: startDate,
    end:   endDate || null,
    memo:  memo,
    active: true,
    createdAt: new Date().toISOString()
  };
  tk.pauseLogs.push(log);

  // tk.paused / pausedAt 동기화
  tk.paused   = true;
  tk.pausedAt = startDate;

  // 종료일이 있으면 이용권 endDate 연장 (중지일수 만큼)
  if(endDate && tk.endDate){
    var suspDays = suspDateDiff(startDate, endDate)+1;
    tk.endDate = suspDateAdd(tk.endDate, suspDays);
  }

  saveState();
  suspRenderLog();
  // 초기화
  _suspCalStart=null; _suspCalEnd=null; _suspCalStep=0;
  suspRenderCal();
  document.getElementById('susp-days-result').style.display='none';
  document.querySelectorAll('.susp-days-opt').forEach(function(b){ b.classList.remove('selected'); });
  document.getElementById('susp-days-custom-inp').value='';
  _suspDaysVal=0;
  document.getElementById('susp-memo').value='';
  document.getElementById('susp-submit-btn').textContent='중지 추가 등록';

  // 변경내역 기록
  tkChangeLogPush(_suspMemberId, '중지', tkLogName(tk),
    '중지기간: '+startDate+(endDate?' ~ '+endDate:' (종료일 미정)'),
    memo||'');
  try{ mbdRenderTickets(); }catch(e){}
  try{ mbdRenderHome(); }catch(e){}
  showToast('이용권이 중지되었습니다','info');
}

/* ─ 이력 편집 ─ */
function suspLogEdit(idx){
  var m  = members.find(function(x){ return x.id===_suspMemberId; });
  var tk = m && m.tickets && m.tickets[_suspTicketIdx];
  if(!tk||!tk.pauseLogs||!tk.pauseLogs[idx]) return;
  var log = tk.pauseLogs[idx];
  _suspEditLogIdx = idx;
  document.getElementById('susp-edit-log-idx').value = idx;
  document.getElementById('susp-edit-start').value = log.start||'';
  document.getElementById('susp-edit-end').value   = log.end||'';
  document.getElementById('susp-edit-memo').value  = log.memo||'';
  document.getElementById('susp-edit-ov').classList.add('open');
}
function suspEditClose(){
  document.getElementById('susp-edit-ov').classList.remove('open');
}
function suspEditSave(){
  var m  = members.find(function(x){ return x.id===_suspMemberId; });
  var tk = m && m.tickets && m.tickets[_suspTicketIdx];
  if(!tk||_suspEditLogIdx===null) return;
  var log = tk.pauseLogs[_suspEditLogIdx];
  if(!log) return;
  var ns = document.getElementById('susp-edit-start').value.trim();
  var ne = document.getElementById('susp-edit-end').value.trim();
  var nm = document.getElementById('susp-edit-memo').value.trim();
  if(!ns){ showToast('시작일을 입력해주세요','warn'); return; }
  // 이전 endDate 보정 (원래 중지일수를 되돌리고 새 일수 적용)
  if(log.end && tk.endDate){
    var oldDays = suspDateDiff(log.start, log.end)+1;
    tk.endDate = suspDateAdd(tk.endDate, -oldDays);
  }
  log.start = ns;
  log.end   = ne || null;
  log.memo  = nm;
  // 새 endDate 반영
  if(log.end && tk.endDate){
    var newDays = suspDateDiff(log.start, log.end)+1;
    tk.endDate = suspDateAdd(tk.endDate, newDays);
  }
  // paused 동기화
  var hasActive = tk.pauseLogs.some(function(l){ return l.active; });
  tk.paused = hasActive;
  tk.pausedAt = hasActive ? (tk.pauseLogs.find(function(l){ return l.active; })||{}).start || suspToday() : null;
  saveState();
  suspEditClose();
  suspRenderLog();
  try{ mbdRenderTickets(); }catch(e){}
  try{ mbdRenderHome(); }catch(e){}
  showToast('중지 기간이 변경되었습니다','ok');
}

/* ─ 이력 삭제 ─ */
function suspLogDelete(idx){
  if(!confirm('이 중지 이력을 삭제하시겠습니까?')) return;
  var m  = members.find(function(x){ return x.id===_suspMemberId; });
  var tk = m && m.tickets && m.tickets[_suspTicketIdx];
  if(!tk||!tk.pauseLogs) return;
  var log = tk.pauseLogs[idx];
  // endDate 보정
  if(log && log.end && tk.endDate){
    var d = suspDateDiff(log.start, log.end)+1;
    tk.endDate = suspDateAdd(tk.endDate, -d);
  }
  tk.pauseLogs.splice(idx,1);
  var hasActive = tk.pauseLogs.some(function(l){ return l.active; });
  tk.paused = hasActive;
  tk.pausedAt = hasActive ? (tk.pauseLogs.find(function(l){ return l.active; })||{}).start : null;
  saveState();
  suspRenderLog();
  try{ mbdRenderTickets(); }catch(e){}
  try{ mbdRenderHome(); }catch(e){}
  showToast('이력이 삭제되었습니다','info');
}

/* ─ 당일 해제 (active → false) ─ */
function suspLogRelease(idx){
  _suspReleaseLogIdx = idx;
  var m  = members.find(function(x){ return x.id===_suspMemberId; });
  var tk = m && m.tickets && m.tickets[_suspTicketIdx];
  var log = tk && tk.pauseLogs && tk.pauseLogs[idx];
  if(!log) return;
  var today = suspToday();
  var days  = log.start <= today ? suspDateDiff(log.start, today) : 0;
  document.getElementById('susp-release-info').innerHTML =
    '<strong>'+suspFmtDate(log.start)+(log.end?' ~ '+suspFmtDate(log.end):'')+'</strong> 중지를 해제합니다.<br>오늘('+suspFmtDate(today)+')부로 즉시 해제됩니다.';
  document.getElementById('susp-release-warn').textContent =
    '실제 중지일수 '+days+'일이 적용됩니다. 이용권 종료일이 남은 기간만큼 조정됩니다.';
  document.getElementById('susp-release-warn').style.display = days>0 ? 'block' : 'none';
  document.getElementById('susp-release-ov').classList.add('open');
}
function suspReleaseClose(){
  document.getElementById('susp-release-ov').classList.remove('open');
}
function suspReleaseConfirm(){
  var m  = members.find(function(x){ return x.id===_suspMemberId; });
  var tk = m && m.tickets && m.tickets[_suspTicketIdx];
  if(!tk||_suspReleaseLogIdx===null) return;
  var log = tk.pauseLogs && tk.pauseLogs[_suspReleaseLogIdx];
  if(!log) return;
  var today = suspToday();

  // 이전 endDate 보정 (원래 예정 종료일 기반 되돌리기)
  if(log.end && tk.endDate){
    var oldSuspDays = suspDateDiff(log.start, log.end)+1;
    tk.endDate = suspDateAdd(tk.endDate, -oldSuspDays);
  }

  // 실제 중지된 일수 반영
  var realDays = log.start <= today ? suspDateDiff(log.start, today) : 0;
  if(realDays > 0 && tk.endDate){
    tk.endDate = suspDateAdd(tk.endDate, realDays);
  }

  log.active = false;
  log.end    = today;
  log.releasedAt = new Date().toISOString();

  var hasActive = tk.pauseLogs.some(function(l){ return l.active; });
  tk.paused   = hasActive;
  tk.pausedAt = hasActive ? (tk.pauseLogs.find(function(l){ return l.active; })||{}).start : null;

  saveState();
  suspReleaseClose();
  suspRenderLog();
  // 변경내역 기록
  var _relTk = m && m.tickets && m.tickets[_suspTicketIdx];
  tkChangeLogPush(_suspMemberId, '중지해제', tkLogName(_relTk),
    '해제일: '+today+(realDays>0?' · 실제중지 '+realDays+'일':''),
    _relTk&&_relTk.endDate ? '종료일 → '+_relTk.endDate : '');
  try{ mbdRenderTickets(); }catch(e){}
  try{ mbdRenderHome(); }catch(e){}
  showToast('이용권 중지가 해제되었습니다','ok');
}

/* ═══ 기존 mbdSuspendTicketById 를 새 모달로 교체 ═══ */
var _origSuspendById = (typeof mbdSuspendTicketById === 'function') ? mbdSuspendTicketById : null;
mbdSuspendTicketById = function(idx){
  var m = members.find(function(x){ return x.id===mbDetailId; });
  if(!m||!m.tickets||!m.tickets[idx]){ showToast('이용권을 찾을 수 없습니다','warn'); return; }
  openSuspendModal(mbDetailId, idx);
};

/* ═══ 기존 mbdSuspendTicket (홈탭 버튼) 도 교체 ═══ */
var _origSuspendTicket = (typeof mbdSuspendTicket === 'function') ? mbdSuspendTicket : null;
mbdSuspendTicket = function(){
  var m = members.find(function(x){ return x.id===mbDetailId; });
  if(!m||!m.tickets||!m.tickets.length){ showToast('이용권이 없습니다','warn'); return; }
  var activeIdx = m.tickets.findIndex(function(tk){ return !tk.paused && !tk.refunded; });
  if(activeIdx<0){
    // 모든 이용권 중 첫번째 비환불 이용권
    activeIdx = m.tickets.findIndex(function(tk){ return !tk.refunded; });
  }
  if(activeIdx<0){ showToast('이용권이 없습니다','warn'); return; }
  openSuspendModal(mbDetailId, activeIdx);
};
</script>
