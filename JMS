  // 복합결제 UI 초기화
  mseResetPayUI();
  // payCard/payCash/payTransfer 필드 우선 복원, 없으면 payMethod 문자열 파싱
  var wrapMap = {'카드':'mse-pay-card-wrap','현금':'mse-pay-cash-wrap','이체':'mse-pay-transfer-wrap'};
  var inpMap  = {'카드':'mse-pay-card','현금':'mse-pay-cash','이체':'mse-pay-transfer'};
  var fieldMap = {'카드': s.payCard||0, '현금': s.payCash||0, '이체': s.payTransfer||0};
  var hasFields = s.payCard || s.payCash || s.payTransfer;
  if(hasFields){
    ['카드','현금','이체'].forEach(function(t){
      var v = fieldMap[t];
      if(!v) return;
      var btn = document.querySelector('.mse-pay-btn[data-val="'+t+'"]');
      if(btn){ btn.classList.add('selected'); btn.style.borderColor='#1a5fa0'; btn.style.background='#eaf3fc'; btn.style.color='#1a4a80'; }
      var wrap = document.getElementById(wrapMap[t]);
      var inp  = document.getElementById(inpMap[t]);
      if(wrap) wrap.style.display='block';
      if(inp)  inp.value = v;
    });
  } else {
    // 구버전: payMethod 문자열 파싱
    var pm = s.payMethod || '';
    var parts = pm.split('+');
    parts.forEach(function(part){
      part = part.trim();
      var m2 = part.match(/^(카드|현금|이체)\s*([\d,]+)/);
      if(m2){
        var t = m2[1], v = parseInt(m2[2].replace(/,/g,''), 10);
        var btn = document.querySelector('.mse-pay-btn[data-val="'+t+'"]');
        if(btn){ btn.classList.add('selected'); btn.style.borderColor='#1a5fa0'; btn.style.background='#eaf3fc'; btn.style.color='#1a4a80'; }
        var wrap = document.getElementById(wrapMap[t]);
        var inp  = document.getElementById(inpMap[t]);
        if(wrap) wrap.style.display='block';
        if(inp)  inp.value = v;
      } else if(pm === '카드' || pm === '현금' || pm === '이체'){
        var btn2 = document.querySelector('.mse-pay-btn[data-val="'+pm+'"]');
        if(btn2){ btn2.classList.add('selected'); btn2.style.borderColor='#1a5fa0'; btn2.style.background='#eaf3fc'; btn2.style.color='#1a4a80'; }
        var wrap2 = document.getElementById(wrapMap[pm]);
        if(wrap2) wrap2.style.display='block';
      }
    });
  }
  mbdSaleEditCalc();
  document.getElementById('mbd-sale-edit-panel').style.display = 'block';
  document.getElementById('mbd-sale-edit-panel').scrollIntoView({behavior:'smooth',block:'nearest'});
}

