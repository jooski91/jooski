<script>
// ── 스케줄 헬퍼 (블록1에서 사용 - 실제 구현은 블록3에서 초기화 후 덮어씀) ──
var lsProSchedules = {};
function lsGetSlotState(proName, dateStr, slotHhmm){
  try{
    var isOff = lsIsOffDay(proName, dateStr);
    if(isOff) return 'off';
    var sch = lsProSchedules[proName];
    if(!sch) return 'normal';
    var wt = sch.workTimes;
    if(!wt || Array.isArray(wt)) return 'normal';
    var d = new Date(dateStr+'T00:00:00');
    var times = wt[d.getDay()];
    if(!times || !times.length) return 'normal';
    var slotEnd = calcEndTime(slotHhmm, 30);
    for(var i=0;i<times.length;i++){
      if(slotHhmm >= times[i].start && slotEnd <= times[i].end) return 'work';
    }
    return 'normal';
  }catch(e){ return 'normal'; }
}
function lsSlotBg(state, isBlocked){
  if(isBlocked) return 'background:#f0f0f0;cursor:not-allowed;opacity:.5';
  if(state==='off')  return 'background:#fff0f0';
  if(state==='work') return 'background:#f0faf0';
  return '';
}
function lsIsOffDay(proName, dateStr){ return false; } // 블록3에서 재정의됨

const _SD_BASE=75, _RD_BASE=75;
function SD(){ try{ var s=localStorage.getItem('tdf_bayDur'); if(s){ var d=JSON.parse(s); return d.std||_SD_BASE; } }catch(e){} return _SD_BASE; }
function RD(){ try{ var s=localStorage.getItem('tdf_bayDur'); if(s){ var d=JSON.parse(s); return d.room||_RD_BASE; } }catch(e){} return _RD_BASE; }
let bays=[],rooms=[],waiting=[],nid=1,mst=null,lesHL=null,durSt=null,durTmp=75;

function zone(n){return n<=3?'A':n<=6?'B':n<=9?'C':'D'}
function N(){return Date.now()}
function elap(t){return t?Math.floor((N()-t)/60000):0}
function rem(t,d){return Math.max(0,d-elap(t))}
function remSec(t,d){if(!t)return null;return Math.max(0,d*60-Math.floor((N()-t)/1000))}
function remStr(t,d){
  const s=remSec(t,d);
  if(s===null)return'';
  if(s===0)return'⚠ 시간 종료';
  const m=Math.floor(s/60),sec=s%60;
  if(m>=60){
    const hh=Math.floor(m/60), mm=m%60;
    return hh+'시간'+(mm>0?mm+'분':'');
  }
  return m>0?m+'분 '+pad(sec)+'초':sec+'초';
}
function sT(t){if(!t)return'';const s=new Date(t);return pad(s.getHours())+':'+pad(s.getMinutes())}
function eT(t,d){if(!t)return'';const e=new Date(t+d*60000);return pad(e.getHours())+':'+pad(e.getMinutes())}
function pad(n){return String(n).padStart(2,'0')}
function tCls(tp){return tp==='레슨'?'les':tp==='룸레슨'?'rles':'occ'}
function tLbl(tp){return tp==='레슨'?'레슨':tp==='룸레슨'?'룸 레슨':'시설이용'}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}

