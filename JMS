      <button id="ls-drag-cancel-btn" style="padding:9px 20px;background:#fff;border:1.5px solid #ddd;color:#555;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit">취소</button>
      <button id="ls-drag-confirm-btn" style="padding:9px 24px;background:#1a5fa0;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit">이동 확인</button>
    </div>
  </div>
</div>

<script>
/* ── 날짜 input placeholder 오늘 날짜로 유지 ── */
(function(){
  function setDatePlaceholders(){
    var today = new Date().toISOString().slice(0,10);
    document.querySelectorAll('input[data-dp="1"]').forEach(function(el){
      // "(선택)" 같은 접미어가 있는 경우 보존
      var cur = el.getAttribute('placeholder')||'';
      var suffix = cur.replace(/\d{4}-\d{2}-\d{2}/g,'').trim();
      el.placeholder = suffix ? today+' '+suffix : today;
    });
  }
  // 페이지 로드 시
  document.addEventListener('DOMContentLoaded', setDatePlaceholders);
  // 이미 로드됐을 경우 즉시
  if(document.readyState !== 'loading') setDatePlaceholders();
  // 모달이 열릴 때마다 (MutationObserver로 display 변화 감지)
  var obs = new MutationObserver(function(muts){
    muts.forEach(function(m){
      if(m.type==='attributes' && m.attributeName==='style') setDatePlaceholders();
    });
  });
  document.querySelectorAll('[id$="-ov"],[id$="-overlay"],[id$="-popup"]').forEach(function(el){
    obs.observe(el, {attributes:true});
  });
})();
</script>

</body>
