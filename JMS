  _mbdEditSaleIdx = idx;
  var s = m.sales[idx];
  document.getElementById('mse-saledate').value   = s.saleDate  || '';
  document.getElementById('mse-paydate').value    = s.payDate   || '';
  var _ptEl = document.getElementById('mse-paytime');
  if(_ptEl){
    if(s.completedAt){
      var _ct = new Date(s.completedAt);
      _ptEl.value = _ct.getHours().toString().padStart(2,'0')+':'+_ct.getMinutes().toString().padStart(2,'0');
