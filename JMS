  if(!results||!results.length){el.innerHTML='<div style="font-size:12px;color:#888;text-align:center;padding:8px">대기자가 없습니다.</div>';return;}
  const zoneNames={A:'A(1~3번)',B:'B(4~6번)',C:'C(7~9번)',D:'D(10~12번)'};
  el.innerHTML=results.map((r,i)=>{
    const w=r.w;
    // 타입 배지
    const typeBadge=w.type==='시설이용'
      ?'<span class="wtype-badge wtype-fac">시설이용</span>'
