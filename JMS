const LS_START_H=9, LS_END_H=23;
const SLOT_H=28; // px per 30-min slot

let lsPros=[
  {name:'이재강'},
  {name:'최진규'},
  {name:'고재향'},
  {name:'박경도'},
  {name:'동대구센터 운영팀'},
