              <span id="set-room-dur" style="font-size:18px;font-weight:800;color:#1a5fa0;min-width:50px;text-align:center">75</span>
              <button onclick="setBayDur('room',+5)" style="width:30px;height:30px;border:1px solid #ddd;border-radius:6px;background:#fff;font-size:14px;font-weight:700;cursor:pointer">+</button>
              <span style="font-size:12px;color:#888">분</span>
