  // 타석 카드의 게이지바 요소만 갱신
  const allB=[...bays.map((b,i)=>({b,i,kind:'normal'})),...rooms.map((b,i)=>({b,i,kind:'room'}))];
  allB.forEach(({b,i,kind})=>{
    if(b.status==='empty'||!b.startTime)return;
    const s=remSec(b.startTime,b.dur);
    if(s===null)return;
    const lbl=kind==='room'?'R'+b.num+' 룸':b.num+'번';
    document.querySelectorAll('.bay:not(.empty)').forEach(card=>{
      const capLbl=card.querySelector('.b-cap-lbl');
      if(!capLbl||capLbl.textContent.trim()!==lbl)return;
      const r=rem(b.startTime,b.dur);
      // urgency 업데이트
      if(s===0||r<=5){card.classList.add('urg-hi');card.classList.remove('urg-lo');}
      else if(r<=10){card.classList.add('urg-lo');card.classList.remove('urg-hi');}
      else{card.classList.remove('urg-hi','urg-lo');}
      // 게이지바 업데이트
      const gaugeWrap=card.querySelector('.b-gauge-wrap');
      if(!gaugeWrap)return;
      const gaugeFill=gaugeWrap.querySelector('.b-gauge-fill');
      const gaugeLbl=gaugeWrap.querySelector('.b-gauge-lbl');
      const pct=b.dur>0?Math.max(0,Math.min(100,100-Math.round(r/b.dur*100))):0;
      const gColor=r<=5?'#e06060':r<=10?'#e09030':'#00b87f';
      const gBg=r<=5?'#f7c0c0':r<=10?'#f5dfa0':'#b0f0da';
      if(gaugeFill){gaugeFill.style.width=pct+'%';gaugeFill.style.background=gColor;}
      if(gaugeWrap){gaugeWrap.style.background=gBg;}
      if(gaugeLbl){
        const txt=s===0?'⚠ 시간 종료':remStr(b.startTime,b.dur);
        gaugeLbl.textContent=txt;
        gaugeLbl.style.color='#222';
        gaugeLbl.style.textShadow='none';
      }
    });
  });
  // 대기시간 실시간 갱신
  document.querySelectorAll('.w-wait-time[data-addedat]').forEach(el=>{
    el.textContent=wTime(+el.dataset.addedat);
  });
  // 포캐스트 패널 잔여시간 갱신
  if(fcActive||fcActive1){
    ['fc-body','fc-body1'].forEach(id=>{
      const panel=document.getElementById(id);if(!panel)return;
      panel.querySelectorAll('.fc-bay[data-baykey]').forEach(el=>{
        const bk=el.dataset.baykey;
        const isRoom=bk.startsWith('r');
        const num=parseInt(bk.slice(1));
        const b=(isRoom?rooms:bays).find(x=>x.num===num);
        if(!b||!b.startTime)return;
        const mins=rem(b.startTime,b.dur);
        const timeEl=el.querySelector('.fc-time');
        if(!timeEl)return;
        if(mins<=0){
          el.className='fc-bay ok assignable';
          timeEl.textContent='탭하여 배정';
        } else {
          timeEl.textContent='약 '+mins+'분 후';
          // 15분 이하 → wait 색상
          if(mins<=15) el.className='fc-bay wait';
          else el.className='fc-bay ok';
          el.dataset.baykey=bk; // 유지
        }
      });
    });
  }
  // 예상 대기시간 패널 실시간 갱신
  renderEstWait();
},1000);
