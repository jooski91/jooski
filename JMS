function renderEstWait(){
  const chips=document.getElementById('est-wait-chips');
  if(!chips)return;
  function soonestMins(pool, type){
    return pool
      .filter(b=>{
        if(b.status==='empty'||!b.startTime||!b.dur) return false;
        return true; // 같은 타석 풀은 레슨/시설이용 구분없이 비는 시점을 모두 반영
      })
      .map(b=>rem(b.startTime,b.dur))
      .filter(m=>m>0)  // 이미 시간 초과된 타석 제외
      .sort((a,c)=>a-c);
  }
  function estMin(type){
    const pool=type==='룸레슨'?rooms:bays;
    const mins=soonestMins(pool, type);
    // 이 타입으로 이미 대기 중인 사람 수 (나보다 앞 순번)
    const rank=waiting.filter(w=>w.type===type).length;

    // 빈 타석 중 이 타입에 실제로 배정 가능한 수 계산
    let emptyCount=pool.filter(b=>b.status==='empty').length;
    if(type==='시설이용'){
      // 빈 타석이 있어도 레슨 대기자 수만큼은 레슨용으로 선점됨
      const lesWaiting=waiting.filter(w=>w.type==='레슨').length;
      emptyCount=Math.max(0, emptyCount-lesWaiting);
    }

    // 빈 타석이 앞 대기자보다 많으면 즉시 입장
    if(emptyCount>rank) return 0;

    // 빈 타석을 앞 대기자에게 먼저 배정 후, 남은 순번에 해당하는 타석 잔여시간
    const waitIdx=rank-emptyCount;
    if(!mins.length) return 0; // 이용 중 타석 없음 → 즉시 입장
    return mins[Math.min(waitIdx, mins.length-1)];
  }
  function chip(label,type,icon){
    const m=estMin(type);
    let bg,color,border,txt;
    if(m===0){bg='#dcfce7';color='#166534';border='#86efac';txt='즉시 입장';}
    else if(m<=5){bg='#fef9c3';color='#713f12';border='#fde047';txt='약 '+m+'분 후';}
    else if(m<=15){bg='#fff7ed';color='#9a3412';border='#fed7aa';txt='약 '+m+'분 후';}
    else{bg='#fef2f2';color='#991b1b';border='#fca5a5';txt='약 '+m+'분 후';}
    return '<span style="display:inline-flex;align-items:center;gap:5px;padding:4px 12px;border-radius:20px;border:1.5px solid '+border+';background:'+bg+';color:'+color+';font-size:12px;font-weight:700;white-space:nowrap">'+
      icon+' <span style="font-weight:600;opacity:.8">'+label+'</span> <span>'+txt+'</span></span>';
  }
  chips.innerHTML=chip('시설이용','시설이용','🏌️');
}

