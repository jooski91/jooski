/* ── 한국 공휴일 (고정) ── */
const KR_HOLIDAYS = {
  '01-01':1,'03-01':1,'05-05':1,'06-06':1,'08-15':1,
  '10-03':1,'10-09':1,'12-25':1
};
function isHoliday(y, m, d){
  const mmdd = String(m+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
  return !!KR_HOLIDAYS[mmdd];
}

function renderCal(){
  const MON=['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
  document.getElementById('cal-month-label').textContent=calYear+'년 '+MON[calMonth];
  const today=new Date(); const todayKey=lsDateKey(today);
  const curKey=lsDateKey(lsCurrentDate());
  const first=new Date(calYear,calMonth,1);
  // 월요일 시작: 0=일 → 7로 변환 후 -1
  const rawDow=first.getDay();
  const startDow=(rawDow===0?7:rawDow)-1; // 0=월 ~ 6=일
  const daysInMonth=new Date(calYear,calMonth+1,0).getDate();
  const daysInPrev=new Date(calYear,calMonth,0).getDate();
  const DOW_MON=['월','화','수','목','금','토','일'];
  // 요일 헤더 색상: 토=파랑, 일=빨강
  const DOW_COLOR=['#333','#333','#333','#333','#333','#1a5fa0','#c03030'];
  let html=DOW_MON.map((d,i)=>`<div class="ls-cal-dow" style="color:${DOW_COLOR[i]}">${d}</div>`).join('');
  // 이전 달 채우기
  for(let i=0;i<startDow;i++){
    html+=`<div class="ls-cal-day other-month">${daysInPrev-startDow+1+i}</div>`;
  }
  for(let d=1;d<=daysInMonth;d++){
    const dk=calYear+'-'+String(calMonth+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    const isTod=dk===todayKey, isSel=dk===curKey;
    const date=new Date(calYear,calMonth,d);
    // 월요일 시작 기준 열 인덱스 (0=월 ~ 6=일)
    const colIdx=(date.getDay()===0?6:date.getDay()-1);
    const isSat=colIdx===5, isSun=colIdx===6;
    const isHol=isHoliday(calYear,calMonth,d);
    let color = isSun||isHol ? '#c03030' : isSat ? '#1a5fa0' : '#333';
    if(isTod) color='#fff';
    html+=`<div class="ls-cal-day${isTod?' today':''}${isSel?' selected':''}" style="color:${color}" onclick="calPickDay(${calYear},${calMonth},${d})">${d}</div>`;
  }
  // 다음 달 채우기
  const total=startDow+daysInMonth;
  const rem=(7-total%7)%7;
  for(let i=1;i<=rem;i++) html+=`<div class="ls-cal-day other-month">${i}</div>`;
  document.getElementById('cal-grid').innerHTML=html;
}
function calPickDay(y,m,d,openPopup){
  const target=new Date(y,m,d);
  const today=new Date(); today.setHours(0,0,0,0);
  target.setHours(0,0,0,0);
  lsDayOffset=Math.round((target-today)/(1000*60*60*24));
  if(lsView==='pro'){
    const dow=target.getDay()===0?7:target.getDay();
    const monday=new Date(target); monday.setDate(target.getDate()-(dow-1));
    const todayDow=today.getDay()===0?7:today.getDay();
    const todayMon=new Date(today); todayMon.setDate(today.getDate()-(todayDow-1));
    lsProWeekOffset=Math.round((monday-todayMon)/(7*24*60*60*1000));
  }
  closeCal();
  lsRender();
}

