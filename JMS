function ciRequestNotifyPermission(){
  if('Notification' in window && Notification.permission==='default'){
    Notification.requestPermission();
  }
}
function ciNotify(title, body){
  if(!('Notification' in window)) return;
  if(Notification.permission==='granted'){
    new Notification(title, {body: body, icon: '', silent: false});
  } else if(Notification.permission==='default'){
    Notification.requestPermission().then(function(p){
      if(p==='granted') new Notification(title, {body: body, icon: '', silent: false});
    });
  }
}
function ciEnsureNotifyPermission(){
  if('Notification' in window && Notification.permission==='default'){
    Notification.requestPermission();
  }
}

/* ── 삭제 ── */
function ciDelete(id){
  var c = ciCheckins.find(function(x){ return x.id===id; });
  if(!c) return;
  if(!confirm('이 체크인 내역을 삭제하시겠습니까?')) return;
  // 연결 레슨 출석 취소
  if(c.type==='lesson' && c.lessonId){
    var ls = lsLessons.find(function(x){ return x.id===c.lessonId; });
    if(ls && ls.status==='attend') ls.status='';
    saveState();
  }
  ciCheckins = ciCheckins.filter(function(x){ return x.id!==id; });
  if(ciSelMemberId===c.memberId) ciSelMemberId=null;
  ciSave(); ciRender();
}

