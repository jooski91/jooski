function lsStudentSearch(q){
  const dd=document.getElementById('ls-student-dropdown');
  const clearBtn=document.getElementById('ls-student-clear');
  clearBtn.style.display=q?'block':'none';
  // 회원이 이미 선택된 상태면 드롭다운 안 열기
  if(document.getElementById('ls-selected-member-id').value){ dd.style.display='none'; return; }
  if(!q.trim()){ dd.style.display='none'; return; }
  const kw=q.trim().toLowerCase();
  const hits=members.filter(m=>
    m.name.toLowerCase().includes(kw)||
    (m.phone||'').replace(/-/g,'').includes(kw.replace(/-/g,''))||
    (m.num||'').toLowerCase().includes(kw)
  ).slice(0,8);
  if(!hits.length){
    dd.innerHTML='<div style="padding:12px 14px;font-size:12px;color:#e53e3e;text-align:center">검색 결과 없음</div>';
    dd.style.display='block';
    return;
  }
  const instructor=document.getElementById('ls-instructor').value;
  dd.innerHTML=hits.map(m=>{
    const tkList=lsGetMemberLessonTickets(m, instructor);
    const hasTicket=tkList.length>0;
    const avatarColor=m.gender==='여'?'#be185d':'#1d4ed8';
    const initial=m.name.charAt(0);
    const badge=hasTicket
      ? `<span class="ls-member-ticket-badge ok">🎫 이용권 ${tkList.length}개</span>`
      : `<span class="ls-member-ticket-badge none">이용권 없음</span>`;
    return `<div class="ls-member-item" onclick="lsSelectMember(members.find(x=>x.id===${m.id}),null)">
      <div class="ls-member-avatar" style="background:${avatarColor}">${esc(initial)}</div>
      <div class="ls-member-info">
        <div class="ls-member-name">${esc(m.name)}</div>
        <div class="ls-member-meta">${esc(m.phone||'—')} · ${esc(m.num||'—')}</div>
      </div>
      ${badge}
    </div>`;
  }).join('');
  dd.style.display='block';
}
function lsSelectMember(m, preselTicketIdx){
  if(!m) return;
  document.getElementById('ls-student-search').value=m.name;
  document.getElementById('ls-student').value=m.name;
  document.getElementById('ls-selected-member-id').value=m.id;
  document.getElementById('ls-student-dropdown').style.display='none';
  document.getElementById('ls-student-clear').style.display='block';
  _lsSelectedTicketIdx=null;
