.ss-rpanel{display:none}.ss-rpanel.active{display:block}
.ss-room-row{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:12px;max-width:300px}
.ss-bay-top,.ss-bay-bot{display:grid;grid-template-columns:repeat(6,1fr);gap:6px}
.ss-bay-top{margin-bottom:6px}
.ss-zone-bar{display:grid;grid-template-columns:repeat(6,1fr);gap:6px;margin-bottom:3px}
.ss-zc{text-align:center;font-size:9px;font-weight:700;padding:2px 0;border-radius:4px 4px 0 0;grid-column:span 3}
.ss-za{background:#e8f4ff;color:#1a4a80}.ss-zb{background:#fff0e0;color:#804000}
.ss-zcc{background:#f0ffe0;color:#1a5010}.ss-zd{background:#fff0f8;color:#80204a}
.ss-mcard{border:1.5px solid #e0e0e0;border-radius:8px;padding:8px;background:#fff;min-height:98px;display:flex;flex-direction:column;gap:3px;transition:border-color .15s,box-shadow .15s}
.ss-mcard.found{border-color:#00c98a;background:#f0fcf8}
.ss-mcard.notfound{border-color:#e0c0c0;background:#fef8f8;opacity:.55}
.ss-mcard-num{font-size:11px;font-weight:800;color:#555}
.ss-mcard.found .ss-mcard-num{color:#00966b}
.ss-mcard-name{font-size:13px;font-weight:700;color:#222;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ss-mcard-time{font-size:11px;color:#777}
.ss-mcard-rem{font-size:15px;font-weight:800;color:#0e6640;margin-top:2px;letter-spacing:-.2px}
.ss-mcard-empty{font-size:11px;color:#bbb;margin-top:auto}
.ss-bay-card{border:1px solid #e0e8f0;border-radius:8px;padding:8px 10px;background:#fafcff}
.ss-bay-card.occ{border-color:#8cc870;background:#f0faf0}
.ss-bay-card .sbc-num{font-size:10px;color:#aaa;margin-bottom:2px}
.ss-bay-card .sbc-name{font-size:12px;font-weight:700;color:#222;margin-bottom:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ss-bay-card .sbc-time{font-size:11px;color:#555}
.ss-bay-card .sbc-rem{font-size:11px;color:#c07000;margin-top:2px;font-weight:700}
.ss-csv-box{background:#f5f5f5;border-radius:7px;padding:8px 10px;font-size:10px;font-family:monospace;color:#333;overflow-x:auto;white-space:pre;line-height:1.6;max-height:160px;overflow-y:auto;border:1px solid #e0e0e0}
.ss-act-section{padding:6px 0}
.ss-act-desc{font-size:12px;color:#555;line-height:1.7;margin-bottom:10px}
#ss-apply-btn{width:100%;padding:10px;border-radius:8px;border:none;background:#1a8a5e;color:#fff;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit}
#ss-apply-btn:hover{background:#136b47}
#ss-apply-btn:disabled{background:#aaa;cursor:not-allowed}
.ss-copy-btn{padding:5px 12px;border-radius:6px;border:1px solid #ddd;background:#fff;font-size:11px;color:#555;cursor:pointer;margin-top:7px;font-family:inherit}
.ss-copy-btn:hover{background:#f0f0f0}
</style>

<div id="ss-overlay" onclick="if(event.target===this)closeScreenshotAnalyzer()">
  <div id="ss-modal">
    <div class="ss-head">
      <div class="ss-head-title">Vision 분석</div>
      <button class="ss-close" onclick="closeScreenshotAnalyzer()">✕</button>
    </div>
    <div class="ss-body">
      <details id="ss-upload-section" open>
        <summary onclick="return false" style="cursor:default;font-size:12px;font-weight:700;color:#888;margin-bottom:8px;list-style:none;pointer-events:none">스크린샷 업로드</summary>
        <div class="ss-upload-zone" id="ss-upload-zone" style="cursor:default">
          <input type="file" id="ss-file-input" accept="image/*" style="display:none">
          <div class="ss-uz-icon">📸</div>
          <p style="font-size:14px;font-weight:700;color:#1a5fa0">RMS 타석관리 화면을 캡처해서 올려주세요</p>
          <p class="hint" style="margin-top:6px">스크린샷을 여기에 끌어다 놓거나 아래 버튼으로 선택</p>
          <p class="hint">PNG · JPG · WEBP 지원 &nbsp;|&nbsp; <b>Ctrl+V</b> 붙여넣기도 가능</p>
          <button type="button" id="ss-pick-file-btn" onclick="document.getElementById('ss-file-input').click()" style="margin-top:10px;padding:7px 16px;border-radius:7px;border:1.5px solid #1a5fa0;background:#fff;color:#1a5fa0;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit">📁 파일 선택하기</button>
        </div>
        <div id="ss-preview-wrap"><img id="ss-preview-img" src="" alt="스크린샷 미리보기"></div>
        <div id="ss-quota-badge" style="font-size:11px;color:#888;margin:4px 0 2px;text-align:right"></div>
        <div class="ss-btn-row">
          <button id="ss-analyze-btn" disabled onclick="ssAnalyze()">타석 시간 추출하기</button>
          <button id="ss-clear-btn" onclick="ssClear()">지우기</button>
        </div>
        <div id="ss-status"></div>
      </details>
      <div id="ss-result">
        <div class="ss-result-tabs">
          <div class="ss-rtab active" onclick="ssTab(this,'ss-panel-apply')">인식 결과</div>
          <div class="ss-rtab" onclick="ssTab(this,'ss-panel-csv')">CSV</div>
        </div>
        <div class="ss-rpanel" id="ss-panel-csv">
          <div class="ss-csv-box" id="ss-csv-box"></div>
          <button class="ss-copy-btn" onclick="ssCopyCSV()">📋 CSV 복사</button>
        </div>
        <div class="ss-rpanel active" id="ss-panel-apply">
          <div class="ss-act-section">
            <div class="ss-act-desc">인식된 타석 정보를 적용합니다. 배치를 확인 후 [적용하기]를 누르세요.</div>
            <div class="ss-room-row" id="ss-room-grid"></div>
            <div class="ss-zone-bar">
              <div class="ss-zc ss-za">A구역 (1~3번)</div>
              <div class="ss-zc ss-zb">B구역 (4~6번)</div>
            </div>
            <div class="ss-bay-top" id="ss-bay-top"></div>
            <div class="ss-zone-bar" style="margin-top:8px">
              <div class="ss-zc ss-zcc">C구역 (7~9번)</div>
              <div class="ss-zc ss-zd">D구역 (10~12번)</div>
            </div>
            <div class="ss-bay-bot" id="ss-bay-bot"></div>
            <div style="display:flex;gap:8px;margin-top:14px">
              <button id="ss-apply-btn" disabled onclick="ssApplyToBays()" style="flex:1">✅ 타석에 적용하기</button>
              <button onclick="ssClear()" style="padding:10px 16px;border-radius:8px;border:1.5px solid #ccc;background:#fff;color:#555;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit">다시 하기</button>
            </div>
          </div>
        </div>
      </div>
      <!-- API 키 입력 -->
      <details id="ss-key-section" style="margin-top:14px;padding:12px 14px;background:#f0f6ff;border:1px solid #c0d8f0;border-radius:10px">
        <summary style="cursor:pointer;font-size:12px;font-weight:700;color:#1a4a80;margin-bottom:6px;list-style:none;display:flex;align-items:center;gap:6px">🔑 Anthropic API 키<span id="ss-key-badge" style="font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px"></span></summary>
        <div id="ss-key-input-row" style="display:flex;gap:6px;align-items:center;margin-top:8px">
          <input type="password" id="ss-api-key" placeholder="API 키를 붙여넣으세요" style="flex:1;font-size:12px;padding:6px 10px;border:1px solid #c0d0e0;border-radius:6px;font-family:monospace;outline:none;background:#fff">
          <button onclick="ssSaveKey()" style="padding:6px 12px;background:#1a5fa0;color:#fff;border:none;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;font-family:inherit;white-space:nowrap">저장</button>
        </div>
        <div id="ss-key-card" style="display:none;align-items:center;justify-content:space-between;gap:8px;padding:8px 10px;margin-top:8px;background:#fff;border:1px solid #b8dcc0;border-radius:7px">
          <div style="display:flex;align-items:center;gap:7px;min-width:0">
            <span style="font-size:13px">🔐</span>
            <span id="ss-key-masked" style="font-size:12px;font-family:monospace;color:#333;letter-spacing:.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"></span>
          </div>
          <div style="display:flex;gap:4px;flex-shrink:0">
            <button onclick="ssEditKey()" style="padding:4px 10px;background:#fff;color:#1a5fa0;border:1px solid #c0d0e0;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;font-family:inherit">변경</button>
            <button onclick="ssDeleteKey()" style="padding:4px 10px;background:#fff;color:#c03030;border:1px solid #e0c0c0;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;font-family:inherit">삭제</button>
          </div>
        </div>
        <div style="margin-top:5px;font-size:10px;color:#aaa">※ 키는 이 브라우저에만 저장되며 외부로 전송되지 않습니다</div>
        <div id="ss-key-status" style="margin-top:5px;font-size:11px;color:#888"></div>
        <div style="margin-top:8px;font-size:11px;color:#555;line-height:1.8;background:#fff;border-radius:7px;padding:9px 11px;border:1px solid #dde8f5">
          <b style="color:#1a4a80">API 키 발급 방법</b><br>
          1. <a href="https://aistudio.google.com" target="_blank" style="color:#1a5fa0;font-weight:700">aistudio.google.com</a> 접속 (구글 계정 로그인)<br>
          2. 왼쪽 사이드바 맨 아래 <b>🔑 열쇠 아이콘</b> 클릭<br>
          3. 상단 <b>+ API 키</b> 버튼 클릭 → 키 생성<br>
          4. <b>키 복사</b> 버튼 눌러서 위 입력란에 붙여넣고 저장<br>
        </div>
      </details>
    </div>
  </div>
</div>

<script>
var _ssBase64 = null;
var _ssCaptureTime = null;
var _ssCountdownTimer = null;
var _ssParsed = [];
var SS_DAILY_LIMIT = 20; // 무료 등급 일일 요청 한도(필요시 조정)

// 오늘 날짜(현지 기준) 문자열 키. 구글 무료 한도는 태평양 시간 자정 기준이라 약간의 오차는 있을 수 있음
function ssTodayKey(){
  var d = new Date();
  return 'ssQuota_' + d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate());
}

function ssGetTodayCount(){
  try{
    var v = localStorage.getItem(ssTodayKey());
    return v ? parseInt(v,10) : 0;
  }catch(e){ return 0; }
}

function ssIncrTodayCount(){
  try{
    var n = ssGetTodayCount() + 1;
    localStorage.setItem(ssTodayKey(), String(n));
    return n;
  }catch(e){ return null; }
}

function ssUpdateQuotaBadge(){
  var el = document.getElementById('ss-quota-badge');
  if(!el) return;
  var n = ssGetTodayCount();
  var remain = SS_DAILY_LIMIT - n;
  el.textContent = '오늘 사용: ' + n + ' / ' + SS_DAILY_LIMIT + '회' + (remain<=3 ? ' (남은 ' + Math.max(0,remain) + '회)' : '');
  el.style.color = remain<=3 ? '#c03030' : (remain<=8 ? '#b07a10' : '#888');
}
document.addEventListener('DOMContentLoaded', ssUpdateQuotaBadge);


function ssMaskKey(key){
  if(!key) return '';
  var tail = key.slice(-4);
  return '••••••••••••' + tail;
}
function ssSetKeyBadge(state){
  // state: 'ok' | 'error' | 'none'
  var b = document.getElementById('ss-key-badge');
  if(!b) return;
  if(state==='ok'){
    b.textContent = '✅';
    b.style.background = '#e0f5e8';
    b.style.color = '#1a8a5e';
  } else if(state==='error'){
    b.textContent = '⚠️ 오류';
    b.style.background = '#ffe0e0';
    b.style.color = '#c03030';
  } else {
    b.textContent = '';
  }
}
function ssShowKeyCard(key){
  document.getElementById('ss-key-input-row').style.display = 'none';
  document.getElementById('ss-key-card').style.display = 'flex';
  document.getElementById('ss-key-masked').textContent = ssMaskKey(key);
}
function ssShowKeyInput(){
  document.getElementById('ss-key-input-row').style.display = 'flex';
  document.getElementById('ss-key-card').style.display = 'none';
}
function openScreenshotAnalyzer(){
  document.getElementById('ss-overlay').classList.add('open');
  var saved = localStorage.getItem('ss_gemini_key');
  var section = document.getElementById('ss-key-section');
  if(saved){
    document.getElementById('ss-api-key').value = saved;
    ssShowKeyCard(saved);
    document.getElementById('ss-key-status').innerHTML = '';
    section.removeAttribute('open');
    ssSetKeyBadge('ok');
  } else {
    ssShowKeyInput();
    document.getElementById('ss-api-key').value = '';
    document.getElementById('ss-key-status').innerHTML = '';
    section.setAttribute('open', '');
    ssSetKeyBadge('error');
  }
}
function closeScreenshotAnalyzer(){
  document.getElementById('ss-overlay').classList.remove('open');
  ssStopCountdown();
}
function ssSaveKey(){
  var key = document.getElementById('ss-api-key').value.trim();
  if(!key){ document.getElementById('ss-key-status').innerHTML='<span style="color:#c03030">키를 입력해주세요</span>'; ssSetKeyBadge('error'); return; }

  localStorage.setItem('ss_gemini_key', key);
  document.getElementById('ss-key-status').innerHTML='<span style="color:#1a8a5e">\u2705 저장되었습니다</span>';
  ssShowKeyCard(key);
  ssSetKeyBadge('ok');
}
function ssEditKey(){
  ssShowKeyInput();
  document.getElementById('ss-key-status').innerHTML = '';
}
function ssDeleteKey(){
  if(!confirm('저장된 API 키를 삭제하시겠습니까?')) return;
  localStorage.removeItem('ss_gemini_key');
  document.getElementById('ss-api-key').value = '';
  ssShowKeyInput();
  document.getElementById('ss-key-status').innerHTML = '<span style="color:#888">키가 삭제되었습니다</span>';
  ssSetKeyBadge('error');
}
function ssGetKey(){
  return (document.getElementById('ss-api-key').value.trim()) || localStorage.getItem('ss_gemini_key') || '';
}

document.getElementById('ss-file-input').addEventListener('change', function(e){
  var f = e.target.files[0];
  if(f) ssHandleFile(f);
});
document.getElementById('ss-upload-zone').addEventListener('dragover', function(e){
  e.preventDefault(); this.style.background='#ddeeff';
});
document.getElementById('ss-upload-zone').addEventListener('dragleave', function(e){
  this.style.background='';
});
document.getElementById('ss-upload-zone').addEventListener('drop', function(e){
  e.preventDefault(); this.style.background='';
  var f = e.dataTransfer.files[0];
  if(f && f.type.startsWith('image/')) ssHandleFile(f);
});

// 팝업이 열려있을 때 Ctrl+V 붙여넣기 지원
document.addEventListener('paste', function(e){
  if(!document.getElementById('ss-overlay').classList.contains('open')) return;
  var items = e.clipboardData && e.clipboardData.items;
  if(!items) return;
  for(var i=0; i<items.length; i++){
    if(items[i].type.startsWith('image/')){
      var file = items[i].getAsFile();
      if(file) ssHandleFile(file);
      break;
    }
  }
});

var _ssMediaType = 'image/png';

function ssHandleFile(file){
  _ssMediaType = file.type || 'image/png';
  var reader = new FileReader();
  reader.onload = function(ev){
    _ssBase64 = ev.target.result.split(',')[1];
    var img = document.getElementById('ss-preview-img');
    img.src = ev.target.result;
    document.getElementById('ss-upload-zone').style.display = 'none';
    document.getElementById('ss-preview-wrap').style.display = 'block';
    document.getElementById('ss-analyze-btn').disabled = false;
    document.getElementById('ss-status').style.display = 'none';
    document.getElementById('ss-result').style.display = 'none';
  };
  reader.readAsDataURL(file);
}

function ssClear(){
  _ssBase64 = null;
  _ssParsed = [];
  _ssCaptureTime = null;
  ssStopCountdown();
  document.getElementById('ss-upload-section').setAttribute('open', '');
  document.getElementById('ss-upload-zone').style.display = 'block';
  document.getElementById('ss-preview-wrap').style.display = 'none';
  document.getElementById('ss-preview-img').src = '';
  document.getElementById('ss-analyze-btn').disabled = true;
  document.getElementById('ss-status').style.display = 'none';
  document.getElementById('ss-result').style.display = 'none';
  document.getElementById('ss-file-input').value = '';
}

function ssSetStatus(type, html){
  var el = document.getElementById('ss-status');
  el.className = 'ss-status ' + type;
  el.innerHTML = html;
  el.style.display = 'block';
}

function ssTab(btn, panelId){
  document.querySelectorAll('.ss-rtab').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.ss-rpanel').forEach(function(p){ p.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById(panelId).classList.add('active');
}

async function ssAnalyze(){
  if(!_ssBase64) return;
  _ssCaptureTime = Date.now();
  ssIncrTodayCount();
  ssUpdateQuotaBadge();
  document.getElementById('ss-analyze-btn').disabled = true;
  document.getElementById('ss-result').style.display = 'none';
  ssSetStatus('loading', '<span class="ss-spinner"></span>AI가 타석 현황을 분석 중입니다...');

  var prompt = '이 이미지는 골프 타석 관리 시스템의 타석 현황 스크린샷입니다.\n각 타석/룸의 정보를 추출해주세요.\n\n타석 번호 표기 규칙(각 카드 좌측 상단에 굵게 표시됨):\n- "R01", "R02" = 룸 1번, 룸 2번 (룸레슨 타석)\n- "E01" ~ "E12" = 1번타석 ~ 12번타석 (일반 타석)\n각 카드 상단의 코드(R01/R02/E01~E12)를 그대로 bay_code 값으로 추출하세요. 절대 임의로 숫자만 추출하지 말고, 반드시 R 또는 E로 시작하는 코드 형태(예: "E03", "R01")로 응답하세요.\n\n추출 항목:\n- bay_code: 위 규칙에 따른 코드 문자열 (예: "E01", "R02")\n- name: 고객명 (빈 타석이면 "빈타석")\n- status: "사용중", "레슨중", "빈타석" 중 하나\n- start_time: HH:MM 형식 시작 시간 (없으면 "")\n- end_time: HH:MM 형식 종료 시간 (없으면 "")\n- remaining: 남은 시간 "X분" 형식. 반드시 화면에 직접 표시되어 있는 값만 그대로 사용하세요. 다른 값으로 계산하거나 추정하지 마세요. 화면에 남은시간이 직접 표시되어 있지 않으면 무조건 ""로 응답하세요.\n\n반드시 JSON 배열만 응답. 마크다운 없이 순수 JSON:\n[{"bay_code":"E01","name":"홍길동","status":"사용중","start_time":"14:00","end_time":"15:00","remaining":"45분"},{"bay_code":"R01","name":"김철수","status":"레슨중","start_time":"10:35","end_time":"11:50","remaining":"1시간 5분"},...]\n\n인식 불가 시 [] 반환.';

  try {
    var apiKey = ssGetKey();
  if(!apiKey){ ssSetStatus('error', '❌ API 키를 먼저 입력하고 저장해주세요'); document.getElementById('ss-analyze-btn').disabled=false; ssSetKeyBadge('error'); return; }
  var resp = await fetch('https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key='+apiKey, {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        contents: [{
          parts: [
            {inline_data: {mime_type: _ssMediaType, data: _ssBase64}},
            {text: prompt}
          ]
        }]
      })
    });
    var data = await resp.json();
    if(!resp.ok) throw new Error((data.error&&data.error.message) || '분석 실패');
    var raw = ((data.candidates||[])[0]||{});
    var raw2 = ((raw.content||{}).parts||[]).map(function(p){ return p.text||''; }).join('');
    var clean = raw2.trim().replace(/```json|```/g,'').trim();
    _ssParsed = JSON.parse(clean);
    if(!Array.isArray(_ssParsed)) throw new Error('형식 오류');
    ssRenderResults();
    ssSetStatus('ok', '✅ ' + _ssParsed.length + '개 타석 인식 완료');
    document.getElementById('ss-result').style.display = 'block';
    document.getElementById('ss-upload-section').removeAttribute('open');
    ssSetKeyBadge('ok');
  } catch(err){
    ssSetStatus('error', '❌ 분석 오류: ' + err.message);
    ssSetKeyBadge('error');
  } finally {
    document.getElementById('ss-analyze-btn').disabled = false;
  }
}

function ssMakeMiniCard(code, label){
  var found = _ssParsed.find(function(b){
    return (b.bay_code||'').toString().trim().toUpperCase() === code;
  });
  var d = document.createElement('div');
  if(!found){
    d.className = 'ss-mcard notfound';
    d.innerHTML = '<div class="ss-mcard-num">'+label+'</div><div class="ss-mcard-empty">인식 안됨</div>';
    return d;
  }
  var isEmpty = (found.status==='빈타석' || !found.name || found.name==='빈타석');
  if(isEmpty){
    d.className = 'ss-mcard';
    d.innerHTML = '<div class="ss-mcard-num">'+label+'</div><div class="ss-mcard-empty">빈 타석</div>';
    return d;
  }
  var timeStr = found.remaining ? ssFmtRemaining(found.remaining) : ((found.start_time && found.end_time) ? found.start_time+' ~ '+found.end_time : '-');

  d.className = 'ss-mcard found';
  d.innerHTML = '<div class="ss-mcard-num">'+label+'</div>'
    +'<div class="ss-mcard-name">'+found.name+'</div>'
    +'<div class="ss-mcard-time">'+found.status+'</div>'
    +'<div class="ss-mcard-rem">'+timeStr+'</div>';
  return d;
}

function ssDiffMinutes(start, end){
  if(!start || !end) return null;
  var sm = String(start).trim().match(/^(\d{1,2}):(\d{2})$/);
  var em = String(end).trim().match(/^(\d{1,2}):(\d{2})$/);
  if(!sm || !em) return null;
  var sMin = parseInt(sm[1],10)*60 + parseInt(sm[2],10);
  var eMin = parseInt(em[1],10)*60 + parseInt(em[2],10);
  var diff = eMin - sMin;
  if(diff < 0) diff += 24*60; // 자정 넘어가는 경우
  return diff;
}

function ssStopCountdown(){
  if(_ssCountdownTimer){ clearInterval(_ssCountdownTimer); _ssCountdownTimer = null; }
}

function ssRenderResults(){
  // 룸 (R01, R02)
  var rg = document.getElementById('ss-room-grid');
  rg.innerHTML = '';
  for(var ri=1; ri<=2; ri++){
    var rcode = 'R' + (ri<10?'0'+ri:ri);
    rg.appendChild(ssMakeMiniCard(rcode, rcode));
  }

  // 일반 타석 1~6 (top), 12~7 (bot) — 메인 화면과 동일 배치
  var top = document.getElementById('ss-bay-top');
  var bot = document.getElementById('ss-bay-bot');
  top.innerHTML = ''; bot.innerHTML = '';
  for(var i=1; i<=6; i++){
    var ecode = 'E' + (i<10?'0'+i:i);
    top.appendChild(ssMakeMiniCard(ecode, i+'번'));
  }
  [12,11,10,9,8,7].forEach(function(i){
    var ecode = 'E' + (i<10?'0'+i:i);
    bot.appendChild(ssMakeMiniCard(ecode, i+'번'));
  });

  // CSV
  var hdr = 'bay_code,name,status,start_time,end_time,remaining';
  var rows = _ssParsed.map(function(b){
    return ['"'+b.bay_code+'"','"'+b.name+'"','"'+b.status+'"',b.start_time,b.end_time,'"'+ssFmtRemaining(b.remaining)+'"'].join(',');
  });
  document.getElementById('ss-csv-box').textContent = [hdr].concat(rows).join('\n');

  // 적용 가능 여부
  var activeList = _ssParsed.filter(function(b){ return b.status!=='빈타석' && b.name && b.name!=='빈타석'; });
  document.getElementById('ss-apply-btn').disabled = activeList.length === 0;
}

function ssCopyCSV(){
  var txt = document.getElementById('ss-csv-box').textContent;
  navigator.clipboard.writeText(txt).then(function(){
    showToast('CSV 복사됨', 'ok');
  });
}

function ssParseRemainingMinutes(str){
  if(!str) return null;
  var h = str.match(/(\d+)\s*시간/);
  var m = str.match(/(\d+)\s*분/);
  if(!h && !m) return null;
  return (h?parseInt(h[1],10)*60:0) + (m?parseInt(m[1],10):0);
}

// 화면에 추출된 남은시간 문자열을 60분부터 "1시간", "1시간10분" 형식으로 표시
function ssFmtRemaining(str){
  if(!str) return str;
  var total = ssParseRemainingMinutes(str);
  if(total === null) return str; // 파싱 안되면 원본 그대로(계산 추가하지 않음)
  if(total < 60) return total+'분';
  var hh = Math.floor(total/60);
  var mm = total%60;
  return hh+'시간'+(mm>0?mm+'분':'');
}

// 적용 전, 현재 사용중인 모든 타석/룸을 먼저 종료 처리(이용기록은 보존)
function ssEndAllOccupied(){
  var nowMs = (typeof N === 'function') ? N() : Date.now();
  var mList = (typeof members !== 'undefined') ? members : [];
  function endOne(b, kind){
    if(!b || b.status==='empty') return;
    var bayLabel = kind==='room' ? 'R'+b.num+' 룸' : b.num+'번';
    var mObj = mList.find(function(m){ return m.name === b.name; }) || null;
    var phone = mObj ? [mObj.phone1,mObj.phone2,mObj.phone3].filter(Boolean).join('-') : '';
    var mbNum = mObj ? (mObj.num||'') : '';
    if(b.startTime && b.name && typeof praclogPush === 'function'){
      var endDt = new Date(nowMs);
      praclogPush({
        bayLabel : bayLabel,
        bayNum   : b.num,
        bayKind  : kind,
        date     : endDt.toISOString().slice(0,10),
        name     : b.name,
        phone    : phone,
        mbNum    : mbNum,
        startMs  : b.startTime,
        endMs    : nowMs,
        startStr : sT(b.startTime),
        endStr   : pad(endDt.getHours())+':'+pad(endDt.getMinutes()),
        type     : b.type
      });
    }
    b.status='empty'; b.name=''; b.type=''; b.startTime=null;
    b.dur = kind==='room' ? RD() : SD();
    b.drinkId=null; b.drinkTemp=null; b.drinkDone=false;
  }
  if(typeof bays !== 'undefined') bays.forEach(function(b){ endOne(b,'normal'); });
  if(typeof rooms !== 'undefined') rooms.forEach(function(r){ endOne(r,'room'); });
}

function ssApplyToBays(){
  var active = _ssParsed.filter(function(b){ return b.status!=='빈타석' && b.name && b.name!=='빈타석'; });
  if(!active.length){ showToast('적용할 타석 정보가 없습니다','warn'); return; }

  // 1) 적용 가능한 타석/룸을 먼저 매칭 (실제 종료/적용 전에 확인)
  var notFound = [];
  var plan = [];
  active.forEach(function(b){
    var code = (b.bay_code||'').toString().trim().toUpperCase();
    var m = code.match(/^([RE])0*([0-9]+)$/);
    if(!m){ notFound.push(code||'?'); return; }
    var kind = m[1]; // 'R' or 'E'
    var n = parseInt(m[2], 10);

    var target;
    if(kind === 'R'){
      if(typeof rooms === 'undefined') return;
      target = rooms.find(function(x){ return x.num == n; });
    } else {
      if(typeof bays === 'undefined') return;
      target = bays.find(function(x){ return x.num == n; });
    }
    if(!target){ notFound.push(code); return; }
    plan.push({b:b, target:target, kind:kind});
  });

  if(!plan.length){
    showToast('적용할 수 있는 타석을 찾지 못했습니다. 타석 코드를 확인해주세요.'+(notFound.length?(' ('+notFound.join(', ')+')'):''), 'warn');
    return;
  }

  // 2) 기존에 사용중이던 모든 타석/룸을 먼저 종료 처리(이용기록 보존) 후
  ssEndAllOccupied();

  // 3) 새로 인식된 정보를 적용
  var applied = 0;
  plan.forEach(function(p){
    var b = p.b, target = p.target, kind = p.kind;

    // 인식된 정보로 전체시간(분) 자동 계산: remaining → start~end 차이 → 기본 60분
    var dur = ssParseRemainingMinutes(b.remaining);
    if(dur === null) dur = ssDiffMinutes(b.start_time, b.end_time);
    if(dur === null || dur <= 0) dur = 60;
    var startMs = Date.now();

    // 이름/상태 설정 — 룸/타석, 레슨/사용중 구분없이 모두 시설이용(이용중)으로 등록
    target.status = 'occupied';
    target.name = b.name;
    target.type = '시설이용';
    target.startTime = startMs;
    target.dur = dur;
    applied++;
  });

  if(applied > 0){
    if(typeof saveState === 'function') saveState();
    if(typeof renderBays === 'function') renderBays();
    showToast(applied+'개 타석 시간 적용 완료'+(notFound.length?(' (인식 실패: '+notFound.join(', ')+')'):''), 'ok');
    closeScreenshotAnalyzer();
  } else {
    showToast('적용할 수 있는 타석을 찾지 못했습니다. 타석 코드를 확인해주세요.'+(notFound.length?(' ('+notFound.join(', ')+')'):''), 'warn');
  }
}
</script>

