// ─── 레슨 예약 시 휴무일/가능시간 체크 ───
// 헬퍼: 해당 날짜가 해당 프로에게 휴무인지 반환
function lsIsOffDay(proName, dateStr){
  var sch = lsProSchedules[proName];
  if(!sch) return false;
  // 특별 출근일이면 무조건 근무
  if((sch.workDates||[]).includes(dateStr)) return false;
  // 임시 휴무 날짜
  if((sch.offDates||[]).includes(dateStr)) return true;
  // 정기 휴무 요일
  var d = new Date(dateStr+'T00:00:00');
  if((sch.offDays||[]).includes(d.getDay())) return true;
  return false;
}

// 헬퍼: 요일별 workTimes에서 해당 날짜/시간이 가능한지 확인
function lsIsInWorkTime(sch, dateStr, startTime, endTime){
  var wt = sch && sch.workTimes;
  if(!wt || Array.isArray(wt)) return true; // 미설정 = 전체 가능
  var d = new Date(dateStr+'T00:00:00');
  var times = wt[d.getDay()];
  if(!times || !times.length) return true; // 해당 요일 미설정 = 전체 가능
  for(var i=0;i<times.length;i++){
    if(startTime>=times[i].start && endTime<=times[i].end) return true;
  }
  return false;
}

// ─── 스케줄 그리드 슬롯 배경색 헬퍼 ───
// (선언은 블록1에서, lsIsOffDay 실제 구현은 아래에서 덮어씀)

function lsIsBlockedBySchedule(proName, dateStr, startTime, endTime){
  var sch = lsProSchedules[proName];
  if(!sch) return null;
  var isWorkDate = (sch.workDates||[]).includes(dateStr);
  if(!isWorkDate){
    if((sch.offDates||[]).includes(dateStr)){
      return proName+'의 임시 휴무일('+fmtDateDow(dateStr)+')입니다. 레슨 예약이 불가합니다.';
    }
    var d = new Date(dateStr+'T00:00:00');
    if((sch.offDays||[]).includes(d.getDay())){
      return proName+'의 정기 휴무일('+DOW_KO[d.getDay()]+'요일)입니다.\n특별 출근일로 등록된 날짜가 아닙니다.';
    }
  }
  // 가능시간 체크
  if(startTime && endTime){
    if(!lsIsInWorkTime(sch, dateStr, startTime, endTime)){
      var d2 = new Date(dateStr+'T00:00:00');
      var times = (sch.workTimes||{})[d2.getDay()]||[];
      var ranges = times.length ? times.map(function(w){ return w.start+'~'+w.end; }).join(', ') : '없음';
      return proName+'의 '+DOW_KO[d2.getDay()]+'요일 레슨 가능 시간('+ranges+') 외입니다. 예약이 불가합니다.';
    }
  }
  return null;
}

