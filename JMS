/* 전화번호 뒷자리 → 회원번호 자동입력 (중복시 끝에 0,1,2... 붙이기) */
/* 전화번호 자동 하이픈 포맷 + 회원번호 자동입력 */
function mbPhonePart(inp, part){
  inp.value = inp.value.replace(/\D/g,'');
  // 자동 포커스 이동
  if(part===1 && inp.value.length===3){
    document.getElementById('mb-phone-2').focus();
  } else if(part===2 && inp.value.length===4){
    document.getElementById('mb-phone-3').focus();
  }
  mbAutoNum();
}

function mbGetPhone(){
  const p1=(document.getElementById('mb-phone-1')||{}).value||'010';
  const p2=(document.getElementById('mb-phone-2')||{}).value||'';
  const p3=(document.getElementById('mb-phone-3')||{}).value||'';
  if(!p2&&!p3) return '';
  return p1+'-'+p2+'-'+p3;
}

function mbAutoNum(){
  const p3=(document.getElementById('mb-phone-3')||{}).value||'';
  const numInp = document.getElementById('mb-num');
  if(!numInp) return;
  const tail = p3.replace(/\D/g,'').slice(-4);
  if(tail.length < 4) return;
  const used = members.filter(m=>mbEditId===null||m.id!==mbEditId).map(m=>(m.num||'').trim());
  let candidate = tail;
  if(used.includes(candidate)){
    let suffix = 0;
    while(used.includes(tail + suffix)) suffix++;
    candidate = tail + suffix;
  }
  numInp.value = candidate;
}

