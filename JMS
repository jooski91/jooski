/* ══════════════════════════════════════════
   레슨 블록 드래그 앤 드롭
══════════════════════════════════════════ */
(function(){
  var _drag = null;      // 드래그 중 상태
  var _drop = null;      // 현재 drop 후보 슬롯

  var MOVE_THRESHOLD = 6; // px - 이 이상 움직여야 드래그로 인식

  /* 고스트 공통 스타일 */
  function makeGhost(l, rect, col){
    var g = document.createElement('div');
    g.style.cssText = [
      'position:fixed','z-index:10000','pointer-events:none',
      'border-radius:8px','border-left:4px solid '+col,
      'background:rgba(26,95,160,.13)',
      'box-shadow:0 6px 20px rgba(0,0,0,.18)',
      'opacity:.92','padding:5px 10px',
      'font-size:12px','font-weight:700','color:'+col,
      'white-space:nowrap','overflow:hidden','text-overflow:ellipsis',
      'max-width:200px','min-width:100px',
      'left:'+rect.left+'px','top:'+rect.top+'px',
      'width:'+Math.max(rect.width,120)+'px',
      'transition:none'
    ].join(';');
    g.textContent = (l.student||'') + '  ' + l.start + '~' + l.end;
    return g;
  }

  /* 슬롯 하이라이트 클리어 */
  function clearDrop(){
    if(_drop && _drop._el){
      _drop._el.style.background = '';
      _drop._el.style.outline    = '';
    }
    _drop = null;
  }

  /* 이벤트 클린업 */
  function unbind(){
    document.removeEventListener('mousemove', onMove);
    document.removeEventListener('mouseup',   onUp);
    document.removeEventListener('touchmove', onTMove);
    document.removeEventListener('touchend',  onTUp);
  }

  /* 드래그 시작 */
  function startDrag(cx, cy, lessonId, block, srcEvent){
    var l = lsLessons.find(function(x){ return x.id === lessonId; });
    if(!l) return;
    if(l.status === 'attend' || l.status === 'absent') return;
    srcEvent.preventDefault();

    var rect = block.getBoundingClientRect();
    var col  = block.style.borderLeftColor || '#1a5fa0';
    var ghost = makeGhost(l, rect, col);
    document.body.appendChild(ghost);
    block.style.opacity = '0.3';

    _drag = {
      lessonId : lessonId,
      ghost    : ghost,
      block    : block,
      ox       : cx - rect.left,  // 클릭 오프셋
      oy       : cy - rect.top,
      startX   : cx,
      startY   : cy,
      dragging : false            // 실제 이동 시작 여부
    };

    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup',   onUp);
    document.addEventListener('touchmove', onTMove, {passive:false});
    document.addEventListener('touchend',  onTUp);
  }

  function onMove(e){ move(e.clientX, e.clientY); }
  function onTMove(e){ e.preventDefault(); move(e.touches[0].clientX, e.touches[0].clientY); }

  function move(cx, cy){
    if(!_drag) return;

    // threshold 넘으면 드래그 시작
    if(!_drag.dragging){
      var dx = cx - _drag.startX, dy = cy - _drag.startY;
      if(Math.sqrt(dx*dx+dy*dy) < MOVE_THRESHOLD) return;
      _drag.dragging = true;
    }

    // 고스트 이동
    _drag.ghost.style.left = (cx - _drag.ox) + 'px';
    _drag.ghost.style.top  = (cy - _drag.oy) + 'px';
    _drag.ghost.style.display = 'none';
    clearDrop();

    // 현재 커서 아래 요소 탐색
    var el = document.elementFromPoint(cx, cy);
    _drag.ghost.style.display = '';

    var slot = el ? el.closest('.ls-slot') : null;
    if(slot && slot.dataset.dk && slot.dataset.sl){
      slot.style.background = 'rgba(26,95,160,.18)';
      slot.style.outline    = '2px solid #1a5fa0';
      _drop = { dk:slot.dataset.dk, sl:slot.dataset.sl,
                pn:slot.dataset.pn||'', _el:slot };
    }
  }

  function onUp(e){ end(e.clientX, e.clientY); }
  function onTUp(e){ var t=e.changedTouches[0]; end(t.clientX,t.clientY); }

  function end(cx, cy){
    if(!_drag){ unbind(); return; }
    var d  = _drag;
    var dt = _drop;
    // 정리
    d.ghost.remove();
    d.block.style.opacity = '';
    clearDrop();
    _drag = null;
    unbind();

    // 드래그 거의 안 했으면 클릭으로 처리 (ctx 메뉴)
    if(!d.dragging || !dt) return;

    var l = lsLessons.find(function(x){ return x.id === d.lessonId; });
    if(!l) return;
    var newPn = dt.pn || l.instructor;
    if(dt.dk === l.date && dt.sl === l.start && newPn === l.instructor) return;
    showDragConfirm(l, dt.dk, dt.sl, newPn);
  }

  /* 변경 확인 모달 */
  function showDragConfirm(l, newDk, newSl, newPn){
    var dur  = l.duration || 30;
    var p    = newSl.split(':').map(Number);
    var eMin = p[0]*60 + p[1] + dur;
    var newEnd = String(Math.floor(eMin/60)).padStart(2,'0')+':'+String(eMin%60).padStart(2,'0');

    var modal = document.getElementById('ls-drag-confirm-ov');
    document.getElementById('ls-drag-student').textContent = l.student||'—';
    document.getElementById('ls-drag-from').textContent =
      (l.date||'') + '  ' + l.start+'~'+l.end +
      (l.instructor ? '  ('+l.instructor+')' : '');
    document.getElementById('ls-drag-to').textContent =
      newDk + '  ' + newSl+'~'+newEnd +
      (newPn ? '  ('+newPn+')' : '');

    document.getElementById('ls-drag-confirm-btn').onclick = function(){
      modal.style.display = 'none';
      l.date=newDk; l.start=newSl; l.end=newEnd;
      if(newPn) l.instructor=newPn;
      saveState(); lsRender();
      showToast('예약이 이동되었습니다','ok');
    };
    document.getElementById('ls-drag-cancel-btn').onclick = function(){
      modal.style.display='none';
    };
    modal.style.display='flex';
  }

  /* 블록에 드래그 바인딩 */
  function bindDrag(block, lessonId){
    block.style.cursor = 'grab';
    block.addEventListener('mousedown', function(e){
      if(e.button!==0) return;
      // stopPropagation 해서 슬롯 클릭(quickAdd) 막기
      e.stopPropagation();
      startDrag(e.clientX, e.clientY, lessonId, block, e);
    });
    block.addEventListener('touchstart', function(e){
      e.stopPropagation();
      startDrag(e.touches[0].clientX, e.touches[0].clientY, lessonId, block, e);
    }, {passive:false});
  }

  window.lsBindDrag = bindDrag;
})();

/* ══════════════════════════════════════════
