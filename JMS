  if(!m) return;
  document.getElementById('ci-mb-search').value=m.name;
  document.getElementById('ci-mb-dropdown').style.display='none';
  var selDiv=document.getElementById('ci-mb-selected');
  document.getElementById('ci-mb-sel-name').textContent=m.name+(m.phone?' · '+m.phone:'');
  selDiv.style.display='flex';
