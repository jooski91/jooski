/* ── 환불 저장 시 이전 상태 백업 ── */
var _mbdRefundSaleIdx = null;
function mbdRefundOpen(idx){
  var m = members.find(function(x){ return x.id===mbDetailId; });
  if(!m||!m.sales||!m.sales[idx]) return;
  _mbdRefundSaleIdx = idx;
  var s = m.sales[idx];
  var g = tkGroups.find(function(x){ return +x.id===+s.groupId; });
  var it = tkItems.find(function(x){ return +x.id===+s.itemId; });
  var tkName = (g&&it)?g.name+' / '+it.name:'—';
  document.getElementById('refund-tk-name').textContent = tkName;
  document.getElementById('refund-sale-price').textContent = Number(s.payAmount||0).toLocaleString()+'원';

  // 연결된 이용권
  var tk = m.tickets ? m.tickets.find(function(t){ return t.id===s.ticketId; }) : null;
  var tkIdx = tk ? m.tickets.indexOf(tk) : -1;
  var today = new Date().toISOString().slice(0,10);

  // 잔여횟수
  var remainCount = null;
  if(it&&it.count){
    var used = lsLessons.filter(function(l){
      if(l.memberId!==m.id) return false;
      if(tk&&l.ticketId===tk.id) return true;
      if(l.ticketIdx===tkIdx) return true;
      return false;
    }).filter(function(l){ return l.status==='attend'||l.status==='absent'; }).length;
    remainCount = Math.max(0, it.count - used);
    document.getElementById('refund-remain-count').textContent = remainCount+' / '+it.count+'회';
  } else {
    document.getElementById('refund-remain-count').textContent = '—';
  }

  // 잔여일수
  var remainDays = null;
  var resolvedEnd = tk ? (tk.endDate||'') : '';
  if(!resolvedEnd&&tk&&tk.startDate&&it&&g) try{ resolvedEnd=_calcEndDate(tk.startDate,it.days,it.validDays,g.cat); }catch(e){}
  if(resolvedEnd){
    var td=new Date(today); var ed=new Date(resolvedEnd);
    remainDays = Math.max(0, Math.round((ed-td)/(1000*60*60*24)));
    document.getElementById('refund-remain-days').textContent = remainDays+'일';
  } else {
    document.getElementById('refund-remain-days').textContent = '—';
  }

  // 기준 환불금액 계산 (잔여비율)
  var base = s.payAmount||0;
  var baseRefund = base;
  if(remainCount!==null && it&&it.count&&it.count>0){
    baseRefund = Math.round(base * remainCount / it.count);
  } else if(remainDays!==null && it&&it.days&&it.days>0){
    baseRefund = Math.round(base * remainDays / it.days);
  }
  document.getElementById('refund-base-amount').textContent = baseRefund.toLocaleString()+'원';
  document.getElementById('refund-penalty').value = '0';
  document.getElementById('refund-reason').value = '';
  document.getElementById('refund-final-amount').textContent = baseRefund.toLocaleString()+'원';
  document.getElementById('refund-ov')._baseRefund = baseRefund;
  document.getElementById('refund-ov').style.display = 'flex';
}

function mbdRefundCalc(){
  var base = document.getElementById('refund-ov')._baseRefund || 0;
  var penalty = parseInt(document.getElementById('refund-penalty').value)||0;
  var final = Math.max(0, base - penalty);
  document.getElementById('refund-final-amount').textContent = final.toLocaleString()+'원';
}

function mbdRefundSave(){
  var m = members.find(function(x){ return x.id===mbDetailId; });
  if(!m||_mbdRefundSaleIdx===null) return;
  var s = m.sales[_mbdRefundSaleIdx];
  if(!s) return;
  var base = document.getElementById('refund-ov')._baseRefund || 0;
  var penalty = parseInt(document.getElementById('refund-penalty').value)||0;
  var final = Math.max(0, base - penalty);
  var reason = document.getElementById('refund-reason').value;
  if(!confirm('환불금액 '+final.toLocaleString()+'원으로 환불 처리하시겠습니까?')) return;
  s._prevSaleStatus = s.saleStatus; // 환불 취소 시 복원용
  s.saleStatus = '환불';
  s.refundAmount = final;
  s.refundPenalty = penalty;
  s.refundReason = reason;
  s.refundAt = Date.now();
  s.unpaid = 0;

  // 연결된 이용권 만료 처리
  var _tk = m.tickets ? m.tickets.find(function(t){ return t.id === s.ticketId; }) : null;
  var _tkIdx = _tk ? m.tickets.indexOf(_tk) : -1;
  if(_tk){
    var _today = new Date().toISOString().slice(0,10);
    _tk.refunded = true;
    _tk.refundedAt = _today;
    if(!_tk.endDate || _tk.endDate > _today){
      _tk._origEndDate = _tk.endDate;
      _tk.endDate = _today;
    }
  }

  // 미완료 예약 레슨 삭제 (출석/결석은 유지), 삭제 건수 기록
  var canceledCount = 0;
  if(_tk){
    // 삭제 전 예약 레슨 목록 백업 (환불취소 복원용)
    s._canceledLessons = lsLessons.filter(function(l){
      if(l.memberId !== m.id) return false;
      if(_tk.id && l.ticketId === _tk.id) return true;
      if(_tkIdx >= 0 && l.ticketIdx === _tkIdx) return true;
      return false;
    }).filter(function(l){ return !l.status; }); // 미처리만

    canceledCount = s._canceledLessons.length;

    lsLessons = lsLessons.filter(function(l){
      if(l.memberId !== m.id) return true;
      var linked = (_tk.id && l.ticketId === _tk.id) || (_tkIdx >= 0 && l.ticketIdx === _tkIdx);
      if(!linked) return true;
      return !!l.status; // 출석/결석은 유지, 빈 값(예약)은 삭제
    });
  }

  // 환불금액만큼 포인트 차감
  if(final > 0 && m.points){
    var deductPt = Math.floor(final * 0.02); // 환불금액의 2% 차감 (적립된 포인트 비율)
    if(deductPt > 0){
      m.points = Math.max(0, m.points - deductPt);
      if(!m.pointHistory) m.pointHistory = [];
      m.pointHistory.push({
        type: 'deduct',
        amount: deductPt,
        reason: '환불 처리 포인트 차감 (환불금액 '+final.toLocaleString()+'원)',
        balanceAfter: m.points,
        createdAt: Date.now()
      });
    }
  }

  saveState();
  lsRender();
  document.getElementById('refund-ov').style.display = 'none';
  mbdRenderSales();
  mbdRenderTickets();
  mbdRenderHome();
  mbdRenderRefundHistory();
  mbdRenderExpiredTickets();
  mbdRenderPointHistory();
  // 변경내역 기록
  var _rfTkName = tkLogNameById(s.groupId, s.itemId);
  tkChangeLogPush(mbDetailId, '환불', _rfTkName,
    '환불금액 '+final.toLocaleString()+'원'+(penalty>0?' (위약금 '+penalty.toLocaleString()+'원)':''),
    reason || '');
  showToast('환불 완료 · 예약 '+canceledCount+'건 삭제 · 이용권 만료', 'ok');
}



/* ── 날짜 + 요일 표시 헬퍼 ── */
var _DAY_KO = ['일','월','화','수','목','금','토'];
function fmtDateDow(dateStr){
  // dateStr: 'YYYY-MM-DD' or 'YYYY.MM.DD'
  if(!dateStr || dateStr==='—') return dateStr||'—';
  var s = dateStr.replace(/\./g,'-');
  var d = new Date(s+'T00:00:00');
  if(isNaN(d)) return dateStr;
  var mo = (d.getMonth()+1);
  var da = d.getDate();
  var dow = _DAY_KO[d.getDay()];
  return mo+'/'+da+'('+dow+')';
}
function fmtDateFullDow(dateStr){
  // returns 'YYYY.MM.DD(요일)'
  if(!dateStr || dateStr==='—') return dateStr||'—';
  var s = dateStr.replace(/\./g,'-');
  var d = new Date(s+'T00:00:00');
  if(isNaN(d)) return dateStr;
  var yy = d.getFullYear();
  var mo = (d.getMonth()+1).toString().padStart(2,'0');
  var da = d.getDate().toString().padStart(2,'0');
  var dow = _DAY_KO[d.getDay()];
  return yy+'.'+mo+'.'+da+'('+dow+')';
}
function fmtDateDotDow(dateStr){
  // returns 'M/D(요일)' from 'YYYY-MM-DD'
  return fmtDateDow(dateStr);
}

