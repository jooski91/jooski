function lsDrawTimeLine(){
  // 오늘이 아니면 제거
  const showLine = isToday(lsCurrentDate());

  // 헤더 행 높이 측정 (sticky header offset)
  function getHeaderH(container){
    var hdr = container ? container.querySelector('.ls-gh') : null;
    return hdr ? hdr.offsetHeight : 0;
  }

  // all-view 그리드
  const grid = document.getElementById('ls-grid');
  if(grid){
    let line = grid.querySelector('.ls-now-line');
    if(!showLine){ if(line) line.remove(); }
    else {
      const now = new Date();
      const h = now.getHours(), m = now.getMinutes();
      if(h >= LS_START_H && h < LS_END_H){
        const headerH = getHeaderH(grid);
        const topPx = headerH + (h - LS_START_H) * 2 * SLOT_H + (m / 60) * 2 * SLOT_H;
        if(!line){
          line = document.createElement('div');
          line.className = 'ls-now-line';
          line.style.cssText = 'position:absolute;left:0;right:0;height:2px;background:rgba(229,62,62,0.45);z-index:50;pointer-events:none';
          line.innerHTML = '';
          grid.style.position = 'relative';
          grid.appendChild(line);
        }
        line.style.top = topPx + 'px';
      } else {
        if(line) line.remove();
      }
    }
  }

  // pro-view 그리드
  const inner = document.getElementById('ls-pro-inner');
  if(inner){
    let line2 = inner.querySelector('.ls-now-line');
    if(!showLine){ if(line2) line2.remove(); }
    else {
      const now = new Date();
      const h = now.getHours(), m = now.getMinutes();
      if(h >= LS_START_H && h < LS_END_H){
        const headerH = getHeaderH(inner);
        const topPx = headerH + (h - LS_START_H) * 2 * SLOT_H + (m / 60) * 2 * SLOT_H;
        if(!line2){
          line2 = document.createElement('div');
          line2.className = 'ls-now-line';
          line2.style.cssText = 'position:absolute;left:0;right:0;height:2px;background:rgba(229,62,62,0.45);z-index:50;pointer-events:none';
          line2.innerHTML = '';
          inner.style.position = 'relative';
          inner.appendChild(line2);
        }
        line2.style.top = topPx + 'px';
      } else {
        if(line2) line2.remove();
      }
    }
  }
}

// 1분마다 시간선 갱신
setInterval(lsDrawTimeLine, 60000);

function renderAllView(d){
  const key=lsDateKey(d);
  const slots=lsTimeSlots();
  const cols=lsPros.length||1;
  const grid=document.getElementById('ls-grid');
  grid.style.gridTemplateColumns=`50px repeat(${cols},1fr)`;

  if(!lsPros.length){
    grid.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:40px;color:#ccc;font-size:13px">👤 프로를 먼저 추가해주세요</div>';
    return;
  }

  // Header
  let html='<div class="ls-gh time-h" style="grid-row:1;border-right:2px solid #e0e0e0">시간</div>';
  lsPros.forEach((p,i)=>{
    const col=lsProColor(i);
    const isBlocked = _lsAllowedPro && p.name !== _lsAllowedPro;
    html+=`<div class="ls-gh" style="grid-row:1;${isBlocked?'opacity:.35;':''}cursor:pointer;transition:background .12s" onclick="lsJumpToPro(${i})" title="${esc(p.name)} 프로별 뷰로 이동" onmouseover="this.style.background='#e8f0fb'" onmouseout="this.style.background=''">${esc(p.name)}${_lsAllowedPro&&!isBlocked?'<span style="display:block;font-size:9px;font-weight:700;color:#1a8a5e;margin-top:1px">담당 프로</span>':''}</div>`;
  });

  // Rows
  const todayLessons=lsLessons.filter(l=>l.date===key);
  slots.forEach((slot,si)=>{
    const ht=slot.isHour?'hour-top':'half-top';
    // time
    html+=`<div class="ls-time-cell ${ht} ${slot.isHour?'':'is-half'}" style="height:${SLOT_H}px">${slot.isHour?slot.label:''}</div>`;
    // pro slots
    lsPros.forEach((p,pi)=>{
      const isBlocked = _lsAllowedPro && p.name !== _lsAllowedPro;
      const otherBlocked = lsIsBlockedByOther(p.name, key, slot.label);
      const state = isBlocked ? 'normal' : lsGetSlotState(p.name, key, slot.label);
      const bgStyle = otherBlocked
        ? 'background:#ebebeb;cursor:not-allowed;'
        : lsSlotBg(state, isBlocked);
      const onclickAll = (isBlocked || otherBlocked) ? '' : `quickAdd(this.dataset.dk,this.dataset.sl,this.dataset.pn)`;
      html+=`<div class="ls-slot ${ht}" style="height:${SLOT_H}px;${bgStyle}" onclick="${onclickAll}" data-dk="${key}" data-sl="${slot.label}" data-pn="${esc(p.name)}" data-si="${si}" data-pi="${pi}"></div>`;
    });
  });

  // 마감 행 (23:00 표시)
  html+=`<div class="ls-time-cell hour-top" style="height:${SLOT_H}px;border-top:2px solid #e0e0e0">23:00</div>`;
  lsPros.forEach(()=>{
    html+=`<div class="ls-slot hour-top" style="height:${SLOT_H}px;background:#f7f7f7;cursor:default;border-top:2px solid #e0e0e0;pointer-events:none"></div>`;
  });
  // 하단 여백 행 (세로선 없음)
  html+=`<div style="grid-column:1/-1;height:48px;background:#f2f3f6;border-top:1px solid #e0e0e0"></div>`;
  grid.innerHTML=html;

  // Overlay blocks
  todayLessons.forEach(l=>{
    const pi=lsPros.findIndex(p=>p.name===l.instructor);
    if(pi<0)return;
