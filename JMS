function closeLessonModal(){
  document.getElementById('lesson-ov').classList.remove('show');
  document.getElementById('ls-student-dropdown').style.display='none';
}
function saveLessonModal(){
  const instructor=document.getElementById('ls-instructor').value;
  const student=(document.getElementById('ls-student').value||document.getElementById('ls-student-search').value).trim();
  const date=document.getElementById('ls-date').value;
  const start=document.getElementById('ls-start').value;
  const duration=parseInt(document.getElementById('ls-duration').value)||30;
  const end=calcEndTime(start,duration);
  const bay=document.getElementById('ls-bay').value;
  const memo=document.getElementById('ls-memo').value.trim();
  const memberIdStr=document.getElementById('ls-selected-member-id').value;
  const memberId=memberIdStr?+memberIdStr:null;
  if(!instructor){alert('프로를 선택하세요.');return;}
  if(!student){alert('회원명을 입력하세요.');return;}
  // DB 없는 직접 입력 회원은 예약 불가
  var memberIdStr2=document.getElementById('ls-selected-member-id').value;
  if(!memberIdStr2){
    alert('회원명을 먼저 선택해주세요.');
    return;
  }
  if(!date){alert('날짜를 선택하세요.');return;}
  // 회원 연결 + 레슨 이용권 있는 경우 이용권 선택 필수
  if(memberId){
    const m=members.find(x=>x.id===memberId);
    if(m){
      const tkList=lsGetMemberLessonTickets(m, instructor);
      if(tkList.length===0){
        alert('해당 프로의 레슨 이용권이 없습니다.');
        return;
      }
      if(_lsSelectedTicketIdx===null){
        alert('이용권을 선택해주세요.');
        return;
      }
    }
  }
  const obj={instructor,student,date,start,end,duration,bay,memo,memberId,ticketIdx:_lsSelectedTicketIdx};
  // ── 중복 체크 (편집 중인 레슨 자신은 제외) ──
  if(lsHasOverlap(instructor, date, start, end, lsEditId)){
    alert(instructor+' 강사의 '+date+' '+start+'~'+end+' 시간에 이미 예약된 레슨이 있습니다.');
    return;
  }
  if(lsEditId){
    const idx=lsLessons.findIndex(l=>l.id===lsEditId);
    if(idx>=0) lsLessons[idx]={...lsLessons[idx],...obj};
  }else{
    lsLessons.push({id:lsLessonId++,...obj});
  }
  closeLessonModal(); lsRender(); saveState();
  // 회원 상세 열려있으면 이용권 탭 갱신
  if(mbDetailId) mbdRenderTickets();
}
function deleteLessonModal(){
  lsLessons=lsLessons.filter(l=>l.id!==lsEditId);
  closeLessonModal(); lsRender(); saveState();
  if(mbDetailId) mbdRenderTickets();
}

