function ciOpenModal(){
  _ciKpNum=''; _ciKpMemberId=null; _ciKpSelections=[];
  ciKpShowStep(1);
  ciKpUpdateDisplay();
  document.getElementById('ci-kp-err').textContent='';
  document.getElementById('ci-kp-hint').textContent='';
  document.getElementById('ci-kp-ov').style.display='flex';
  document.addEventListener('keydown', _ciKpKeyHandler);
}
function ciCloseModal(){ ciKpClose(); }
function ciKpClose(){
  document.getElementById('ci-kp-ov').style.display='none';
  document.removeEventListener('keydown', _ciKpKeyHandler);
}
function _ciKpKeyHandler(e){
  var ov = document.getElementById('ci-kp-ov');
  if(!ov || ov.style.display==='none') return;
  // step1만 키보드 처리
  var step1 = document.getElementById('ci-kp-step1');
  if(!step1 || !step1.classList.contains('active')) return;
  if(e.key>='0' && e.key<='9'){ e.preventDefault(); ciKpPress(e.key); }
  else if(e.key==='Backspace'){ e.preventDefault(); ciKpDel(); }
  else if(e.key==='Enter'){ e.preventDefault(); ciKpConfirm(); }
  else if(e.key==='Escape'){ e.preventDefault(); ciKpClose(); }
}
function ciKpBack(){
  _ciKpMemberId=null; _ciKpSelections=[];
  ciKpShowStep(1);
  document.getElementById('ci-kp-err').textContent='';
}
function ciKpShowStep(n){
  document.getElementById('ci-kp-step1').classList.toggle('active', n===1);
  document.getElementById('ci-kp-step2').classList.toggle('active', n===2);
}
function ciKpPress(d){
  if(_ciKpNum.length>=8) return;
  _ciKpNum += d;
  ciKpUpdateDisplay();
  ciKpTryMatch();
}
function ciKpDel(){
  if(!_ciKpNum.length) return;
  _ciKpNum = _ciKpNum.slice(0,-1);
  ciKpUpdateDisplay();
  document.getElementById('ci-kp-err').textContent='';
  document.getElementById('ci-kp-hint').textContent='';
  document.getElementById('ci-kp-enter-btn').disabled = _ciKpNum.length===0;
  ciKpTryMatch();
}
function ciKpReset(){
  _ciKpNum='';
  ciKpUpdateDisplay();
  document.getElementById('ci-kp-err').textContent='';
  document.getElementById('ci-kp-hint').textContent='';
  document.getElementById('ci-kp-enter-btn').disabled=true;
}
function ciKpUpdateDisplay(){
  var el = document.getElementById('ci-kp-numtxt');
  if(el) el.textContent = _ciKpNum || '';
  var enterBtn = document.getElementById('ci-kp-enter-btn');
  if(enterBtn) enterBtn.disabled = _ciKpNum.length===0;
}
function ciKpTryMatch(){
  var matches = members.filter(function(m){ return (m.num||'')===_ciKpNum; });
  var hintEl = document.getElementById('ci-kp-hint');
  var errEl  = document.getElementById('ci-kp-err');
  if(matches.length===1){
    if(hintEl) hintEl.textContent = matches[0].name+' 님 확인됨';
    if(errEl)  errEl.textContent='';
  } else {
    if(hintEl) hintEl.textContent='';
  }
}
function ciKpEnter(){
  if(!_ciKpNum) return;
  var matches = members.filter(function(m){ return (m.num||'')===_ciKpNum; });
  var errEl = document.getElementById('ci-kp-err');
  if(!matches.length){ errEl.textContent='일치하는 회원번호가 없습니다.'; return; }
  if(matches.length>1){ errEl.textContent='동일 회원번호가 여러 명 있습니다. 관리자에게 문의하세요.'; return; }
  _ciKpMemberId = matches[0].id;
  errEl.textContent='';
  ciKpShowMemberStep(matches[0]);
}

/* ── STEP2: 회원 + 이용권 다중선택 ── */
function ciKpShowMemberStep(m){
  var colors=['#1a5fa0','#0d9488','#7c3aed','#be185d','#b45309','#0369a1'];
  var col=colors[(m.name.charCodeAt(0)||0)%colors.length];
  var av=document.getElementById('ci-kp-avatar');
  av.textContent=m.name.charAt(0); av.style.background=col;
  document.getElementById('ci-kp-mname').textContent=m.name;
  document.getElementById('ci-kp-mmeta').textContent=(m.branch||'동대구센터')+(m.phone?' · '+m.phone:'');

  var today=ciTodayStr();
  var allTks=(m.tickets||[]).map(function(tk,i){return{tk:tk,idx:i};})
    .filter(function(o){ return !o.tk.refunded && (!o.tk.endDate||o.tk.endDate>=today); });

  var tkList=document.getElementById('ci-kp-tk-list');
  if(!allTks.length){
    tkList.innerHTML='<div style="font-size:12px;color:#f59e0b;padding:10px 0;text-align:center">유효한 이용권이 없습니다</div>';
    _ciKpSelections=[];
  } else {
    tkList.innerHTML=allTks.map(function(o){
      var g=tkGroups.find(function(x){return +x.id===+o.tk.groupId;});
      var it=tkItems.find(function(x){return +x.id===+o.tk.itemId;});
      var gName=g?g.name:'이용권';
      var meta=tkCatMeta(g?g.cat:'');
      var bc=(meta.badgeCls||'#eee:#666').split(':');
      var isLesson=(meta.group==='레슨');
      var isFacCount=g&&g.cat==='연습장-횟수';

      // 잔여횟수 계산
      var remainHtml='';
      if((isLesson||isFacCount) && it && it.count){
        var usedC=lsLessons.filter(function(l){
          if(l.memberId!==m.id) return false;
          if(o.tk.id && l.ticketId===o.tk.id) return true;
          if(l.ticketIdx===o.idx) return true;
          return false;
        }).filter(function(l){return l.status==='attend'||l.status==='absent';}).length;
        var remC=Math.max(0,it.count-usedC);
        var remColor=remC===0?'#dc2626':remC<=3?'#d97706':'#16a34a';
        var remBg=remC===0?'#fee2e2':remC<=3?'#fef3c7':'#f0fdf4';
        remainHtml='<span style="font-size:10px;font-weight:700;padding:2px 7px;border-radius:5px;background:'+remBg+';color:'+remColor+'">잔여 '+remC+'/'+it.count+'회</span>';
      }

      // 유효기간 표시
      var today=ciTodayStr();
      var expHtml='';
      if(o.tk.endDate){
        var daysLeft=Math.round((new Date(o.tk.endDate)-new Date(today))/(1000*60*60*24));
        var expColor=daysLeft<=7?'#dc2626':daysLeft<=30?'#d97706':'#6b7280';
        expHtml='<span style="font-size:9px;color:'+expColor+';white-space:nowrap">'+(daysLeft<0?'만료':daysLeft===0?'오늘만료':daysLeft+'일후만료')+'</span>';
      }

      var proHtml = (isLesson && o.tk.pro) ? '<span style="font-size:10px;color:#6b7280">👤 '+esc(mbGetProName(o.tk.pro))+'</span>' : '';
      return '<div class="ci-kp-tk" id="ci-kp-tk-'+o.idx+'" onclick="ciKpToggleTk('+m.id+','+o.idx+','+isLesson+')">'+
        '<div style="display:flex;align-items:center;gap:6px;flex:1;min-width:0">'+
          '<span class="ci-kp-tk-badge" style="background:'+bc[0]+';color:'+bc[1]+'">'+meta.badge+'</span>'+
          '<div style="display:flex;flex-direction:column;gap:1px">'+
            '<span class="ci-kp-tk-name">'+esc(gName)+'</span>'+
            proHtml+
          '</div>'+
        '</div>'+
        '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:2px;flex-shrink:0">'+
          (remainHtml||'')+
          '<span class="ci-kp-tk-exp">'+(o.tk.endDate?'~'+o.tk.endDate:'기간 무제한')+'</span>'+
          expHtml+
        '</div>'+
        '<div class="ci-kp-tk-check" style="margin-left:6px"><svg width="10" height="10" viewBox="0 0 10 10"><polyline points="1.5,5 4,7.5 8.5,2.5" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>'+
      '</div>';
    }).join('');
    // 자동 선택 없음 - 사용자가 직접 선택
    _ciKpSelections=[];
    setTimeout(function(){ ciKpRenderSelections(m); },0);
  }
  ciKpShowStep(2);
  ciKpUpdateConfirmBtn();
}

function ciKpToggleTk(memberId, idx, isLesson){
  var m=members.find(function(x){return x.id===memberId;});
  var existing=_ciKpSelections.findIndex(function(s){return s.ticketIdx===idx;});
  if(existing>=0){
    // 이미 선택 → 해제 (단, 마지막 1개는 해제 안 함)
    if(_ciKpSelections.length<=1){ return; }
    _ciKpSelections.splice(existing,1);
  } else {
    _ciKpSelections.push({ticketIdx:idx, type:isLesson?'lesson':'facility', lessonId:null});
  }
  if(m) ciKpRenderSelections(m);
  ciKpUpdateConfirmBtn();
}

function ciKpRenderSelections(m){
  // 이용권 카드 선택 하이라이트
  document.querySelectorAll('.ci-kp-tk').forEach(function(el){
    var elIdx=+el.id.replace('ci-kp-tk-','');
    var isSel=_ciKpSelections.some(function(s){return s.ticketIdx===elIdx;});
    el.classList.toggle('selected', isSel);
  });
  var lessonSels=_ciKpSelections.filter(function(s){return s.type==='lesson';});
  var facSels=_ciKpSelections.filter(function(s){return s.type==='facility';});
  var lw=document.getElementById('ci-kp-ls-wrap');
  if(!lessonSels.length){ lw.style.display='none'; return; }

  var dateStr=ciTodayStr();
  var todayLess=lsLessons.filter(function(l){ return +l.memberId===+m.id && l.date===dateStr && l.start && l.end && l.start!==l.end; });

  // 레슨 스케줄 목록 - 예약 없으면 섹션 자체 숨김
  var ll=document.getElementById('ci-kp-ls-list');
  if(!todayLess.length){
    lw.style.display='none';
  } else {
  lw.style.display='';
    ll.innerHTML=todayLess.map(function(l){
      var linkedSel=_ciKpSelections.find(function(s){return s.lessonId===l.id;});
      var isSel=!!linkedSel;
      var attended=l.status==='attend';
      return '<div class="ci-kp-ls'+(isSel?' selected':'')+'" id="ci-kp-ls-'+l.id+'" onclick="ciKpToggleLesson('+l.id+')">'+
        '<span style="font-size:14px">'+(attended?'✅':'📅')+'</span>'+
        '<span style="font-size:12px;font-weight:700;color:#111;flex:1">'+l.start+'~'+l.end+'</span>'+
        '<span style="font-size:11px;color:#888">'+esc(l.instructor)+'</span>'+
        (attended?'<span style="font-size:9px;background:#dcfce7;color:#166534;padding:1px 5px;border-radius:4px;font-weight:700">출석</span>':'')+
        '<div class="ci-kp-tk-check"><svg width="10" height="10" viewBox="0 0 10 10"><polyline points="1.5,5 4,7.5 8.5,2.5" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>'+
      '</div>';
    }).join('');
  }

  // 시설 동시 체크인 섹션 - 레슨 이용권만 선택된 경우 시설이용권도 있으면 표시
  var afw=document.getElementById('ci-kp-also-fac-wrap');
  var afl=document.getElementById('ci-kp-also-fac-list');
  var today=ciTodayStr();
  var allTks=(m.tickets||[]).map(function(tk,i){return{tk:tk,idx:i};})
    .filter(function(o){ return !o.tk.refunded && (!o.tk.endDate||o.tk.endDate>=today); });
  var facTks=allTks.filter(function(o){
    var g=tkGroups.find(function(x){return +x.id===+o.tk.groupId;});
    var meta=tkCatMeta(g?g.cat:'');
    return meta.group!=='레슨';
  });
  // 레슨만 선택됐고 시설이용권이 있으면 동시체크인 옵션 표시
  if(facTks.length && !facSels.length){
    afw.style.display='';
    afl.innerHTML=facTks.map(function(o){
      var g=tkGroups.find(function(x){return +x.id===+o.tk.groupId;});
      var it=tkItems.find(function(x){return +x.id===+o.tk.itemId;});
      var gName=g?g.name:'시설이용권';
      var meta=tkCatMeta(g?g.cat:'');
      var bc=(meta.badgeCls||'#eee:#666').split(':');
      var isAlsoSel=_ciKpSelections.some(function(s){return s.ticketIdx===o.idx;});
      return '<div class="ci-kp-also-fac'+(isAlsoSel?' selected':'')+'" id="ci-kp-also-fac-'+o.idx+'" onclick="ciKpToggleAlsoFac('+m.id+','+o.idx+')">'+
        '<span style="font-size:18px">🏌️</span>'+
        '<span class="ci-kp-tk-badge" style="background:'+bc[0]+';color:'+bc[1]+'">'+meta.badge+'</span>'+
        '<span class="ci-kp-tk-name">'+esc(gName)+'</span>'+
        '<span style="font-size:10px;color:#10b981;font-weight:700">'+(isAlsoSel?'함께 체크인':'터치하여 추가')+'</span>'+
        '<div class="ci-kp-tk-check"><svg width="10" height="10" viewBox="0 0 10 10"><polyline points="1.5,5 4,7.5 8.5,2.5" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>'+
      '</div>';
    }).join('');
  } else if(facSels.length) {
    // 시설이용권이 이미 선택된 경우도 표시 유지
    afw.style.display='';
    afl.innerHTML=facTks.map(function(o){
      var g=tkGroups.find(function(x){return +x.id===+o.tk.groupId;});
      var it=tkItems.find(function(x){return +x.id===+o.tk.itemId;});
      var gName=g?g.name:'시설이용권';
      var meta=tkCatMeta(g?g.cat:'');
      var bc=(meta.badgeCls||'#eee:#666').split(':');
      var isAlsoSel=_ciKpSelections.some(function(s){return s.ticketIdx===o.idx;});
      return '<div class="ci-kp-also-fac'+(isAlsoSel?' selected':'')+'" id="ci-kp-also-fac-'+o.idx+'" onclick="ciKpToggleAlsoFac('+m.id+','+o.idx+')">'+
        '<span style="font-size:18px">🏌️</span>'+
        '<span class="ci-kp-tk-badge" style="background:'+bc[0]+';color:'+bc[1]+'">'+meta.badge+'</span>'+
        '<span class="ci-kp-tk-name">'+esc(gName)+'</span>'+
        '<span style="font-size:10px;color:#10b981;font-weight:700">'+(isAlsoSel?'함께 체크인':'터치하여 추가')+'</span>'+
        '<div class="ci-kp-tk-check"><svg width="10" height="10" viewBox="0 0 10 10"><polyline points="1.5,5 4,7.5 8.5,2.5" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>'+
      '</div>';
    }).join('');
  } else {
    afw.style.display='none';
  }
}

function ciKpToggleAlsoFac(memberId, idx){
  var m=members.find(function(x){return x.id===memberId;});
  var existing=_ciKpSelections.findIndex(function(s){return s.ticketIdx===idx;});
  if(existing>=0){
    _ciKpSelections.splice(existing,1);
  } else {
    _ciKpSelections.push({ticketIdx:idx, type:'facility', lessonId:null});
  }
  if(m) ciKpRenderSelections(m);
  ciKpUpdateConfirmBtn();
}

function ciKpToggleLesson(lid){
  // 레슨 선택들 중 첫 번째 미연결 레슨 이용권에 연결 / 이미 연결됐으면 해제
  var linkedIdx=_ciKpSelections.findIndex(function(s){return s.lessonId===lid;});
  if(linkedIdx>=0){
    _ciKpSelections[linkedIdx].lessonId=null;
  } else {
    // 미연결 레슨 이용권 찾기
    var freeIdx=_ciKpSelections.findIndex(function(s){return s.type==='lesson' && !s.lessonId;});
    if(freeIdx>=0) _ciKpSelections[freeIdx].lessonId=lid;
  }
  var m=members.find(function(x){return x.id===_ciKpMemberId;});
  if(m) ciKpRenderSelections(m);
}

function ciKpUpdateConfirmBtn(){
  var btn=document.getElementById('ci-kp-confirm-btn');
  if(!btn) return;
  var cnt=_ciKpSelections.length;
  btn.textContent = cnt>1 ? '✅ 체크인 ('+cnt+'건)' : '✅ 체크인';
  btn.disabled = cnt===0;
}

function ciKpConfirm(){
  if(!_ciKpMemberId){ showToast('회원을 확인해주세요','warn'); return; }
  if(!_ciKpSelections.length){ showToast('이용권을 선택해주세요','warn'); return; }
  var m=members.find(function(x){return x.id===_ciKpMemberId;});
  if(!m){ showToast('회원을 찾을 수 없습니다','warn'); return; }
  var now=new Date();
  var _rm=now.getMinutes(),_rr=Math.round(_rm/10)*10,_rh=now.getHours()+(_rr===60?1:0);_rr=_rr===60?0:_rr;
  var timeStr=(_rh+'').padStart(2,'0')+':'+(_rr+'').padStart(2,'0');
  var dateStr=ciOffsetDate(ciDateOffset);
  var stateChanged=false;

  // ── 사전 검증 ──
  for(var vi=0; vi<_ciKpSelections.length; vi++){
    var sel=_ciKpSelections[vi];
    var tk=m.tickets && m.tickets[sel.ticketIdx];
    var g=tk ? tkGroups.find(function(x){return +x.id===+tk.groupId;}) : null;
    var meta=g ? tkCatMeta(g.cat) : null;
    var isLesson=meta ? meta.group==='레슨' : (sel.type==='lesson');

    if(isLesson){
      // 레슨 이용권: 당일 예약 레슨 없으면 거절 처리
      if(!sel.lessonId){
        var dateStr2=ciOffsetDate(ciDateOffset);
        var now2=new Date();
        var _rm2=now2.getMinutes(),_rr2=Math.round(_rm2/10)*10,_rh2=now2.getHours()+(_rr2===60?1:0);_rr2=_rr2===60?0:_rr2;
        var timeStr2=(_rh2+'').padStart(2,'0')+':'+(_rr2+'').padStart(2,'0');
        ciCheckins.push({
          id: ciNextId++, date: dateStr2, time: timeStr2,
          memberId: _ciKpMemberId, memberName: m.name,
          type: 'lesson', ticketIdx: sel.ticketIdx, lessonId: null,
          memo: '', status: 'rejected', checkedAt: now2.getTime()
        });
        ciSave(); ciKpClose();
        ciSelMemberId=_ciKpMemberId; ciRender();
        var tkName=g ? g.name : '레슨 이용권';
        ciNotify('⛔ 입장 거절', m.name+' 님 — '+tkName+' 예약 레슨 없음');
        showToast(m.name+' 님 — 예약된 레슨 없음. 거절 처리됨','warn');
        return;
      }
      var ls=lsLessons.find(function(x){return x.id===sel.lessonId;});
      if(!ls){
        showToast('레슨 스케줄을 찾을 수 없습니다.','warn');
        return;
      }
    } else if(meta && meta.group==='연습장' && g.cat==='연습장-횟수'){
      // 시설 횟수권: 잔여횟수 체크
      var it=tkItems.find(function(x){return +x.id===+tk.itemId;});
      if(it && it.count){
        var used=lsLessons.filter(function(l){
          if(l.memberId!==m.id) return false;
          if(tk.id && l.ticketId===tk.id) return true;
          if(l.ticketIdx===sel.ticketIdx) return true;
          return false;
        }).filter(function(l){return l.status==='attend'||l.status==='absent';}).length;
        var remain=Math.max(0, it.count - used);
        if(remain<=0){
          var tkName2=g ? g.name : '시설 이용권';
          showToast('['+tkName2+'] 잔여 횟수가 없습니다.','warn');
          return;
        }
      }
    }
  }

  // ── 처리 ──
  _ciKpSelections.forEach(function(sel){
    var tk=m.tickets && m.tickets[sel.ticketIdx];
    var g=tk ? tkGroups.find(function(x){return +x.id===+tk.groupId;}) : null;
    var meta=g ? tkCatMeta(g.cat) : null;
    var isLesson=meta ? meta.group==='레슨' : (sel.type==='lesson');
    var isFacilityCount=meta && g.cat==='연습장-횟수';

    if(isLesson && sel.lessonId){
      // 레슨: 예약 레슨 출석 처리
      var ls=lsLessons.find(function(x){return x.id===sel.lessonId;});
      if(ls && ls.status!=='attend'){
        ls.status='attend';
        stateChanged=true;
      }
    } else if(isFacilityCount){
      // 시설 횟수권: lsLessons에 출석 레코드 추가 → 횟수 차감
      lsLessons.push({
        id: lsLessonId++,
        instructor: tk.pro || '',
        student: m.name,
        date: dateStr,
        start: timeStr,
        end: timeStr,
        duration: 0,
        bay: '',
        memo: '시설이용 (자동)',
        memberId: m.id,
        ticketIdx: sel.ticketIdx,
        ticketId: tk.id || null,
        status: 'attend'
      });
      stateChanged=true;
    }

    ciCheckins.push({
      id: ciNextId++,
      date: dateStr,
      time: timeStr,
      memberId: _ciKpMemberId,
      memberName: m.name,
      type: sel.type,
      ticketIdx: sel.ticketIdx,
      lessonId: isLesson ? sel.lessonId : null,
      memo: '',
      checkedAt: now.getTime()
    });
  });

  if(stateChanged){ saveState(); try{ lsRender(); }catch(e){} }
  ciSave();
  ciKpClose();
  ciSelMemberId=_ciKpMemberId;
  ciRender();
  try{ mbdRenderTickets(); }catch(e){}
  var cnt=_ciKpSelections.length;
  var typeLabel=_ciKpSelections.map(function(s){return s.type==='lesson'?'레슨':'시설';}).join('+');
  ciNotify('✅ 입장 완료', m.name+' 님 — '+typeLabel+(cnt>1?' ('+cnt+'건)':''));
  ciEnsureNotifyPermission();
  showToast(m.name+' 님 체크인 완료'+(cnt>1?' ('+cnt+'건)':''),'ok');
}

function ciModalSetType(t){
  _ciModalType=t; _ciModalLessonId=null;
  ['facility','lesson'].forEach(function(k){
    var b = document.getElementById('ci-type-'+k);
    if(!b) return;
    var active=k===t;
    b.style.borderColor=active?'#1a5fa0':'#ddd';
    b.style.background =active?'#eaf3fc':'#fff';
    b.style.color      =active?'#1a4a80':'#666';
  });
  ciModalRefreshTickets();
}
function ciMbSearch(v){
  var kw=(v||'').trim().toLowerCase();
  var dd=document.getElementById('ci-mb-dropdown');
  if(!kw){ dd.style.display='none'; return; }
  var res=members.filter(function(m){
    return m.name.toLowerCase().includes(kw)||(m.phone||'').replace(/-/g,'').includes(kw.replace(/-/g,''));
  }).slice(0,8);
  if(!res.length){ dd.style.display='none'; return; }
  var colors=['#1a5fa0','#0d9488','#7c3aed','#be185d','#b45309','#0369a1'];
  dd.innerHTML=res.map(function(m){
    var col=colors[(m.name.charCodeAt(0)||0)%colors.length];
    return '<div onclick="ciMbSelect('+m.id+')" style="display:flex;align-items:center;gap:8px;padding:9px 12px;cursor:pointer;border-bottom:1px solid #f0f0f0;transition:background .1s" onmouseover="this.style.background=\'#f0f6ff\'" onmouseout="this.style.background=\'\'">'+
      '<div style="width:28px;height:28px;border-radius:50%;background:'+col+';display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:#fff;flex-shrink:0">'+esc(m.name.charAt(0))+'</div>'+
      '<div><div style="font-size:13px;font-weight:700;color:#111">'+esc(m.name)+'</div><div style="font-size:11px;color:#999">'+esc(m.phone||'—')+'</div></div>'+
