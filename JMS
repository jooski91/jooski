    label = (s.getMonth()+1)+'월 '+s.getDate()+'일 – '+(e.getMonth()+1)+'월 '+e.getDate()+'일';
  } else {
    var y = now.getFullYear(), m = now.getMonth() + acOffset;
    while(m > 11){ m -= 12; y++; } while(m < 0){ m += 12; y--; }
    s = new Date(y, m, 1);
    e = new Date(y, m+1, 0);
    label = y+'년 '+(m+1)+'월';
  }
  s.setHours(0,0,0,0); e.setHours(23,59,59,999);
  return { s:s, e:e, label:label };
}

/* ═══════════════════════════════════
   전역 날짜 피커 (dpOpen / dpClose)
═══════════════════════════════════ */
var _dpTarget = null, _dpYear = 0, _dpMonth = 0;
var _dpKrHol = {'01-01':1,'03-01':1,'05-05':1,'06-06':1,'08-15':1,'10-03':1,'10-09':1,'12-25':1};

function dpOpen(input){
  _dpTarget = input;
  var val = input.value;
  var d = val && /^\d{4}-\d{2}-\d{2}$/.test(val) ? new Date(val+'T00:00:00') : new Date();
  _dpYear = d.getFullYear(); _dpMonth = d.getMonth();
  dpRender();
  var pop = document.getElementById('dp-popup');
  pop.style.display = 'block';
  // position:fixed 기준 — scrollY 더하면 안 됨
  var rect = input.getBoundingClientRect();
  var popH = 280; // 달력 팝업 예상 높이
  var top, left;
  // 아래 공간 부족하면 위로 띄움
  if(rect.bottom + popH > window.innerHeight && rect.top > popH){
    top = rect.top - popH - 4;
  } else {
    top = rect.bottom + 4;
  }
  left = rect.left;
  if(left + 252 > window.innerWidth) left = window.innerWidth - 258;
  if(left < 4) left = 4;
  pop.style.top  = top  + 'px';
  pop.style.left = left + 'px';
  setTimeout(function(){ document.addEventListener('click', dpOutside); }, 10);
}
function dpSyncInput(input){
  // 수동 입력 시 달력 월 동기화
  var val = input.value;
  if(/^\d{4}-\d{2}-\d{2}$/.test(val)){
    var d = new Date(val+'T00:00:00');
    if(!isNaN(d)){
      _dpYear = d.getFullYear(); _dpMonth = d.getMonth();
      if(_dpTarget === input) dpRender();
    }
  }
}
function dpOutside(e){
  var pop = document.getElementById('dp-popup');
  if(pop.contains(e.target)) return;
  if(_dpTarget && _dpTarget.contains(e.target)) return;
  dpClose();
}
function dpClose(){
  document.getElementById('dp-popup').style.display = 'none';
  document.removeEventListener('click', dpOutside);
  _dpTarget = null;
}
function dpMove(n){
  _dpMonth += n;
  if(_dpMonth > 11){ _dpMonth = 0; _dpYear++; }
  if(_dpMonth < 0){ _dpMonth = 11; _dpYear--; }
  dpRender();
}
function dpPick(y, m, d){
  if(!_dpTarget) return;
  var val = y + '-' + String(m+1).padStart(2,'0') + '-' + String(d).padStart(2,'0');
  _dpTarget.value = val;
  // 연결된 oninput/onchange 트리거
  _dpTarget.dispatchEvent(new Event('input', {bubbles:true}));
  _dpTarget.dispatchEvent(new Event('change', {bubbles:true}));
  dpClose();
}
function dpRender(){
  var MON=['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
  document.getElementById('dp-month-label').textContent = _dpYear + '년 ' + MON[_dpMonth];
  var today = new Date(); today.setHours(0,0,0,0);
  var selVal = _dpTarget ? _dpTarget.value : '';
  var first = new Date(_dpYear, _dpMonth, 1);
  var rawDow = first.getDay();
  var startDow = (rawDow === 0 ? 7 : rawDow) - 1;
  var daysInMonth = new Date(_dpYear, _dpMonth+1, 0).getDate();
  var daysInPrev  = new Date(_dpYear, _dpMonth, 0).getDate();
  var DOW = ['월','화','수','목','금','토','일'];
  var DOW_C = ['#333','#333','#333','#333','#333','#1a5fa0','#c03030'];
  var html = DOW.map(function(d,i){
    return '<div style="font-size:10px;font-weight:700;color:'+DOW_C[i]+';text-align:center;padding:3px 0">'+d+'</div>';
  }).join('');
  for(var i=0;i<startDow;i++){
    html += '<div style="font-size:11px;text-align:center;color:#ddd;padding:4px 2px">'+(daysInPrev-startDow+1+i)+'</div>';
  }
  for(var d2=1;d2<=daysInMonth;d2++){
    var dk = _dpYear+'-'+String(_dpMonth+1).padStart(2,'0')+'-'+String(d2).padStart(2,'0');
    var date2 = new Date(_dpYear,_dpMonth,d2); date2.setHours(0,0,0,0);
    var colIdx = (date2.getDay()===0?6:date2.getDay()-1);
    var isSat=colIdx===5, isSun=colIdx===6;
    var isHol=!!_dpKrHol[String(_dpMonth+1).padStart(2,'0')+'-'+String(d2).padStart(2,'0')];
    var isTod=date2.getTime()===today.getTime(), isSel=dk===selVal;
    var color = isTod?'#fff':(isSun||isHol?'#c03030':isSat?'#1a5fa0':'#333');
    var bg = isSel?'#1a5fa0':isTod?'#60a5fa':'transparent';
    var fw = (isSel||isTod)?'700':'400';
    html += '<div onclick="dpPick('+_dpYear+','+_dpMonth+','+d2+')" style="font-size:12px;text-align:center;padding:4px 2px;border-radius:5px;cursor:pointer;background:'+bg+';color:'+color+';font-weight:'+fw+'">'+d2+'</div>';
  }
  var total = startDow + daysInMonth;
  var rem = (7 - total%7) % 7;
  for(var j=1;j<=rem;j++) html += '<div style="font-size:11px;text-align:center;color:#ddd;padding:4px 2px">'+j+'</div>';
  document.getElementById('dp-grid').innerHTML = html;
}

