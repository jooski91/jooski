// 회원의 가장 최근 활성 이용권 배지
function mbGetTicketBadge(m){
  if(!m.tickets || !m.tickets.length) return '<span style="color:#ccc;font-size:11px">—</span>';
  var today = new Date().toISOString().slice(0,10);
  // 활성(종료일 >= 오늘 or 종료일 없음) 이용권 중 가장 최근
  var active = m.tickets.filter(function(tk){
    return !tk.endDate || tk.endDate >= today;
  });
  var list = active.length ? active : m.tickets; // 활성 없으면 전체
  var tk = list[list.length-1];
  var g  = tkGroups.find(function(x){ return +x.id === +tk.groupId; });
  var it = tkItems.find(function(x){ return +x.id === +tk.itemId; });
  if(!g || !it) return '<span style="color:#ccc;font-size:11px">—</span>';
  var isActive = !tk.endDate || tk.endDate >= today;
  var color  = isActive ? '#1a5fa0' : '#aaa';
  var bg     = isActive ? '#e8f0fa' : '#f5f5f5';
  var border = isActive ? '#c0d8f0' : '#e0e0e0';
  return '<span style="font-size:11px;font-weight:700;padding:2px 8px;border-radius:8px;white-space:nowrap;background:'+bg+';color:'+color+';border:1px solid '+border+'">'+esc(g.name+' / '+it.name)+'</span>';
}

// 회원의 담당 프로 이름 (가장 최근 활성 이용권 기준)
function mbGetActivePro(m){
  if(!m.tickets || !m.tickets.length) return '—';
  var today = new Date().toISOString().slice(0,10);
  var active = m.tickets.filter(function(tk){
    return tk.pro && (!tk.endDate || tk.endDate >= today);
  });
  if(!active.length){
    // 활성 없으면 pro 있는 가장 최근 티켓
    var withPro = m.tickets.filter(function(tk){ return tk.pro; });
    if(!withPro.length) return '—';
    active = [withPro[withPro.length-1]];
  }
  var tk = active[active.length-1];
  return mbGetProName(tk.pro);
}

// pro id → 이름
function mbGetProName(proId){
  if(!proId) return '—';
  // id로 먼저 찾고, 없으면 name으로 직접 매칭 (name이 value로 저장된 경우)
  var p = lsPros.find(function(x){ return String(x.id)===String(proId) || x.name===proId; });
  return p ? p.name : proId;
}

var mbPerPage = 25;
