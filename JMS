/* 레슨 툴팁용 이용권 정보 HTML 생성 */
function lsTicketInfoHtml(l){
  if(!l.memberId) return '';
  var m = members.find(function(x){ return x.id === l.memberId; });
  if(!m || !m.tickets || !m.tickets.length) return '';
  // ticketId 또는 ticketIdx로 매칭
  var tk = null;
  if(l.ticketId) tk = m.tickets.find(function(t){ return t.id === l.ticketId; });
  if(!tk && l.ticketIdx != null) tk = m.tickets[l.ticketIdx];
  if(!tk) tk = m.tickets[0]; // fallback: 첫 번째
  if(!tk) return '';
  var g  = tkGroups.find(function(x){ return +x.id === +tk.groupId; });
  var it = tkItems.find(function(x){ return +x.id === +tk.itemId; });
  if(!g && !it) return '';
  var name = (g && it) ? g.name+' / '+it.name : (it ? it.name : (g ? g.name : ''));
  // 잔여횟수
  var countPart = '';
  if(it && it.count){
    var lessons = lsLessons.filter(function(x){
      if(x.memberId !== m.id) return false;
      if(tk.id && x.ticketId === tk.id) return true;
      if(x.ticketIdx === l.ticketIdx) return true;
      return false;
    });
    var used = lessons.filter(function(x){ return x.status==='attend'||x.status==='absent'; }).length;
    var remain = Math.max(0, it.count - used);
    countPart = ' · 잔여 '+remain+'/'+it.count+'회';
  }
  // 잔여일수
  var daysPart = '';
  var resolvedEnd = tk.endDate || '';
  if(!resolvedEnd && tk.startDate && it && g){
    try{ resolvedEnd = _calcEndDate(tk.startDate, it.days, it.validDays, g.cat); }catch(e){}
  }
  if(resolvedEnd){
    var td = new Date(); td.setHours(0,0,0,0);
    var ed = new Date(resolvedEnd); ed.setHours(0,0,0,0);
    var diff = Math.round((ed - td)/(1000*60*60*24));
    if(diff > 0) daysPart = ' · '+diff+'일 남음';
    else if(diff === 0) daysPart = ' · 오늘 만료';
    else daysPart = ' · 만료됨';
  }
  return '<br><span style="opacity:.75;font-size:10px">📞 '+(m.phone||'—')+'</span><br><span style="opacity:.75;font-size:10px">🎫 '+esc(name)+countPart+daysPart+'</span>';
}

