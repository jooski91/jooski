/* ── 이용권 종료일 자동계산 헬퍼 ── */
function _calcEndDate(startVal, days, validDays, cat){
  if(!startVal) return '';
  // 기간형(연습장-기간): days 기준
  // 횟수형: validDays 기준
  // 레슨형: validDays 있으면 validDays, 없으면 days
  var useDays = 0;
  if(cat === '연습장-기간'){
    useDays = days || 0;
  } else {
    useDays = validDays || days || 0;
  }
  if(!useDays) return '';
  var sd = new Date(startVal);
  if(isNaN(sd)) return '';
  sd.setDate(sd.getDate() + useDays - 1);
  return sd.getFullYear()+'-'+(sd.getMonth()+1).toString().padStart(2,'0')+'-'+sd.getDate().toString().padStart(2,'0');
}

// 이용권 추가 모달: 시작일 변경 → 종료일 자동계산
function mbdTkCalcEnd(){
  var it  = tkItems.find(function(x){ return +x.id === +_mbdSelItemId; });
  var g   = it ? tkGroups.find(function(x){ return +x.id === +it.groupId; }) : null;
  var startVal = document.getElementById('mbd-tk-startdate').value;
  var endEl    = document.getElementById('mbd-tk-enddate');
  if(!it || !g){ endEl.value = ''; return; }
  var endVal = _calcEndDate(startVal, it.days, it.validDays, g.cat);
  endEl.value = endVal;
  // 종료일 필드 스타일: 자동계산이면 배경 유지, 직접 편집 가능
  endEl.style.background = endVal ? '#f0f6ff' : '#f8fafc';
  endEl.style.color = endVal ? '#1a4a80' : '#555';
}

// 이용권 수정 모달: 시작일 변경 → 종료일 자동계산
function mbdTdCalcEnd(){
