function doAssign(idx,kind){
  if(!assignMode)return;
  const w=waiting.find(x=>x.id===assignMode.wid);if(!w){cancelAssignMode();return;}
  const arr=kind==='room'?rooms:bays;
  const slot=arr[idx];
  if(!slot||slot.status!=='empty'){showToast('빈 타석을 선택해주세요','warn');return;}
  const isR=w.type==='룸레슨';
  if(isR&&kind!=='room'){showToast('룸레슨은 룸 타석에만 배정할 수 있습니다','warn');return;}
  slot.status='occupied';slot.name=w.name;slot.type=w.type;slot.startTime=N();
  slot.dur=isR?RD():SD();slot.mark='';slot.markNote='';
  slot.drinkId=w.drinkId||null;slot.drinkTemp=w.drinkTemp||null;slot.drinkDone=w.drinkDone||false;
  waiting=waiting.filter(x=>x.id!==assignMode.wid);
