function mbdSaleEditSave(){
  var m = members.find(function(x){ return x.id === mbDetailId; });
  if(!m || _mbdEditSaleIdx === null) return;
  var s = m.sales[_mbdEditSaleIdx];
  var price    = parseFloat(document.getElementById('mse-price').value)||0;
  var discount = parseFloat(document.getElementById('mse-discount').value)||0;
  var point    = parseFloat(document.getElementById('mse-point').value)||0;
  var salePrice= Math.max(0, price - discount);
  var payAmt   = Math.max(0, salePrice - point);
  // 복합결제 합산 — hidden input 대신 직접 각 수단에서 읽어 조립
  var card     = parseFloat(document.getElementById('mse-pay-card').value)||0;
  var cash     = parseFloat(document.getElementById('mse-pay-cash').value)||0;
  var transfer = parseFloat(document.getElementById('mse-pay-transfer').value)||0;
  var paidTotal = card + cash + transfer;
  var parts = [];
  if(card)     parts.push('카드 '+card);
  if(cash)     parts.push('현금 '+cash);
  if(transfer) parts.push('이체 '+transfer);
  var payMethod = parts.join('+');
  var unpaid   = paidTotal > 0 ? Math.max(0, payAmt - paidTotal) : payAmt;
  var payDate  = document.getElementById('mse-paydate').value;
  var prevStatus = s.saleStatus;
  s.saleDate   = document.getElementById('mse-saledate').value || s.saleDate;
  s.payDate    = payDate;
  s.listPrice  = price;
  s.discount   = discount;
  s.pointUsed  = point;
  s.salePrice  = salePrice;
  s.payAmount  = payAmt;
  s.unpaid     = unpaid;
  s.payMethod  = payMethod;
  s.payCard     = card;
  s.payCash     = cash;
  s.payTransfer = transfer;
  s.saleStatus = unpaid > 0 ? '미수금' : (paidTotal > 0 || payMethod ? '결제완료' : '미수금');
  // 포인트 2% 적립: 미수금→결제완료 전환 시
  if(prevStatus !== '결제완료' && s.saleStatus === '결제완료' && payAmt > 0){
    var m2 = members.find(function(x){ return x.id===mbDetailId; });
    if(m2){
      var ep2 = Math.floor(payAmt * 0.02);
      if(ep2 > 0){
        if(!m2.points) m2.points = 0;
        m2.points += ep2;
        if(!m2.pointHistory) m2.pointHistory = [];
        var _g2 = tkGroups.find(function(x){ return +x.id===+s.groupId; });
        var _it2 = tkItems.find(function(x){ return +x.id===+s.itemId; });
        var _tn2 = (_g2&&_it2)?_g2.name+' / '+_it2.name:'이용권';
        m2.pointHistory.push({type:'earn',amount:ep2,reason:'결제완료 전환 2% 적립 ('+_tn2+')',balanceAfter:m2.points,createdAt:Date.now()});
      }
    }
  }
  if(unpaid === 0){
    if(payDate){
      var pd = payDate.split('-').map(Number);
      var paytimeVal = (document.getElementById('mse-paytime')||{}).value||'12:00';
      var ptParts = paytimeVal.split(':').map(Number);
      s.completedAt = new Date(pd[0], pd[1]-1, pd[2], ptParts[0]||12, ptParts[1]||0, 0).getTime();
    } else if(!s.completedAt){
      s.completedAt = Date.now();
    }
  } else {
    s.completedAt = null;
  }
  saveState();
  mbdSaleEditCancel();
  mbdRenderSales();
  try{ acRender(); }catch(e){}
  // 변경내역 기록
  var _sLogName = tkLogNameById(s.groupId, s.itemId);
  if(prevStatus !== s.saleStatus){
    if(s.saleStatus === '결제완료'){
      tkChangeLogPush(mbDetailId, '미수금결제', _sLogName, '결제완료 처리 · '+payAmt.toLocaleString()+'원', '결제: '+(s.payMethod||'미지정'));
    } else if(s.saleStatus === '미수금'){
      tkChangeLogPush(mbDetailId, '기간변경', _sLogName, '판매정보 수정', '미수금 '+unpaid.toLocaleString()+'원');
    }
  } else {
    tkChangeLogPush(mbDetailId, '기간변경', _sLogName, '판매정보 수정', s.saleStatus);
  }
}

