<style>
.set-tab-btn{padding:6px 16px;font-size:12px;font-weight:700;cursor:pointer;border:none;background:none;color:#999;font-family:inherit;border-bottom:3px solid transparent;transition:color .15s,border-bottom-color .15s}
.set-tab-btn:hover{color:#555}
.set-tab-btn.active{color:#1a5fa0;border-bottom-color:#1a5fa0}
.set-pane{display:none}.set-pane.active{display:block}
.set-card{background:#fff;border:1px solid #e8e8e8;border-radius:12px;padding:20px 22px;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.set-card-title{font-size:15px;font-weight:800;color:#111;margin-bottom:4px}
.set-card-desc{font-size:12px;color:#888;line-height:1.6}
.set-row{display:flex;align-items:center;gap:10px;padding:9px 12px;border:1px solid #eee;border-radius:8px;background:#fafafa}
.set-row-name{flex:1;font-size:13px;font-weight:600;color:#222}
.set-row-edit-inp{flex:1;font-size:13px;font-weight:600;padding:3px 8px;border:1px solid #90bce0;border-radius:5px;outline:none;font-family:inherit}
.set-edit-btn{border:none;background:none;color:#1a5fa0;cursor:pointer;font-size:12px;font-weight:700;padding:0 6px}
.set-del-btn{border:none;background:none;color:#d03030;cursor:pointer;font-size:15px;font-weight:700;padding:0 6px}
.set-save-btn{background:#1a5fa0;color:#fff;border:none;border-radius:5px;padding:3px 10px;font-size:11px;font-weight:700;cursor:pointer;font-family:inherit}
.set-sch-pro-tab{padding:6px 14px;font-size:12px;font-weight:700;border:2px solid #e0e0e0;border-radius:20px;cursor:pointer;background:#fff;color:#666;font-family:inherit;transition:all .15s;white-space:nowrap}
.set-sch-pro-tab:hover{border-color:#90bce0;color:#1a5fa0}
.set-sch-pro-tab.active{border-color:transparent;color:#fff}
/* 프로 관리 서브탭 */
.set-sub-tab-btn{padding:8px 20px;font-size:12px;font-weight:700;cursor:pointer;border:none;background:none;color:#aaa;font-family:inherit;border-bottom:2px solid transparent;margin-bottom:-2px;transition:color .15s,border-color .15s}
.set-sub-tab-btn:hover{color:#555}
.set-sub-tab-btn.active{color:#1a5fa0;border-bottom-color:#1a5fa0}
.set-sub-pane{display:none}.set-sub-pane.active{display:block}
</style>

<script>
/* ========= 설정 페이지 ========= */

var _setSchPro = null; // 현재 선택된 프로 이름

function setTab(btn, paneId){
  document.querySelectorAll('.set-tab-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.set-pane').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(paneId).classList.add('active');
  if(paneId==='set-branch') setRenderBranch();
  if(paneId==='set-pro') { setRenderPro(); setRenderSchTabs(); }
  if(paneId==='set-schedule'){ setRenderSchTabs(); }
  if(paneId==='set-bay') setRenderBayDur();
}

function setProSubTab(sub){
  document.querySelectorAll('.set-sub-tab-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.set-sub-pane').forEach(p=>p.classList.remove('active'));
  document.getElementById('set-pro-subtab-'+sub).classList.add('active');
  document.getElementById('set-pro-subpane-'+sub).classList.add('active');
  if(sub==='list') setRenderPro();
  if(sub==='schedule') setRenderSchTabs();
}

// ─── 설정 페이지 열릴 때 초기화 ───
(function(){
  var origShow = showPage;
  showPage = function(pageId){
    origShow(pageId);
    if(pageId==='settings-page'){
      setRenderBranch();
      setRenderPro();
      setRenderBayDur();
      setRenderSchTabs();
      // 센터 이름 복원
      var savedName = '';
      try{ savedName = localStorage.getItem('tdf_centerName')||''; }catch(e){}
      var inp = document.getElementById('set-center-name');
      if(inp) inp.value = savedName || document.getElementById('topbar-logo-text').textContent;
      // 탭 첫번째 활성
      document.querySelectorAll('.set-tab-btn').forEach(function(b,i){ b.classList.toggle('active',i===0); });
      document.querySelectorAll('.set-pane').forEach(function(p,i){ p.classList.toggle('active',i===0); });
      // 프로관리 서브탭 초기화
      document.querySelectorAll('.set-sub-tab-btn').forEach(function(b,i){ b.classList.toggle('active',i===0); });
      document.querySelectorAll('.set-sub-pane').forEach(function(p,i){ p.classList.toggle('active',i===0); });
    }
  };
})();

// ─── 지점 렌더 ───
function setRenderBranch(){
  var el = document.getElementById('set-branch-list');
  if(!el) return;
  if(!mbBranches.length){ el.innerHTML='<div style="color:#bbb;font-size:12px;text-align:center;padding:12px">지점 없음</div>'; return; }
  el.innerHTML = mbBranches.map(function(b,i){
    return '<div class="set-row" id="set-br-row-'+i+'">'+
      '<span class="set-row-name" id="set-br-name-'+i+'">'+esc(b)+'</span>'+
      '<button class="set-edit-btn" onclick="setBranchEdit('+i+')">✏️</button>'+
      '<button class="set-del-btn" onclick="setBranchDel('+i+')" title="삭제">✕</button>'+
    '</div>';
  }).join('');
}
function setBranchEdit(i){
  var row = document.getElementById('set-br-row-'+i);
  var nameEl = document.getElementById('set-br-name-'+i);
  var cur = mbBranches[i];
  nameEl.outerHTML='<input class="set-row-edit-inp" id="set-br-inp-'+i+'" value="'+esc(cur)+'" onkeydown="if(event.key===\'Enter\')setBranchSave('+i+')" />';
  row.querySelector('.set-edit-btn').outerHTML='<button class="set-save-btn" onclick="setBranchSave('+i+')">저장</button>';
  document.getElementById('set-br-inp-'+i).focus();
}
function setBranchSave(i){
  var inp = document.getElementById('set-br-inp-'+i);
  if(!inp) return;
  var val = inp.value.trim();
  if(!val){ alert('지점명을 입력해주세요.'); return; }
  mbBranches[i] = val; saveState(); setRenderBranch(); mbSyncBranchSelects();
}
function setBranchDel(i){
  if(mbBranches.length<=1){ alert('지점을 최소 1개 이상 유지해야 합니다.'); return; }
  if(!confirm(mbBranches[i]+' 지점을 삭제할까요?')) return;
  mbBranches.splice(i,1); saveState(); setRenderBranch(); mbSyncBranchSelects();
}
function setBranchAdd(){
  var inp = document.getElementById('set-branch-inp');
  var val = (inp.value||'').trim();
  if(!val){ alert('지점명을 입력해주세요.'); return; }
  if(mbBranches.includes(val)){ alert('이미 있는 지점입니다.'); return; }
  mbBranches.push(val); inp.value='';
  saveState(); setRenderBranch(); mbSyncBranchSelects();
}
function setCenterNameSave(){
  var val = (document.getElementById('set-center-name').value||'').trim();
  if(!val){ alert('이름을 입력해주세요.'); return; }
  var logoEl = document.getElementById('topbar-logo-text');
  if(logoEl) logoEl.textContent = val;
  try{ localStorage.setItem('tdf_centerName', val); }catch(e){}
  showToast('센터 이름이 변경되었습니다 ✅','ok');
}

// ─── 프로 렌더 ───
function setRenderPro(){
  var el = document.getElementById('set-pro-list');
  if(!el) return;
  if(!lsPros.length){ el.innerHTML='<div style="color:#bbb;font-size:12px;text-align:center;padding:12px">등록된 프로 없음</div>'; return; }
  el.innerHTML = lsPros.map(function(p,i){
    var col = LS_COLORS[i%LS_COLORS.length];
    return '<div class="set-row" id="set-pro-row-'+i+'">'+
      '<span class="set-row-name" id="set-pro-nm-'+i+'">'+esc(p.name)+'</span>'+
      '<button class="set-edit-btn" onclick="setProEdit('+i+')">✏️</button>'+
      '<button class="set-del-btn" onclick="setProDel('+i+')">✕</button>'+
    '</div>';
  }).join('');
}
function setProEdit(i){
  var row = document.getElementById('set-pro-row-'+i);
  var nmEl = document.getElementById('set-pro-nm-'+i);
  nmEl.outerHTML='<input class="set-row-edit-inp" id="set-pro-inp-'+i+'" value="'+esc(lsPros[i].name)+'" onkeydown="if(event.key===\'Enter\')setProSave('+i+')" />';
  row.querySelector('.set-edit-btn').outerHTML='<button class="set-save-btn" onclick="setProSave('+i+')">저장</button>';
  document.getElementById('set-pro-inp-'+i).focus();
}
function setProSave(i){
  var inp = document.getElementById('set-pro-inp-'+i);
  if(!inp) return;
  var newName = inp.value.trim();
  if(!newName){ alert('이름을 입력해주세요.'); return; }
  if(lsPros.findIndex(function(p,idx){ return p.name===newName && idx!==i; })>=0){ alert('이미 있는 이름입니다.'); return; }
  var oldName = lsPros[i].name;
  lsPros[i].name = newName;
  lsLessons.forEach(function(l){ if(l.instructor===oldName) l.instructor=newName; });
  saveState(); setRenderPro(); lsSyncProSelect(); setRenderSchTabs();
}
function setProDel(i){
  if(!confirm(lsPros[i].name+' 프로를 삭제할까요?')) return;
  lsPros.splice(i,1);
  if(lsSelectedPro>=lsPros.length) lsSelectedPro=0;
  saveState(); setRenderPro(); lsSyncProSelect(); setRenderSchTabs();
}
function setProAdd(){
  var inp = document.getElementById('set-pro-inp');
  var name = (inp.value||'').trim();
  if(!name) return;
  if(lsPros.length>=7){ alert('프로는 최대 7명까지 등록할 수 있습니다.'); return; }
  if(lsPros.find(function(p){ return p.name===name; })){ alert('이미 등록된 프로입니다.'); return; }
  lsPros.push({name:name}); inp.value='';
  saveState(); setRenderPro(); lsSyncProSelect(); setRenderSchTabs();
}

// ─── 프로 스케줄 (정기 휴무요일 + 임시 휴무날짜 + 레슨 가능시간) ───
var DOW_KO=['일','월','화','수','목','금','토'];
var lsProSchedules = {};

function setLoadSchedules(){
  try{ var s=localStorage.getItem('tdf_proSchedules'); if(s) lsProSchedules=JSON.parse(s); }catch(e){ lsProSchedules={}; }
  // 마이그레이션: 기존 breaks → workTimes 변환
  Object.keys(lsProSchedules).forEach(function(name){
    var sch = lsProSchedules[name];
    if(sch.breaks && !sch.workTimes){
      // 기존 breaks(불가시간)가 있으면 빈 배열로 초기화 (불가→가능 방식 전환)
      sch.workTimes = [];
      delete sch.breaks;
      setSaveSchedules();
    }
    if(!sch.workTimes) sch.workTimes = [];
  });
}
function setSaveSchedules(){
  try{ localStorage.setItem('tdf_proSchedules', JSON.stringify(lsProSchedules)); }catch(e){}
}
function schMarkDirty(){
  var unsaved = document.getElementById('set-sch-unsaved');
  if(unsaved) unsaved.style.display='flex';
}
function schSave(){
  setSaveSchedules();
  var unsaved = document.getElementById('set-sch-unsaved');
  if(unsaved) unsaved.style.display='none';
  openSaveModal('스케줄 저장 완료', '프로 스케줄이 저장되었습니다.');
}

function setRenderSchTabs(){
  var el = document.getElementById('set-sch-pro-tabs');
  if(!el) return;
  if(!lsPros.length){
    el.innerHTML='<div style="color:#bbb;font-size:12px">등록된 프로가 없습니다</div>';
    document.getElementById('set-sch-body').innerHTML='';
    return;
  }
  el.innerHTML = lsPros.map(function(p,i){
    var col = LS_COLORS[i%LS_COLORS.length];
    var isActive = _setSchPro===p.name;
    return '<button onclick="setSchSelectPro(\''+p.name.replace(/'/g,"\\'")+'\')" style="'+
      'padding:7px 16px;font-size:12px;font-weight:700;border-radius:20px;cursor:pointer;font-family:inherit;white-space:nowrap;transition:all .15s;'+
      (isActive
        ? 'background:'+col+';border:2px solid '+col+';color:#fff;'
        : 'background:#fff;border:2px solid #e0e0e0;color:#666;')+
      '">'+esc(p.name)+'</button>';
  }).join('');
  if(_setSchPro && lsPros.find(function(p){ return p.name===_setSchPro; })){
    setRenderSchBody(_setSchPro);
  } else {
    _setSchPro = null;
    document.getElementById('set-sch-body').innerHTML='<div style="color:#bbb;font-size:13px;text-align:center;padding:20px">위에서 프로를 선택해주세요</div>';
  }
}

function setSchSelectPro(name){
  _setSchPro = name;
  // 미저장 표시 숨김 (프로 전환 시)
  var unsaved = document.getElementById('set-sch-unsaved');
  if(unsaved){ unsaved.style.display='none'; }
  var el = document.getElementById('set-sch-pro-tabs');
  if(el){
    var btns = el.querySelectorAll('button');
    lsPros.forEach(function(p,i){
      var col = LS_COLORS[i%LS_COLORS.length];
      var btn = btns[i]; if(!btn) return;
      var isActive = p.name===name;
      btn.style.background   = isActive ? col : '#fff';
      btn.style.borderColor  = isActive ? col : '#e0e0e0';
      btn.style.color        = isActive ? '#fff' : '#666';
    });
  }
  setRenderSchBody(name);
}

function setRenderSchBody(name){
  var el = document.getElementById('set-sch-body');
  if(!el) return;
  if(!lsProSchedules[name]) lsProSchedules[name]={offDays:[],offDates:[],workDates:[],workTimes:{}};
  var sch = lsProSchedules[name];
  // 마이그레이션: 배열형 → 요일별 객체형
  if(Array.isArray(sch.workTimes)){
    var old = sch.workTimes;
    sch.workTimes = {};
    if(old.length){ DOW_KO.forEach(function(_,i){ sch.workTimes[i]=old.map(function(w){ return {start:w.start,end:w.end}; }); }); }
    setSaveSchedules();
  }
  if(!sch.workTimes || Array.isArray(sch.workTimes)) sch.workTimes = {};

  var nm = name.replace(/'/g,"\\'");

  // ── 1. 정기 휴무 요일 (월~일 순서로 표시, 인덱스는 JS getDay() 기준 유지) ──
  var DOW_DISPLAY = [1,2,3,4,5,6,0]; // 월화수목금토일 순서 (JS getDay 인덱스)
  var dowHtml = '<div style="margin-bottom:20px;padding-bottom:18px;border-bottom:1px solid #f0f0f0">'+
    '<div style="font-size:13px;font-weight:800;color:#333;margin-bottom:10px">정기 휴무 요일</div>'+
    '<div style="display:flex;gap:6px;flex-wrap:wrap" id="set-dow-wrap">';
  DOW_DISPLAY.forEach(function(i){
    var d = DOW_KO[i];
    var on = (sch.offDays||[]).includes(i);
    dowHtml += '<button id="set-dow-'+i+'" onclick="setSchToggleDay(\''+nm+'\','+i+')" style="'+
      'width:52px;padding:8px 0;border-radius:10px;cursor:pointer;font-size:13px;font-weight:700;font-family:inherit;transition:all .15s;'+
      (on ? 'background:#d03030;border:2px solid #d03030;color:#fff;' : 'background:#fff;border:2px solid #e0e0e0;color:#666;')+
      '">'+d+'</button>';
  });
  dowHtml += '</div></div>';

  // ── 2. 임시 휴무 날짜 ──
  var offDates = sch.offDates || [];
  var dateHtml = '<div style="margin-bottom:20px;padding-bottom:18px;border-bottom:1px solid #f0f0f0">'+
    '<div style="font-size:13px;font-weight:800;color:#333;margin-bottom:6px">임시 휴무 날짜</div>'+
    '<div style="font-size:11px;color:#999;margin-bottom:10px">정기 휴무가 아닌 특정 날짜 휴무 (예: 명절, 개인 휴가)</div>'+
    '<div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px">';
  if(!offDates.length) dateHtml += '<span style="font-size:12px;color:#ccc">등록된 임시 휴무 없음</span>';
  offDates.sort().forEach(function(dt){
    var d = new Date(dt+'T00:00:00');
    var label = (d.getMonth()+1)+'/'+(d.getDate())+'('+DOW_KO[d.getDay()]+')';
    dateHtml += '<span style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;background:#fff0f0;border:1.5px solid #f09090;border-radius:20px;font-size:12px;font-weight:700;color:#c03030">'+
      label+'<button onclick="setSchRemoveDate(\''+nm+'\',\''+dt+'\')" style="background:none;border:none;color:#c03030;cursor:pointer;font-size:13px;line-height:1;padding:0;font-weight:700">✕</button></span>';
  });
  dateHtml += '</div>'+
    '<div style="display:flex;gap:8px;align-items:center">'+
    '<input type="text" id="set-offdate-inp" placeholder="2026-05-19" onclick="dpOpen(this)" oninput="dpSyncInput(this)" data-dp="1" style="padding:7px 10px;border:1.5px solid #ddd;border-radius:8px;font-size:13px;font-family:inherit;outline:none;color:#333;cursor:text;background:#fff;min-width:130px"/>'+
    '<button onclick="setSchAddDate(\''+nm+'\',document.getElementById(\'set-offdate-inp\').value)" style="background:#d03030;color:#fff;border:none;border-radius:8px;padding:7px 16px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit">+ 추가</button>'+
    '</div></div>';

  // ── 3. 특별 출근일 ──
  var workDates = sch.workDates || [];
  var workHtml = '<div style="margin-bottom:20px;padding-bottom:18px;border-bottom:1px solid #f0f0f0">'+
    '<div style="font-size:13px;font-weight:800;color:#333;margin-bottom:6px">특별 출근일 <span style="font-size:11px;font-weight:500;color:#888">(정기 휴무 요일 중 예외 출근)</span></div>'+
    '<div style="font-size:11px;color:#999;margin-bottom:10px">정기 휴무 요일이지만 해당 날짜만 출근 — 레슨 예약 가능</div>'+
    '<div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px">';
  if(!workDates.length) workHtml += '<span style="font-size:12px;color:#ccc">등록된 특별 출근일 없음</span>';
  workDates.sort().forEach(function(dt){
    var d = new Date(dt+'T00:00:00');
    var label = (d.getMonth()+1)+'/'+(d.getDate())+'('+DOW_KO[d.getDay()]+')';
    workHtml += '<span style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;background:#f0faf4;border:1.5px solid #8cc870;border-radius:20px;font-size:12px;font-weight:700;color:#1a7040">'+
      label+'<button onclick="setSchRemoveWork(\''+nm+'\',\''+dt+'\')" style="background:none;border:none;color:#1a7040;cursor:pointer;font-size:13px;line-height:1;padding:0;font-weight:700">✕</button></span>';
  });
  workHtml += '</div>'+
    '<div style="display:flex;gap:8px;align-items:center">'+
