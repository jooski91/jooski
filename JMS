}
function ciMbClear(){
  _ciModalMemberId=null; _ciModalTicketIdx=null; _ciModalLessonId=null;
  document.getElementById('ci-mb-search').value='';
  document.getElementById('ci-mb-selected').style.display='none';
  document.getElementById('ci-ticket-wrap').style.display='none';
  document.getElementById('ci-lesson-wrap').style.display='none';
}
function ciModalRefreshTickets(){
  var m=_ciModalMemberId?members.find(function(x){return x.id===_ciModalMemberId;}):null;
  var tw=document.getElementById('ci-ticket-wrap');
  var lw=document.getElementById('ci-lesson-wrap');
  if(!m){ tw.style.display='none'; lw.style.display='none'; return; }
  var today=ciTodayStr();
  // 타입에 맞는 이용권만
  var tks=(m.tickets||[]).filter(function(tk,i){
    if(tk.refunded) return false;
    if(tk.endDate && tk.endDate<today) return false;
    var g=tkGroups.find(function(x){return +x.id===+tk.groupId;});
    if(!g) return true;
    var isLesson=tkCatMeta(g.cat).group==='레슨';
    return _ciModalType==='lesson' ? isLesson : !isLesson;
  });
  if(!tks.length){
    var tl=document.getElementById('ci-ticket-list');
    tl.innerHTML='<div style="font-size:11px;color:#f59e0b;padding:6px 0">해당 유형의 유효한 이용권이 없습니다.</div>';
    tw.style.display='block';
  } else {
    var tl=document.getElementById('ci-ticket-list');
    tl.innerHTML=tks.map(function(tk){
      var idx=(m.tickets||[]).indexOf(tk);
      var g=tkGroups.find(function(x){return +x.id===+tk.groupId;});
      var gName=g?g.name:'이용권';
      var meta=tkCatMeta(g?g.cat:'');
      var bc=(meta.badgeCls||'#eee:#666').split(':');
      var sel=_ciModalTicketIdx===idx;
      return '<div onclick="ciModalSelTicket('+idx+')" style="display:flex;align-items:center;gap:8px;padding:8px 10px;border:1.5px solid '+(sel?'#1a5fa0':'#e0e0e0')+';border-radius:7px;background:'+(sel?'#eaf3fc':'#fff')+';cursor:pointer;transition:all .12s">'+
        '<span style="font-size:10px;font-weight:700;padding:2px 6px;border-radius:4px;background:'+bc[0]+';color:'+bc[1]+'">'+meta.badge+'</span>'+
        '<span style="font-size:12px;font-weight:700;color:#111;flex:1">'+esc(gName)+'</span>'+
        '<span style="font-size:10px;color:#aaa">'+(tk.endDate?'~'+tk.endDate:'')+'</span>'+
      '</div>';
    }).join('');
    tw.style.display='block';
  }
  // 레슨 스케줄 연결
  if(_ciModalType==='lesson'){
    var dateStr=ciTodayStr();
    var todayLess=lsLessons.filter(function(l){
      return l.memberId===m.id && l.date===dateStr;
    });
    var ll=document.getElementById('ci-lesson-list');
    if(!todayLess.length){
      lw.style.display='none';
    } else {
      ll.innerHTML=todayLess.map(function(l){
        var sel=_ciModalLessonId===l.id;
        var attended=l.status==='attend';
        return '<div onclick="ciModalSelLesson('+l.id+')" style="display:flex;align-items:center;gap:8px;padding:7px 10px;border:1.5px solid '+(sel?'#1a5fa0':'#e0e0e0')+';border-radius:7px;background:'+(sel?'#eaf3fc':'#fff')+';cursor:pointer;transition:all .12s">'+
          '<span style="font-size:13px">'+(attended?'✅':'📅')+'</span>'+
          '<span style="font-size:12px;font-weight:700;color:#111;flex:1">'+l.start+'~'+l.end+'</span>'+
          '<span style="font-size:11px;color:#888">'+esc(l.instructor)+'</span>'+
          (attended?'<span style="font-size:9px;background:#dcfce7;color:#166534;padding:1px 5px;border-radius:4px;font-weight:700">출석</span>':'')+
        '</div>';
      }).join('');
      lw.style.display='block';
    }
  } else {
    lw.style.display='none';
  }
}
function ciModalSelTicket(idx){
  _ciModalTicketIdx=idx;
  ciModalRefreshTickets();
}
function ciModalSelLesson(id){
  _ciModalLessonId = _ciModalLessonId===id ? null : id;
  ciModalRefreshTickets();
}
function ciConfirm(){
  if(!_ciModalMemberId){ showToast('회원을 선택해주세요','warn'); return; }
  var m=members.find(function(x){return x.id===_ciModalMemberId;});
  if(!m){ showToast('회원을 찾을 수 없습니다','warn'); return; }
  var now=new Date();
  var _rm=now.getMinutes(),_rr=Math.round(_rm/10)*10,_rh=now.getHours()+(_rr===60?1:0);_rr=_rr===60?0:_rr;
  var timeStr=(_rh+'').padStart(2,'0')+':'+(_rr+'').padStart(2,'0');
  var dateStr=ciOffsetDate(ciDateOffset);
  var record={
    id: ciNextId++,
    date: dateStr,
    time: timeStr,
    memberId: _ciModalMemberId,
    memberName: m.name,
    type: _ciModalType,
    ticketIdx: _ciModalTicketIdx,
    lessonId: _ciModalType==='lesson'?_ciModalLessonId:null,
    memo: (document.getElementById('ci-memo').value||'').trim(),
    checkedAt: now.getTime()
  };
  ciCheckins.push(record);
  // 레슨 출석 처리
  if(_ciModalType==='lesson' && _ciModalLessonId){
    var ls=lsLessons.find(function(x){return x.id===_ciModalLessonId;});
    if(ls && ls.status!=='attend'){ ls.status='attend'; saveState(); }
  }
  ciSave();
  ciCloseModal();
  ciSelMemberId = _ciModalMemberId;
  ciRender();
  showToast(m.name+' 님 체크인 완료','ok');
}

/* ── 서브탭 위치 정렬: 해당 탑바 버튼 왼쪽 끝에 맞춤 ── */
var _currentSubtabPage = null;
var _tbBtnMap = {
  'bay-page':'tb-bay','lesson-page':'tb-lesson','checkin-page':'tb-checkin','member-page':'tb-member',
  'ticket-page':'tb-ticket','accounting-page':'tb-accounting','settings-page':'tb-settings'
};
function alignSubtab(pageId){
  if(pageId) _currentSubtabPage = pageId;
  var pid = _currentSubtabPage;
  if(!pid) return;
  var subtabId = pid.replace('-page','-subtab-bar');
  var subtab = document.getElementById(subtabId);
  if(!subtab || subtab.style.display==='none') return;
  var tbId = _tbBtnMap[pid];
  if(!tbId){ subtab.style.paddingLeft='0'; return; }
  var tbBtn = document.getElementById(tbId);
  if(!tbBtn){ subtab.style.paddingLeft='0'; return; }
  var lft = tbBtn.getBoundingClientRect().left;
  // paddingLeft 대신 overflow:visible 유지하고 첫 버튼에 margin으로 정렬
  // → 서브탭 전체 폭이 보장되도록 paddingLeft는 쓰되, overflow:hidden 해제
  subtab.style.paddingLeft = (lft > 0 ? lft : 0) + 'px';
  subtab.style.overflowX = 'auto';
  subtab.style.overflowY = 'hidden';
}
window.addEventListener('resize', function(){ alignSubtab(null); });
