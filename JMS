var _mbdSelGroupId = null;
var _mbdSelItemId  = null;
var _mbdDetailTicketIdx = null;

/* 이용권 탭 렌더 */
function mbdRenderTickets(){
  const m = members.find(function(x){ return x.id === mbDetailId; });
  const el = document.getElementById('mbd-ticket-list');
  if(!el) return;
  const tickets = (m && m.tickets) ? m.tickets.filter(function(tk){ return !tk.refunded; }) : [];
  if(!tickets.length){
    el.innerHTML = '<div style="text-align:center;padding:32px 0;color:#bbb;font-size:12px"><div style="font-size:32px;margin-bottom:8px">🎫</div>보유 이용권이 없습니다</div>';
    return;
  }
  el.innerHTML = tickets.map(function(tk){
    var i = m.tickets.indexOf(tk); // 원본 인덱스 (lsLessons.ticketIdx 기준)
    var g = tkGroups.find(function(g){ return +g.id === +tk.groupId; });
    var it = tkItems.find(function(x){ return +x.id === +tk.itemId; });
    var meta = g ? tkCatMeta(g.cat) : null;
    var cols = meta ? meta.badgeCls.split(':') : ['#eee','#666'];
    var badgeStyle = 'background:'+cols[0]+';color:'+cols[1];
    var badgeText  = meta ? meta.badge : (g ? g.cat : '');
    var statusColor = tk.payStatus==='결제완료' ? '#16a34a' : tk.payStatus==='미결제' ? '#c07000' : '#7c3aed';
    var statusBg    = tk.payStatus==='결제완료' ? '#f0fdf4' : tk.payStatus==='미결제' ? '#fffbeb' : '#f5f3ff';
    var statusBorder= tk.payStatus==='결제완료' ? '#86efac' : tk.payStatus==='미결제' ? '#fde68a' : '#c4b5fd';
    // 이 이용권에 연결된 레슨 목록으로 출석/결석/예약 카운트 계산
    var tkLessons = lsLessons.filter(function(l){
      if(l.memberId !== m.id) return false;
      if(tk.id && l.ticketId === tk.id) return true;
      if(l.ticketIdx === i) return true;
      return false;
    });
    var attendCount = tkLessons.filter(function(l){ return l.status === 'attend'; }).length;
    var absentCount = tkLessons.filter(function(l){ return l.status === 'absent'; }).length;
    var totalCount  = it ? (it.count || 0) : 0;
    var usedCount   = attendCount + absentCount;
    var remainCount = totalCount ? Math.max(0, totalCount - usedCount) : null;

    var countInfo = '';
    if(it){
      if(it.days) countInfo += '<span>기간 <strong>'+it.days+'일</strong></span>';
      // 금액은 보유이용권에서 제거 (판매내역에서만 표시)
    }
    // 횟수 카운트 뱃지 (횟수형 이용권인 경우) — 잔여일은 나중에 합산
    var countBadges = '';
    if(totalCount){
      countBadges =
        '<div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:8px;margin-bottom:2px">'+
          '<span style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:6px;background:#f1f5f9;color:#334155">전체 <strong>'+totalCount+'</strong>회</span>'+
          '<span style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:6px;background:#eff6ff;color:#1d4ed8">출석 <strong>'+attendCount+'</strong>회</span>'+
          '<span style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:6px;background:#fee2e2;color:#dc2626">결석 <strong>'+absentCount+'</strong>회</span>'+
          '<span style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:6px;background:#f0fdf4;color:#16a34a">잔여 <strong>'+remainCount+'</strong>회</span>'+
          '{{REMAIN_DAYS}}'+
        '</div>';
    } else if(tkLessons.length){
      countBadges =
        '<div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:8px;margin-bottom:2px">'+
          '<span style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:6px;background:#eff6ff;color:#1d4ed8">출석 <strong>'+attendCount+'</strong>회</span>'+
          '<span style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:6px;background:#fee2e2;color:#dc2626">결석 <strong>'+absentCount+'</strong>회</span>'+
          '{{REMAIN_DAYS}}'+
        '</div>';
    } else {
      countBadges = '{{REMAIN_DAYS_WRAP}}';
    }
    var startStr = tk.startDate ? fmtDateDow(tk.startDate) : '—';
    var endStr = '';
    var remainDaysStr = '';
    // 저장된 endDate 우선, 없으면 자동 계산
    var resolvedEnd = tk.endDate || '';
    if(!resolvedEnd && tk.startDate && it && g){
      resolvedEnd = _calcEndDate(tk.startDate, it.days, it.validDays, g.cat);
    }
    if(resolvedEnd){
      endStr = '<span>~ <strong>'+fmtDateDow(resolvedEnd)+'</strong></span>';
      var todayD = new Date(); todayD.setHours(0,0,0,0);
      var endD = new Date(resolvedEnd); endD.setHours(0,0,0,0);
      var diffDays = Math.round((endD - todayD) / (1000*60*60*24));
      if(diffDays > 0){
        remainDaysStr = '<span style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:6px;background:#fef9c3;color:#854d0e">잔여 <strong>'+diffDays+'일</strong></span>';
      } else if(diffDays === 0){
        remainDaysStr = '<span style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:6px;background:#fee2e2;color:#dc2626">오늘 만료</span>';
      } else {
        remainDaysStr = '<span style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:6px;background:#f1f5f9;color:#94a3b8">만료됨</span>';
      }
    }
    // 잔여일 플레이스홀더 치환
    var rdWrap = remainDaysStr ? '<div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:8px;margin-bottom:2px">'+remainDaysStr+'</div>' : '';
    countBadges = countBadges.replace('{{REMAIN_DAYS}}', remainDaysStr).replace('{{REMAIN_DAYS_WRAP}}', rdWrap);
    var proBtn = '';
    return '<div class="mbd-ticket-card">'+
            '<div class="mbd-ticket-card-top">'+
        '<div>'+
          '<div class="mbd-ticket-card-name">'+(g&&it ? esc(g.name)+' / '+esc(it.name) : esc(it ? it.name : '—'))+'</div>'+
          '<div class="mbd-ticket-card-group">'+esc(g ? g.name : '—')+'</div>'+
        '</div>'+
        '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px">'+
          '<span style="font-size:10px;font-weight:700;color:#94a3b8;background:#f1f5f9;padding:2px 7px;border-radius:5px">No.'+(i+1)+'</span>'+
          '<span class="mbd-ticket-badge" style="'+badgeStyle+'">'+esc(badgeText)+'</span>'+
        '</div>'+
