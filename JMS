  if(!start||!end){ alert('시간을 입력하세요.'); return; }
  if(start>=end){ alert('종료 시간은 시작 시간보다 늦어야 합니다.'); return; }
  // 중복 체크 (자기 자신 제외)
  var overlap = lsOtherScheds.find(function(s){
    if(editId && s.id===+editId) return false;
    return s.pro===pro && s.date===date && s.start<end && s.end>start;
  });
  if(overlap){ alert((pro?pro+' ':'')+date+' '+overlap.start+'~'+overlap.end+' 에 이미 기타 스케줄이 있습니다.'); return; }
  if(editId){
    var idx = lsOtherScheds.findIndex(function(s){ return s.id===+editId; });
    if(idx>=0) lsOtherScheds[idx] = {id:+editId, pro:pro, date:date, start:start, end:end, memo:memo};
  } else {
    lsOtherScheds.push({id:lsOtherSchedId++, pro:pro, date:date, start:start, end:end, memo:memo});
  }
  lsSaveOtherScheds();
  lsRender();
  closeLessonModal();
  showToast(editId?'수정되었습니다.':'기타 스케줄이 등록되었습니다.','ok');
}

