/* 이용권별 예약 내역 렌더 */
function mbdRenderTicketLessons(m, ticketIdx, tk){
  var lessons = lsLessons.filter(function(l){
    if(l.memberId !== m.id) return false;
    if(tk.id && l.ticketId === tk.id) return true;
    if(l.ticketIdx === ticketIdx) return true;
    return false;
  });
  if(!lessons.length) return '<div style="margin-top:10px;border-top:1px dashed #e0e8f0;padding-top:8px">'+
    '<div style="font-size:11px;color:#bbb;padding:4px 0">예약된 레슨이 없습니다</div>'+
  '</div>';

  var sorted = lessons.slice().sort(function(a,b){ return (b.date+b.start).localeCompare(a.date+a.start); }); // 최신순
  var today = new Date().toISOString().slice(0,10);
  var MAX = 3;
  var display = sorted.slice(0, MAX);

  function makeRow(l){
    var isPast = l.date < today;
    var isToday = l.date === today;
    var statusColor, statusBg, statusLabel;
    if(l.status==='attend'){      statusColor='#60a5fa'; statusBg='#eff6ff'; statusLabel='출석'; }
    else if(l.status==='absent'){ statusColor='#dc2626'; statusBg='#fee2e2'; statusLabel='결석'; }
    else if(isPast){              statusColor='#aaa';    statusBg='#f5f5f5'; statusLabel='완료'; }
    else if(isToday){             statusColor='#c07000'; statusBg='#fffbeb'; statusLabel='오늘'; }
    else {                        statusColor='#1a5fa0'; statusBg='#e8f0fa'; statusLabel='예정'; }
    return '<div style="display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;background:'+statusBg+';margin-bottom:4px">'+
      '<span style="font-size:10px;font-weight:700;padding:2px 6px;border-radius:5px;background:'+statusColor+';color:#fff;white-space:nowrap">'+statusLabel+'</span>'+
      '<span style="font-size:12px;font-weight:700;color:#222;white-space:nowrap">'+esc(l.date ? fmtDateDow(l.date) : '—')+'</span>'+
      '<span style="font-size:11px;color:#555;white-space:nowrap">'+esc(l.start||'')+(l.end?' ~ '+esc(l.end):'')+'</span>'+
      '<span style="font-size:11px;color:#888;white-space:nowrap">'+esc(l.instructor||'')+'</span>'+
      (l.bay ? '<span style="font-size:10px;color:#aaa">'+esc(l.bay)+'</span>' : '')+
    '</div>';
  }

  var rows = display.map(makeRow).join('');
  return '<div style="margin-top:10px;border-top:1px dashed #e0e8f0;padding-top:8px">'+
    '<div style="font-size:11px;font-weight:700;color:#888;margin-bottom:6px">예약 내역 ('+sorted.length+'건)</div>'+
    rows+
  '</div>';
}

