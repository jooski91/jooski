/* ── 예약 취소 (이용권 사용 내역에서 예정 레슨 삭제) ── */
function mbdCancelLesson(lessonId){
  if(!confirm('이 레슨 예약을 취소하시겠습니까?\n취소 후 복구할 수 없습니다.')) return;
  var idx = lsLessons.findIndex(function(l){ return l.id === lessonId; });
  if(idx < 0){ showToast('예약을 찾을 수 없습니다','warn'); return; }
  var l = lsLessons[idx];
  if(l.status === 'attend' || l.status === 'absent'){
    showToast('출석/결석 처리된 레슨은 취소할 수 없습니다','warn'); return;
  }
  lsLessons.splice(idx, 1);
  saveState();
  lsRender();
  mbdRenderHome();
  mbdRenderTickets();
  // 현재 열린 모달을 같은 컨텍스트로 재렌더
  if(_lhContext){
    if(_lhContext.type === 'all'){
      mbdOpenAllLessonHistory(_lhContext.memberId);
    } else if(_lhContext.type === 'ticket'){
      mbdOpenLessonHistory(_lhContext.memberId, _lhContext.ticketIdx);
    }
  }
  showToast('예약이 취소되었습니다','ok');
}

function mbdDeleteTicket(idx){
  var m = members.find(function(x){ return x.id === mbDetailId; });
  if(!m || !m.tickets) return;
  var tk = m.tickets[idx];
  if(!tk) return;

  // 연결된 레슨 수 파악
  var linkedLessons = lsLessons.filter(function(l){
    if(l.memberId !== m.id) return false;
    if(tk.id && l.ticketId === tk.id) return true;
    if(l.ticketIdx === idx) return true;
    return false;
  });

  if(!confirm('이용권을 삭제하면 연결된 레슨 예약 '+linkedLessons.length+'건과 포인트 적립 내역도 함께 삭제됩니다.\n정말 삭제할까요?')) return;

  // ① 연결된 모든 레슨 삭제 (출석/결석 포함)
  lsLessons = lsLessons.filter(function(l){
    if(l.memberId !== m.id) return true;
    if(tk.id && l.ticketId === tk.id) return false;
    if(l.ticketIdx === idx) return false;
    return true;
  });

  // ② 이 이용권 삭제 후 ticketIdx 재정렬 (idx 이후 인덱스 -1)
  lsLessons.forEach(function(l){
    if(l.memberId === m.id && l.ticketIdx != null && l.ticketIdx > idx){
      l.ticketIdx -= 1;
    }
  });

  // ③ 이 이용권으로 적립된 포인트 차감
  var saleRec = (m.sales||[]).find(function(s){ return s.ticketId === tk.id; });
  if(saleRec && saleRec.payAmount > 0){
    var earned = Math.floor(saleRec.payAmount * 0.02);
    if(earned > 0 && m.points){
      var before = m.points;
      m.points = Math.max(0, m.points - earned);
      if(!m.pointHistory) m.pointHistory = [];
      m.pointHistory.push({
        type: 'deduct',
        amount: earned,
        reason: '이용권 삭제 포인트 환수',
        balanceAfter: m.points,
        createdAt: Date.now()
      });
    }
  }

  // ④ 판매내역에서도 제거
  if(m.sales) m.sales = m.sales.filter(function(s){ return s.ticketId !== tk.id; });

  // ⑤ 이용권 삭제
  m.tickets.splice(idx, 1);

  saveState();
  lsRender();
  mbdRenderTickets();
  mbdRenderSales();
  mbdRenderHome();
  mbdRenderPointHistory();
  showToast('이용권 삭제 완료 · 연결 레슨 '+linkedLessons.length+'건 삭제됨', 'ok');
}

