











<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<title>JMS</title>
<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Pretendard','Apple SD Gothic Neo','Malgun Gothic',sans-serif;background:#f2f3f6;color:#1a1a1a;font-size:14px}
.app{max-width:1600px;margin:0 auto;padding:20px 28px 20px}
/* ── 페이지 헤더 (전체 너비 서브바) ── */
.page-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;height:56px;
  background:#fff;
  border-bottom:1px solid #e8ecf0;
  flex-shrink:0;
}
.page-header-left{display:flex;align-items:center;gap:12px}
.page-header .tab-btn{border-bottom:3px solid transparent;margin-bottom:-1px}
.page-header-accent{display:none}
.page-header-title{font-size:15px;font-weight:700;color:#111;letter-spacing:-.2px;display:flex;align-items:center;gap:7px}
.page-header-title::before{content:'';display:inline-block;width:3px;height:14px;border-radius:2px;background:#3b82f6;flex-shrink:0}
.page-header-right{display:flex;align-items:center;gap:8px}
.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.header .time{font-size:14px;color:#666;font-variant-numeric:tabular-nums;font-weight:600}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.sc{background:#fff;border-radius:10px;padding:12px 14px;text-align:center;border:1px solid #e8e8e8;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.sl{font-size:11px;color:#888;margin-bottom:4px}
.sv{font-size:24px;font-weight:700;color:#111}
.sv.green{color:#1a8a5e}.sv.amber{color:#c07000}.sv.red{color:#d03030}
.main{display:grid;grid-template-columns:1fr 380px;gap:16px}
.sec-title{font-size:11px;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px}
.form-title{font-size:13px;font-weight:700;color:#333;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;gap:6px}
.legend{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px}
.li{display:flex;align-items:center;gap:4px;font-size:11px;color:#666}
.ld{width:10px;height:10px;border-radius:3px;flex-shrink:0}
.ld.empty{background:#f0f0f0;border:1px solid #ddd}
.ld.occ{background:#bdd6f0}.ld.les{background:#b8dda0}.ld.rles{background:#cbc8f5}
.ld.sug{background:#d4f0e0;border:2px solid #1a8a5e}
.ld.blk{background:#ffe0e0;border:2px dashed #d05050}.ld.urg{background:#ffcccc;border:2px solid #d03030}

/* Next lesson */
.nl-panel{background:#fff;border:1px solid #e8e8e8;border-radius:10px;padding:12px 14px;margin-bottom:14px;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.nl-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.nl-ttl{font-size:12px;font-weight:700;color:#444}
.nl-clr{font-size:11px;color:#aaa;cursor:pointer;border:none;background:none;padding:0;font-family:inherit}
.nl-clr:hover{color:#888}
.nl-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.nl-lbl{font-size:11px;color:#666;white-space:nowrap}
.nl-inp{font-size:13px;padding:5px 8px;border:1px solid #ddd;border-radius:6px;background:#fff;color:#111;font-family:inherit;outline:none;width:110px}
.nl-inp:focus{border-color:#90bce0}
.nl-btn{background:#1a5fa0;color:#fff;border:none;border-radius:6px;padding:6px 14px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit}
.nl-btn:hover{background:#144880}
.nl-res{margin-top:10px;padding:10px 12px;border-radius:8px;font-size:12px;line-height:1.6}
.nl-res.ok{background:#f0faf4;border:1px solid #8cc870;color:#1a5010}
.nl-res.warn{background:#fff8e0;border:1px solid #e0c040;color:#6a4800}
.nl-res.none{background:#fff0f0;border:1px solid #e09090;color:#8a2020}



/* Zone bars */
.zone-bar{display:grid;grid-template-columns:repeat(6,1fr);gap:6px;margin-bottom:3px}
.zc{text-align:center;font-size:9px;font-weight:700;padding:2px 0;border-radius:4px 4px 0 0}
.za{background:#e8f4ff;color:#1a4a80}.zb{background:#fff0e0;color:#804000}
.zcc{background:#f0ffe0;color:#1a5010}.zd{background:#fff0f8;color:#80204a}

/* Bay grids */
.room-row{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:14px;max-width:360px}
.bay-top{display:grid;grid-template-columns:repeat(6,1fr);gap:6px;margin-bottom:6px}
.bay-bot{display:grid;grid-template-columns:repeat(6,1fr);gap:6px;margin-bottom:4px}
.bay-arrow{display:flex;justify-content:space-between;font-size:10px;color:#aaa;margin-bottom:14px;padding:0 2px}

/* Bay card */
.bay{border:1px solid #e0e0e0;border-radius:8px;padding:0 0 6px;cursor:pointer;background:#fff;min-height:160px;position:relative;transition:box-shadow .15s,border-color .15s;display:flex;flex-direction:column}
.bay:hover{box-shadow:0 2px 8px rgba(0,0,0,.1);border-color:#bbb}
.bay.occ{background:#e0faf2;border-color:#00c98a}
.bay.les{background:#e0faf2;border-color:#00c98a}
.bay.rles{background:#e0faf2;border-color:#00c98a}
.bay.urg-lo{border-color:#f0a040!important;background:#fffae8!important}
.bay.urg-hi{border-color:#d03030!important;background:#fff4f4!important;animation:pulse 1.4s infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(208,48,48,0)}50%{box-shadow:0 0 0 4px rgba(208,48,48,.18)}}
.bay.sug-best{outline:2px solid #1a8a5e;background:#f0faf4!important;border-color:#1a8a5e!important}
.bay.sug-blk{outline:2px dashed #d05050;background:#fff4f4!important;border-color:#d05050!important}
/* 타석번호 뚜껑 */
.b-cap{border-radius:7px 7px 0 0;padding:2px 4px 2px 7px;font-size:11px;font-weight:700;color:#fff;background:#00b87f;letter-spacing:.2px;flex-shrink:0;display:flex;align-items:center;justify-content:space-between;gap:2px}
.b-cap-lbl{flex:1;white-space:nowrap}
.b-cap-btns{display:flex;gap:2px;flex-shrink:0}
.bay.occ .b-cap{background:#00b87f}
.bay.les .b-cap{background:#00b87f}
.bay.rles .b-cap{background:#00b87f}
.bay.empty-bay .b-cap{background:#bbb}
.empty-cap{background:#ccc!important}
/* 뚜껑 아래 콘텐츠 패딩 */
.b-body{padding:6px 7px 0;display:flex;flex-direction:column;flex:1}

/* Bay inner */
/* Bay header row */
.b-header{display:flex;align-items:center;gap:4px;margin-bottom:4px;flex-wrap:nowrap}
.b-num{font-size:12px;font-weight:700;color:#666;white-space:nowrap;flex-shrink:0;margin-bottom:3px}
.b-name{font-size:13px;font-weight:700;color:#222;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.b-tag{display:inline-block;font-size:11px;padding:2px 6px;border-radius:3px;font-weight:700;margin:2px 0 1px}
.bay.occ .b-tag{background:#b0f0da;color:#005c40}
.bay.les .b-tag{background:#b8dda0;color:#1a5010}
.bay.rles .b-tag{background:#cbc8f5;color:#2a1870}
.b-times{font-size:13px;font-weight:600;color:#555;margin-top:auto;margin-bottom:2px;letter-spacing:.2px}
.b-rem{font-size:13px;font-weight:700;margin-top:4px;letter-spacing:-.3px}
.bay.occ .b-rem,.bay.les .b-rem{color:#007a55}.bay.rles .b-rem{color:#2a1870}
.b-rem.lo{color:#c07000!important}.b-rem.hi{color:#c03030!important}.b-rem.exp{color:#c03030!important;font-size:13px}
/* Gauge bar */
.b-gauge-wrap{position:relative;height:19px;border-radius:6px;overflow:hidden}
.b-gauge-fill{position:absolute;left:0;top:0;height:100%;border-radius:6px;transition:width .8s linear}
.b-gauge-lbl{position:absolute;left:0;right:0;top:0;bottom:0;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#222;text-shadow:none;white-space:nowrap;overflow:hidden;letter-spacing:-.8px}
.b-wait{display:block;font-size:9px;background:#fff3cd;border:1px solid #ffc107;border-radius:3px;color:#856404;padding:1px 4px;margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:600}
.b-sug-badge{display:inline-block;font-size:9px;padding:1px 5px;border-radius:3px;font-weight:700;margin-top:2px;background:#d4f0e4;color:#0e6640}
.b-blk-badge{display:inline-block;font-size:9px;padding:1px 5px;border-radius:3px;font-weight:700;margin-top:2px;background:#ffe0e0;color:#a02020}
.b-lesson-badge{display:inline-block;font-size:8px;padding:1px 6px;border-radius:8px;font-weight:800;background:#0e6640;color:#fff;letter-spacing:.2px}

/* Buttons on bay */
.b-btns{display:flex;gap:3px;margin-bottom:2px}
.end-btn,.mk-btn{font-size:9px;padding:2px 5px;border-radius:4px;cursor:pointer;font-weight:700;line-height:1.4;border:1px solid}
.dur-btn{font-size:13px;padding:3px 7px;border-radius:4px;cursor:pointer;font-weight:700;line-height:1.4;border:1px solid}
.end-btn{border-color:#e09090;color:#c03030;background:#fff}.end-btn:hover{background:#fde8e8}
.dur-btn{border-color:#90bce0;color:#1a4a80;background:#fff}.dur-btn:hover{background:#e8f4ff}
/* cap 안에 들어가는 버튼 (뚜껑 배경에 맞게 오버라이드) */
.b-cap .end-btn{background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.4);color:#fff;font-size:9px;padding:1px 5px}
.b-cap .end-btn:hover{background:rgba(255,255,255,0.3)}
.b-cap .mv-btn{background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.4);color:#fff;font-size:9px;padding:1px 5px}
.b-cap .mv-btn:hover{background:rgba(255,255,255,0.3)}
.b-cap .dur-btn{background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.4);color:#fff;font-size:14px;padding:0px 5px;line-height:1.4}
.b-cap .dur-btn:hover{background:rgba(255,255,255,0.3)}

/* ── Member detail ticket tab ── */
.mbd-ticket-card{background:#fff;border:1.5px solid #e0e8f0;border-radius:10px;padding:12px 14px;margin-bottom:8px;position:relative;transition:box-shadow .15s}
.mbd-ticket-card:hover{box-shadow:0 2px 8px rgba(0,0,0,.08)}
.mbd-ticket-card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:6px}
.mbd-ticket-card-name{font-size:13px;font-weight:800;color:#1a1a1a;line-height:1.3}
.mbd-ticket-card-group{font-size:11px;color:#888;margin-top:1px}
.mbd-ticket-badge{display:inline-flex;align-items:center;font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;white-space:nowrap}
.mbd-ticket-card-meta{display:flex;flex-wrap:wrap;gap:8px 14px;font-size:11px;color:#666;margin-bottom:4px}
.mbd-ticket-card-meta span{display:flex;align-items:center;gap:3px}
.mbd-ticket-card-meta strong{color:#333;font-weight:700}
.mbd-ticket-card-del{position:absolute;top:10px;right:12px;background:none;border:none;color:#ccc;cursor:pointer;font-size:15px;line-height:1;padding:2px;transition:color .12s}
.mbd-ticket-card-del:hover{color:#c03030}
.mbd-tk-select-row{display:flex;align-items:center;gap:8px;padding:9px 12px;border:1.5px solid #e0e0e0;border-radius:8px;cursor:pointer;background:#fff;transition:all .14s;font-family:inherit;width:100%;text-align:left}
.mbd-tk-select-row:hover{border-color:#90bce0;background:#f5f9ff}
.mbd-tk-select-row.selected{border-color:#1a5fa0;background:#eaf3fc}
.mbd-tk-item-row{display:flex;align-items:center;gap:8px;padding:7px 12px;border:1px solid #e8e8e8;border-radius:7px;cursor:pointer;background:#fafafa;transition:all .14s;font-family:inherit;width:100%;text-align:left}
.mbd-tk-item-row:hover{border-color:#90bce0;background:#f5f9ff}
.mbd-tk-item-row.selected{border-color:#1a5fa0;background:#eaf3fc}
.mbd-pay-btn.selected{border-color:#1a5fa0!important;background:#eaf3fc!important;color:#1a4a80!important}
/* ── 레슨 회원명 검색 드롭다운 ── */
.ls-member-item{
  display:flex;align-items:center;gap:10px;
  padding:9px 14px;cursor:pointer;border-bottom:1px solid #f0f0f0;
  transition:background .1s;
}
.ls-member-item:last-child{border-bottom:none}
.ls-member-item:hover{background:#f0f6ff}
.ls-member-avatar{
  width:32px;height:32px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:800;color:#fff;flex-shrink:0;
}
.ls-member-info{flex:1;min-width:0}
.ls-member-name{font-size:13px;font-weight:700;color:#111}
.ls-member-meta{font-size:11px;color:#999;margin-top:1px}
.ls-member-ticket-badge{
  font-size:10px;font-weight:700;padding:2px 7px;border-radius:8px;
  white-space:nowrap;flex-shrink:0;
}
.ls-member-ticket-badge.ok{background:#dcfce7;color:#166534}
.ls-member-ticket-badge.none{background:#fef3c7;color:#92400e}
.ls-tk-panel-header{
  display:flex;align-items:center;gap:10px;
  padding:10px 14px;background:#f8fafc;border-bottom:1px solid #e8ecf0;
}
.ls-tk-member-chip{display:flex;align-items:center;gap:8px;flex:1;min-width:0}
.ls-tk-chip-name{font-size:13px;font-weight:800;color:#111}
.ls-tk-chip-meta{font-size:11px;color:#888}
.ls-tk-change-btn{
  font-size:11px;color:#1a5fa0;background:none;border:1px solid #90bce0;
  border-radius:5px;padding:3px 9px;cursor:pointer;font-family:inherit;font-weight:600;
  white-space:nowrap;flex-shrink:0;
}
.ls-tk-change-btn:hover{background:#eaf3fc}
.ls-tk-tickets{padding:10px 14px}
.ls-tk-ticket-row{
  display:flex;align-items:center;gap:8px;
  padding:8px 10px;border-radius:8px;border:1.5px solid #e0e0e0;
  margin-bottom:6px;cursor:pointer;background:#fff;transition:all .14s;
  font-family:inherit;width:100%;text-align:left;
}
.ls-tk-ticket-row:last-child{margin-bottom:0}
.ls-tk-ticket-row:hover{border-color:#90bce0;background:#f5f9ff}
.ls-tk-ticket-row.selected{border-color:#1a5fa0;background:#eaf3fc}
.ls-tk-ticket-row.unavail{opacity:.5;cursor:not-allowed;border-color:#e0e0e0;background:#f8f8f8}
.ls-tk-no-ticket{text-align:center;padding:16px 0;color:#f59e0b;font-size:12px;font-weight:700}

/* Type symbol picker */
.type-picker{display:flex;gap:6px;margin-top:4px}
.type-opt{flex:1;padding:8px 4px;border:2px solid #e0e0e0;border-radius:8px;cursor:pointer;text-align:center;background:#fff;font-family:inherit;transition:all .15s;user-select:none}
.type-opt:hover{border-color:#bbb;background:#f8f8f8}
.type-opt.selected{border-color:#1a5fa0;background:#eaf3fc}
.type-opt .tp-icon{font-size:20px;display:block;margin-bottom:2px}
.type-opt .tp-lbl{font-size:10px;font-weight:700;color:#555}
.type-opt.selected .tp-lbl{color:#1a4a80}

/* Bulk end */
.bulk-end-btn{background:#fff;border:1.5px solid #e09090;color:#c03030;border-radius:7px;padding:6px 12px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;white-space:nowrap;transition:all .15s}
.bulk-end-btn:hover{background:#fde8e8}
.be-list{display:flex;flex-direction:column;gap:6px;max-height:340px;overflow-y:auto;margin-bottom:12px}
.be-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;border:1px solid #eee;background:#fafafa;cursor:pointer;transition:background .12s}
.be-item:hover{background:#f0f0f0}
.be-item.selected{background:#fff4f4;border-color:#f09090}
.be-cb{width:18px;height:18px;accent-color:#c03030;cursor:pointer;flex-shrink:0}
.be-info{flex:1;min-width:0}
.be-name{font-size:13px;font-weight:700;color:#111}
.be-meta{font-size:10px;color:#888;margin-top:1px}
.be-rem{font-size:11px;font-weight:700;margin-left:auto;flex-shrink:0}
.be-sel-row{display:flex;gap:8px;margin-bottom:10px}
.be-sel-btn{font-size:11px;padding:4px 10px;border-radius:5px;border:1px solid #ddd;background:#fff;cursor:pointer;font-family:inherit;color:#555;font-weight:600}
.be-sel-btn:hover{background:#f0f0f0}
.be-empty{text-align:center;padding:20px;color:#aaa;font-size:12px}
@media(max-width:600px){.bulk-end-btn{font-size:11px;padding:5px 9px}}

/* ── Alert Panel ── */
.alert-panel{
  display:flex;align-items:center;gap:10px;
  min-height:48px;margin-bottom:10px;
  padding:10px 14px;border-radius:10px;
  border:1.5px solid #e8e8e8;background:#fafafa;
  border-left-width:3px;border-left-color:#e0e0e0;
  transition:background .25s,border-color .25s,box-shadow .25s;
  box-shadow:0 1px 4px rgba(0,0,0,.05);
}
.alert-panel.idle-empty{border-left-color:#34c47c;background:#f5fcf8}
.alert-panel.idle-wait{border-left-color:#f5a623;background:#fffbf2}
.alert-panel.mode-assign{border-left-color:#1a5fa0;background:#f0f6ff}
.alert-panel.mode-notif{border-left-color:#f5c842;background:#fffdf0}
.alert-icon{font-size:17px;flex-shrink:0;width:22px;text-align:center}
.alert-body{flex:1;min-width:0}
.alert-name{font-size:13px;font-weight:800;color:#1a1a1a;line-height:1.3}
.alert-msg{font-size:11px;color:#666;margin-top:2px;font-weight:500}
.alert-close{
  background:#fff;border:1.5px solid #bbb;border-radius:6px;
  color:#555;cursor:pointer;font-size:12px;font-weight:700;
  padding:5px 12px;font-family:inherit;flex-shrink:0;
  transition:background .15s,color .15s,border-color .15s;
}
.alert-close:hover{background:#f0f0f0;color:#333;border-color:#999}
.alert-close:empty{display:none}
.alert-panel.mode-assign .alert-close{
  background:#fff;border-color:#1a5fa0;color:#1a5fa0;
}
.alert-panel.mode-assign .alert-close:hover{background:#e8f0fb;border-color:#144880;color:#144880}

/* Tabs */
.tab-bar{display:flex;gap:0;margin-bottom:16px;border-bottom:2px solid #e0e0e0}
.tab-btn{padding:6px 16px;font-size:12px;font-weight:700;cursor:pointer;border:none;background:none;color:#999;font-family:inherit;border-bottom:3px solid transparent;transition:color .15s,border-bottom-color .15s}
.tab-btn:hover{color:#555}
.tab-btn.active{color:#1a5fa0;border-bottom-color:#1a5fa0}
.tab-pane{display:none}
.tab-pane.active{display:block}

/* Wait-only tab full layout */
.wait-full{display:grid;grid-template-columns:1fr 400px;gap:16px}
.wait-full-list{background:#fff;border:1px solid #e8e8e8;border-radius:10px;padding:14px;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.wf-title{font-size:13px;font-weight:700;color:#111;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center}
.wf-count{font-size:11px;color:#888;font-weight:400}

/* Panel */
.pbox{background:#fff;border:1px solid #e8e8e8;border-radius:10px;padding:14px;margin-bottom:12px;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.w-empty{text-align:center;padding:20px;color:#aaa;font-size:12px}
.wi{padding:8px 0;border-bottom:1px solid #f0f0f0}
.wi:last-child{border-bottom:none}
.wi-top{display:flex;align-items:center;gap:8px}
.wrank{width:22px;height:22px;border-radius:50%;background:#f0f0f0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#888;flex-shrink:0}
.wrank.first{background:#f0f0f0;color:#888}
.winfo{flex:1;min-width:0}
.wname{font-size:13px;font-weight:700;color:#111}
.wmeta{font-size:11px;color:#888;margin-top:1px}
.w-wait-time{color:#111;font-weight:600}
.wtype-badge{display:inline-block;font-size:10px;font-weight:700;padding:1px 6px;border-radius:4px;margin-right:4px;vertical-align:middle}
.wtype-fac{background:#e0f2fe;color:#0369a1;border:1px solid #7dd3fc}
.wtype-les{background:#ffe4ec;color:#9d174d;border:1px solid #fca5a5}
