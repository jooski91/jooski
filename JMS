function mbdSaveBulkBook(){
  var m = members.find(function(x){ return x.id===mbDetailId; });
  if(!m||_mbdActionTicketIdx===null){ showToast('오류: 이용권 정보 없음','warn'); return; }
  var tk = m.tickets[_mbdActionTicketIdx];
  if(!tk) return;

  var startDate = document.getElementById('tk-bulk-startdate').value;
  var endDate   = document.getElementById('tk-bulk-enddate').value;
  var timeVal   = document.getElementById('tk-bulk-time').value || '09:00';
  var durVal    = parseInt(document.getElementById('tk-bulk-dur').value,10) || 30;
  if(!startDate||!endDate){ showToast('시작일/종료일을 입력해주세요','warn'); return; }

  var selDays = [];
  for(var d=0;d<7;d++){
    var lbl = document.getElementById('tk-bulk-day-'+d);
    if(lbl && lbl.dataset.sel==='1') selDays.push(d);
  }
  if(!selDays.length){ showToast('요일을 하나 이상 선택해주세요','warn'); return; }

  // ── 잔여 횟수 계산 ──
  var it = tkItems.find(function(x){ return +x.id===+tk.itemId; });
  var totalCount = (tk.totalCount!=null) ? tk.totalCount : (it&&it.count ? +it.count : null);
  var usedCount = lsLessons.filter(function(l){
    if(l.memberId !== m.id) return false;
    if(tk.id && l.ticketId===tk.id) return true;
    if(l.ticketIdx===_mbdActionTicketIdx) return true;
    return false;
  }).length; // 출석/결석/예정 전부 이미 소진된 것으로 간주
  var remain = (totalCount!=null) ? Math.max(0, totalCount - usedCount) : null;

  // ── start/end 시간 문자열 계산 ──
  function calcEnd(startStr, mins){
    var parts = startStr.split(':');
    var h = parseInt(parts[0],10), min = parseInt(parts[1],10);
    min += mins;
    h += Math.floor(min/60); min = min%60;
    if(h>=24) h=23, min=59;
    return ('0'+h).slice(-2)+':'+('0'+min).slice(-2);
  }
  var endTime = calcEnd(timeVal, durVal);

  // ── 날짜 순회하며 예약 생성 ──
  var cur = new Date(startDate+'T00:00:00');
  var endD = new Date(endDate+'T00:00:00');
  var added = 0;
  var skipped = 0; // 잔여 초과로 못 넣은 수

  while(cur <= endD){
    if(selDays.indexOf(cur.getDay()) >= 0){
      // 잔여 횟수 소진 시 중단
      if(remain !== null && added >= remain){
        skipped++;
        cur.setDate(cur.getDate()+1);
        continue;
      }
      lsLessons.push({
        id: lsLessonId++,
        instructor: tk.pro || '',
        student: m.name,
        date: cur.toISOString().slice(0,10),
        start: timeVal,
        end: endTime,
        duration: durVal,
        bay: '',
        memo: '',
        memberId: m.id,
        ticketIdx: _mbdActionTicketIdx,
        ticketId: tk.id || null,
        status: ''
      });
      added++;
    }
    cur.setDate(cur.getDate()+1);
  }

  saveState();
  document.getElementById('tk-bulkbook-ov').style.display = 'none';
  mbdRenderTickets();
  lsRender();
  if(mbDetailId) mbdRenderHome();

  if(skipped > 0){
    showToast(added+'건 예약 완료 · 잔여 횟수 초과로 '+skipped+'건 제외됨', 'warn');
  } else {
    var remAfter = remain !== null ? ' (잔여 '+(remain-added)+'회)' : '';
    showToast(added+'건 예약 완료'+remAfter, 'ok');
  }
}

