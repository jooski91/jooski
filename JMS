/* ===== HOME ===== */
function homeRender(){
  const now = new Date();
  const mo=now.getMonth()+1, da=now.getDate();
  const emptyBays = bays.filter(b=>b.status==='empty').length;
  const waitCount = waiting.length;

  // ── 이슈 자동 생성 ──
  const issues = [];
  const nowMs = Date.now();

  // 대기 오래된 손님
  waiting.forEach(w=>{
    const mins = Math.floor((nowMs-(w.addedAt||nowMs))/60000);
    if(mins>=20) issues.push({dot:'red', text:w.name+'님 대기 '+mins+'분 초과', time:mins+'분 전'});
  });

  // 타석 시간 초과 / 임박
  const allSlots=[...bays,...rooms];
  allSlots.forEach(b=>{
    if(b.status==='active'&&b.startTime){
      const elapsed=Math.floor((nowMs-b.startTime)/60000);
      const remain=(b.dur||75)-elapsed;
      const label=b.type==='룸레슨'?b.num+'번 룸':b.num+'번 타석';
      if(remain<0) issues.push({dot:'red',text:label+' '+b.name+'님 시간 초과',time:Math.abs(remain)+'분 초과'});
      else if(remain<=10) issues.push({dot:'yellow',text:label+' '+b.name+'님 잔여 '+remain+'분',time:remain+'분 남음'});
    }
  });

  // 오늘 레슨 일정
  const todayStr=now.getFullYear()+'-'+String(mo).padStart(2,'0')+'-'+String(da).padStart(2,'0');
  const todayLessons=(typeof lsLessons!=='undefined')?lsLessons.filter(l=>l.date===todayStr):[];
  if(todayLessons.length>0) issues.push({dot:'blue',text:'오늘 레슨 '+todayLessons.length+'건 예정',time:'오늘'});

  // 빈 타석 + 대기 동시
  if(waitCount>0&&emptyBays>0) issues.push({dot:'green',text:'빈 타석 '+emptyBays+'개 · 대기 '+waitCount+'명 안내 필요',time:'지금'});

  const issueEl=document.getElementById('home-issues');
  document.getElementById('home-issue-count').textContent=issues.length+'건';
  issueEl.innerHTML = issues.length===0
    ? '<div class="home-empty">✅ 현재 이슈가 없습니다</div>'
    : issues.map(i=>`
      <div class="home-issue-row">
        <div class="home-issue-dot ${i.dot}"></div>
        <div class="home-issue-text">${i.text}</div>
        <div class="home-issue-time">${i.time}</div>
      </div>`).join('');
}

