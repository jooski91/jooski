══════════════════════════════════════════ */
(function(){
  var _rsz = null;
  var SLOT_MIN = 30; // 최소 30분

  function startResize(e, lessonId, block){
    e.stopPropagation(); e.preventDefault();
    var l = lsLessons.find(function(x){ return x.id===lessonId; });
    if(!l) return;
    var slotH = window.SLOT_H||28;
