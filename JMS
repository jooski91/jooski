    if(cash)     displayParts.push('현금 '+cash.toLocaleString()+'원');
    if(transfer) displayParts.push('이체 '+transfer.toLocaleString()+'원');
    sumEl.innerHTML = displayParts.join(' + ')+(remain > 0 ? ' <span style="color:#c03030;font-weight:700">· 미수금 '+remain.toLocaleString()+'원</span>' : remain < 0 ? ' <span style="color:#c07000;font-weight:700">· 초과 '+Math.abs(remain).toLocaleString()+'원</span>' : ' <span style="color:#16a34a;font-weight:700">· 완납</span>');
  } else {
    sumEl.style.display = 'none';
  }
}

